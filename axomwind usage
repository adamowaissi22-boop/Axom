local function createButton(parent, text, callback)
    local button = Instance.new("TextButton")
    button.Parent = parent
    button.Text = text
    button.AutoButtonColor = false
    AxomWind.style(button, "w-full bg-blue-600 rounded-lg py-3 text-white font-semibold text-size-base")
    
    local function onHover()
        button.BackgroundColor3 = Color3.fromRGB(37, 99, 235)
    end
    
    local function onLeave()
        button.BackgroundColor3 = Color3.fromRGB(37, 99, 235)
    end
    
    button.MouseEnter:Connect(onHover)
    button.MouseLeave:Connect(onLeave)
    button.MouseButton1Click:Connect(callback)
    
    return button
end

local function createToggle(parent, labelText, defaultState, callback)
    local container = Instance.new("Frame")
    container.Parent = parent
    AxomWind.style(container, "w-full bg-gray-750 rounded-lg py-2 px-3")
    container.AutomaticSize = Enum.AutomaticSize.Y
    
    local label = Instance.new("TextLabel")
    label.Parent = container
    label.Text = labelText
    label.TextXAlignment = Enum.TextXAlignment.Left
    AxomWind.style(label, "text-gray-200 text-size-base font-medium")
    label.Size = UDim2.new(0.7, 0, 0, 32)
    label.BackgroundTransparency = 1
    
    local toggleButton = Instance.new("TextButton")
    toggleButton.Parent = container
    toggleButton.Text = ""
    toggleButton.Size = UDim2.new(0, 48, 0, 24)
    toggleButton.Position = UDim2.new(1, -52, 0.5, -12)
    AxomWind.style(toggleButton, "rounded-full border-2")
    toggleButton.BorderColor3 = Color3.fromRGB(75, 85, 99)
    
    local toggleIndicator = Instance.new("Frame")
    toggleIndicator.Parent = toggleButton
    toggleIndicator.Size = UDim2.new(0, 20, 0, 20)
    toggleIndicator.Position = UDim2.new(0, 2, 0.5, -10)
    AxomWind.style(toggleIndicator, "rounded-full bg-gray-400")
    
    local state = defaultState
    
    local function updateToggle()
        if state then
            toggleButton.BackgroundColor3 = Color3.fromRGB(34, 197, 94)
            toggleButton.BorderColor3 = Color3.fromRGB(34, 197, 94)
            toggleIndicator.Position = UDim2.new(1, -22, 0.5, -10)
            toggleIndicator.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        else
            toggleButton.BackgroundColor3 = Color3.fromRGB(31, 41, 55)
            toggleButton.BorderColor3 = Color3.fromRGB(75, 85, 99)
            toggleIndicator.Position = UDim2.new(0, 2, 0.5, -10)
            toggleIndicator.BackgroundColor3 = Color3.fromRGB(156, 163, 175)
        end
    end
    
    toggleButton.MouseButton1Click:Connect(function()
        state = not state
        updateToggle()
        callback(state)
    end)
    
    updateToggle()
    
    return {
        setState = function(newState)
            state = newState
            updateToggle()
        end,
        getState = function()
            return state
        end
    }
end

local function createSlider(parent, labelText, min, max, default, callback)
    local container = Instance.new("Frame")
    container.Parent = parent
    AxomWind.style(container, "w-full bg-gray-750 rounded-lg py-2 px-3")
    container.AutomaticSize = Enum.AutomaticSize.Y
    
    local label = Instance.new("TextLabel")
    label.Parent = container
    label.Text = labelText
    label.TextXAlignment = Enum.TextXAlignment.Left
    AxomWind.style(label, "text-gray-200 text-size-base font-medium")
    label.Size = UDim2.new(0.7, 0, 0, 24)
    label.BackgroundTransparency = 1
    
    local valueLabel = Instance.new("TextLabel")
    valueLabel.Parent = container
    valueLabel.Text = tostring(default)
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right
    AxomWind.style(valueLabel, "text-gray-400 text-size-sm")
    valueLabel.Size = UDim2.new(0.3, 0, 0, 24)
    valueLabel.BackgroundTransparency = 1
    
    local sliderBar = Instance.new("Frame")
    sliderBar.Parent = container
    sliderBar.Size = UDim2.new(1, 0, 0, 4)
    sliderBar.Position = UDim2.new(0, 0, 1, -8)
    AxomWind.style(sliderBar, "bg-gray-700 rounded-full")
    
    local sliderFill = Instance.new("Frame")
    sliderFill.Parent = sliderBar
    sliderFill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    AxomWind.style(sliderFill, "bg-blue-600 rounded-full")
    
    local sliderHandle = Instance.new("Frame")
    sliderHandle.Parent = container
    sliderHandle.Size = UDim2.new(0, 16, 0, 16)
    sliderHandle.Position = UDim2.new((default - min) / (max - min), -8, 1, -12)
    AxomWind.style(sliderHandle, "bg-white rounded-full shadow-md")
    
    local value = default
    local dragging = false
    
    local function updateSlider(inputPosition)
        local relativePos = math.clamp((inputPosition.X - sliderBar.AbsolutePosition.X) / sliderBar.AbsoluteSize.X, 0, 1)
        value = min + (relativePos * (max - min))
        value = math.floor(value * 100) / 100
        
        sliderFill.Size = UDim2.new(relativePos, 0, 1, 0)
        sliderHandle.Position = UDim2.new(relativePos, -8, 1, -12)
        valueLabel.Text = tostring(value)
        
        callback(value)
    end
    
    sliderHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            updateSlider(input.Position)
        end
    end)
    
    sliderBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            updateSlider(input.Position)
        end
    end)
    
    game:GetService("UserInputService").InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateSlider(input.Position)
        end
    end)
    
    game:GetService("UserInputService").InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    return {
        setValue = function(newValue)
            value = math.clamp(newValue, min, max)
            local relativePos = (value - min) / (max - min)
            sliderFill.Size = UDim2.new(relativePos, 0, 1, 0)
            sliderHandle.Position = UDim2.new(relativePos, -8, 1, -12)
            valueLabel.Text = tostring(value)
            callback(value)
        end,
        getValue = function()
            return value
        end
    }
end

local function createDropdown(parent, labelText, options, defaultIndex, callback)
    local container = Instance.new("Frame")
    container.Parent = parent
    AxomWind.style(container, "w-full bg-gray-750 rounded-lg py-2 px-3")
    container.AutomaticSize = Enum.AutomaticSize.Y
    
    local label = Instance.new("TextLabel")
    label.Parent = container
    label.Text = labelText
    label.TextXAlignment = Enum.TextXAlignment.Left
    AxomWind.style(label, "text-gray-200 text-size-base font-medium mb-2")
    label.Size = UDim2.new(1, 0, 0, 24)
    label.BackgroundTransparency = 1
    
    local dropdownButton = Instance.new("TextButton")
    dropdownButton.Parent = container
    dropdownButton.Text = options[defaultIndex] or options[1]
    AxomWind.style(dropdownButton, "w-full bg-gray-700 rounded-lg py-2 text-gray-200 text-size-sm")
    
    local dropdownFrame = Instance.new("Frame")
    dropdownFrame.Parent = container
    AxomWind.style(dropdownFrame, "w-full bg-gray-700 rounded-lg mt-1")
    dropdownFrame.Visible = false
    dropdownFrame.AutomaticSize = Enum.AutomaticSize.Y
    
    local dropdownList = Instance.new("UIListLayout")
    dropdownList.Parent = dropdownFrame
    dropdownList.Padding = UDim.new(0, 4)
    
    local selectedIndex = defaultIndex
    
    for i, option in ipairs(options) do
        local optionButton = Instance.new("TextButton")
        optionButton.Parent = dropdownFrame
        optionButton.Text = option
        AxomWind.style(optionButton, "w-full bg-transparent text-gray-300 text-size-sm py-2")
        optionButton.BackgroundTransparency = 0.9
        
        optionButton.MouseEnter:Connect(function()
            optionButton.BackgroundColor3 = Color3.fromRGB(55, 65, 81)
        end)
        
        optionButton.MouseLeave:Connect(function()
            optionButton.BackgroundColor3 = Color3.fromRGB(55, 65, 81)
        end)
        
        optionButton.MouseButton1Click:Connect(function()
            selectedIndex = i
            dropdownButton.Text = option
            dropdownFrame.Visible = false
            callback(option, i)
        end)
    end
    
    dropdownButton.MouseButton1Click:Connect(function()
        dropdownFrame.Visible = not dropdownFrame.Visible
    end)
    
    return {
        setSelected = function(index)
            selectedIndex = index
            dropdownButton.Text = options[index]
            callback(options[index], index)
        end,
        getSelected = function()
            return selectedIndex
        end
    }
end

local function createInput(parent, labelText, placeholder, default, callback)
    local container = Instance.new("Frame")
    container.Parent = parent
    AxomWind.style(container, "w-full bg-gray-750 rounded-lg py-2 px-3")
    container.AutomaticSize = Enum.AutomaticSize.Y
    
    local label = Instance.new("TextLabel")
    label.Parent = container
    label.Text = labelText
    label.TextXAlignment = Enum.TextXAlignment.Left
    AxomWind.style(label, "text-gray-200 text-size-base font-medium mb-2")
    label.Size = UDim2.new(1, 0, 0, 24)
    label.BackgroundTransparency = 1
    
    local inputBox = Instance.new("TextBox")
    inputBox.Parent = container
    inputBox.Text = default or ""
    inputBox.PlaceholderText = placeholder
    AxomWind.style(inputBox, "w-full bg-gray-700 rounded-lg py-2 px-3 text-gray-200 text-size-sm")
    inputBox.ClearTextOnFocus = false
    
    inputBox:GetPropertyChangedSignal("Text"):Connect(function()
        callback(inputBox.Text)
    end)
    
    return {
        setText = function(text)
            inputBox.Text = text
        end,
        getText = function()
            return inputBox.Text
        end
    }
end

