local function makeButton(text, color)
    local btn = Instance.new("TextButton")
    btn.Name = "Button"
    btn.Parent = content
    btn.Size = UDim2.new(1, 0, 0, 40)
    btn.BackgroundColor3 = color or Color3.fromRGB(40, 40, 50)
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 16
    btn.AutoButtonColor = false
    
    local btncorner = Instance.new("UICorner")
    btncorner.CornerRadius = UDim.new(0, 8)
    btncorner.Parent = btn
    
    local btnstroke = Instance.new("UIStroke")
    btnstroke.Thickness = 1.5
    btnstroke.Color = Color3.fromRGB(100, 100, 255)
    btnstroke.Transparency = 0.5
    btnstroke.Parent = btn
    
    local btngradient = Instance.new("UIGradient")
    btngradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, color or Color3.fromRGB(40, 40, 50)),
        ColorSequenceKeypoint.new(1, (color or Color3.fromRGB(40, 40, 50)):Lerp(Color3.fromRGB(0, 0, 0), 0.2))
    })
    btngradient.Rotation = 90
    btngradient.Parent = btn
    
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = (color or Color3.fromRGB(40, 40, 50)):Lerp(Color3.fromRGB(255, 255, 255), 0.1)}):Play()
        TweenService:Create(btnstroke, TweenInfo.new(0.2), {Transparency = 0}):Play()
    end)
    
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = color or Color3.fromRGB(40, 40, 50)}):Play()
        TweenService:Create(btnstroke, TweenInfo.new(0.2), {Transparency = 0.5}):Play()
    end)
    
    btn.MouseButton1Click:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(100, 100, 255)}):Play()
        TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = color or Color3.fromRGB(40, 40, 50)}):Play()
    end)
    
    return btn
end

