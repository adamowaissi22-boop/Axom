local function removeVIP()
    table.clear(removedVIP)
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name:lower():find("vip") then
            removedVIP[#removedVIP + 1] = { clone = obj:Clone(), parent = obj.Parent }
            obj:Destroy()
        end
    end
end

local function bringBackVIP()
    for _, data in ipairs(removedVIP) do
        if data.parent and data.clone then
            data.clone.Parent = data.parent
        end
    end
    table.clear(removedVIP)
end

local function deleteWalls()
    table.clear(removedWalls)
    for _, obj in ipairs(workspace:GetDescendants()) do
        local cleanName = obj.Name:lower():gsub("%s","")
        if cleanName:find("rightwall") and obj.Parent then
            table.insert(removedWalls, {clone = obj:Clone(), parent = obj.Parent})
            obj:Destroy()
        end
    end
    wallsDeleted = true
end

local function undoWalls()
    for _, data in ipairs(removedWalls) do
        if data.parent and data.clone then
            data.clone.Parent = data.parent
        end
    end
    table.clear(removedWalls)
    wallsDeleted = false
end

local function applyPrompt(prompt)
    if not cache[prompt] then
        cache[prompt] = prompt.HoldDuration
    end
    prompt.HoldDuration = 0
    prompt.RequiresLineOfSight = false
end

local function restorePrompt(prompt)
    if cache[prompt] then
        prompt.HoldDuration = cache[prompt]
    end
end

