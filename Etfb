local function applyTheme(theme)
    currentTheme = themes[theme]
    main.BackgroundColor3 = currentTheme.bg
    stroke.Color = currentTheme.accent
    gradient.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, currentTheme.bg), ColorSequenceKeypoint.new(1, currentTheme.bg2)})
    topbar.BackgroundColor3 = currentTheme.bg2
    title.TextColor3 = currentTheme.text
    themeBtn.BackgroundColor3 = currentTheme.element
    minimize.BackgroundColor3 = currentTheme.element
    close.BackgroundColor3 = currentTheme.element
    mainTabBtn.BackgroundColor3 = mainTabBtn.BackgroundColor3 == currentTheme.accent and currentTheme.accent or currentTheme.element
    creditsTabBtn.BackgroundColor3 = creditsTabBtn.BackgroundColor3 == currentTheme.accent and currentTheme.accent or currentTheme.element
    content.ScrollBarImageColor3 = currentTheme.accent
    for _, v in pairs(content:GetChildren()) do
        if v:IsA("Frame") then
            if v.Name == "Button" then
                v.BackgroundColor3 = currentTheme.element
                local l = v:FindFirstChild("Label")
                if l then l.TextColor3 = currentTheme.text end
            elseif v.Name == "Toggle" then
                v.BackgroundColor3 = currentTheme.element
                local l = v:FindFirstChild("Label")
                if l then l.TextColor3 = currentTheme.text end
                local s = v:FindFirstChild("Switch")
                if s then
                    local c = s:FindFirstChild("Circle")
                    if c then
                        if s.BackgroundColor3 == currentTheme.accent then
                            s.BackgroundColor3 = currentTheme.accent
                        else
                            s.BackgroundColor3 = currentTheme.element
                        end
                    end
                end
            elseif v.Name == "Input" then
                v.BackgroundColor3 = currentTheme.element
                local l = v:FindFirstChild("Label")
                if l then l.TextColor3 = currentTheme.text end
                local b = v:FindFirstChild("Box")
                if b then
                    b.BackgroundColor3 = currentTheme.bg2
                    b.TextColor3 = currentTheme.text
                end
            end
        end
    end
end

themeBtn.MouseButton1Click:Connect(function()
    currentThemeIndex = currentThemeIndex % #themeList + 1
    applyTheme(themeList[currentThemeIndex])
end)

