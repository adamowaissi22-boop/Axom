    createButton("Fly", nil, function() loadstring(game:HttpGet("https://raw.githubusercontent.com/adamowaissi22-boop/Axom/refs/heads/main/Fly%20Script"))() end).Parent = mainSection
    
    local playerSection = createSection("Player")
