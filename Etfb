    btn.Size = UDim2.new(1, -10, 0, 45)
    btn.BackgroundColor3 = color or currentTheme.element
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 10)
    btnCorner.Parent = btn
    local btnStroke = Instance.new("UIStroke")
    btnStroke.Thickness = 1.5
    btnStroke.Color = currentTheme.accent
    btnStroke.Transparency = 0.5
    btnStroke.Parent = btn
    local label = Instance.new("TextLabel")
    label.Name = "Label"
    label.Parent = btn
    label.Size = UDim2.new(1, -20, 1, 0)
    label.Position = UDim2.new(0, 10, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = currentTheme.text
    label.Font = Enum.Font.Gotham
    label.TextSize = 15
    label.TextXAlignment = Enum.TextXAlignment.Left
    local click = Instance.new("TextButton")
    click.Parent = btn
    click.Size = UDim2.new(1, 0, 1, 0)
    click.BackgroundTransparency = 1
    click.Text = ""
    click.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = (color or currentTheme.element):Lerp(currentTheme.text, 0.1)}):Play()
        TweenService:Create(btnStroke, TweenInfo.new(0.2), {Transparency = 0}):Play()
    end)
    click.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = color or currentTheme.element}):Play()
        TweenService:Create(btnStroke, TweenInfo.new(0.2), {Transparency = 0.5}):Play()
    end)
    click.MouseButton1Click:Connect(callback)
    return btn
end

