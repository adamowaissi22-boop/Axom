    "Interactable", "LayoutOrder", "LineHeight", "MidImage", "Name", "Padding", "PaddingBottom", "PaddingLeft",
    "PaddingRight", "PaddingTop", "Parent", "PlaceholderColor3", "PlaceholderText", "Position", "RichText",
    "Rotation", "Scale", "ScaleType", "ScrollBarImageColor3", "ScrollBarImageTransparency", "ScrollBarThickness",
    "ScrollingDirection", "ScrollingEnabled", "SelectionImageObject", "SelectionOrder", "Size", "SizeConstraint",
    "SliceCenter", "SliceScale", "SortOrder", "Text", "TextColor3", "TextDirection", "TextFit", "TextScaled",
    "TextSize", "TextStrokeColor3", "TextStrokeTransparency", "TextTransparency", "TextTruncate", "TextWrapped",
    "TextXAlignment", "TextYAlignment", "Thickness", "TileSize", "TopImage", "Transparency", "VerticalAlignment",
    "VerticalScrollBarInset", "VerticalScrollBarPosition", "Visible", "ZIndex", "ZIndexBehavior"
}
    
    local serializers = {
        ColorSequence = function(seq)
            local points = {}
            for _, kp in ipairs(seq.Keypoints) do
                table.insert(points, string.format("ColorSequenceKeypoint.new(%s, Color3.fromRGB(%d, %d, %d))",
                    kp.Time, kp.Value.R*255, kp.Value.G*255, kp.Value.B*255))
            end
            return string.format("ColorSequence.new({%s})", table.concat(points, ", "))
        end,
        NumberSequence = function(seq)
            local points = {}
            for _, kp in ipairs(seq.Keypoints) do
                table.insert(points, string.format("NumberSequenceKeypoint.new(%s, %s, %s)", kp.Time, kp.Value, kp.Envelope))
            end
            return string.format("NumberSequence.new({%s})", table.concat(points, ", "))
        end,
        Color3 = function(c) return string.format("Color3.fromRGB(%d, %d, %d)", c.R*255, c.G*255, c.B*255) end,
        UDim2 = function(u) return string.format("UDim2.new(%s, %s, %s, %s)", u.X.Scale, u.X.Offset, u.Y.Scale, u.Y.Offset) end,
        UDim = function(u) return string.format("UDim.new(%s, %s)", u.Scale, u.Offset) end,
        Rect = function(r) return string.format("Rect.new(%s, %s, %s, %s)", r.Min.X, r.Min.Y, r.Max.X, r.Max.Y) end,
        Vector2 = function(v) return string.format("Vector2.new(%s, %s)", v.X, v.Y) end,
        Enum = function(e) return tostring(e) end,
        EnumItem = function(e) return tostring(e) end,
        Font = function(f) return string.format("Font.new(%q, Enum.FontWeight.%s, Enum.FontStyle.%s)", f.Family, f.Weight.Name, f.Style.Name) end,
        number = function(n) return tostring(n) end,
        boolean = function(b) return tostring(b) end,
        string = function(s) return string.format("%q", s) end,
    }
    
    local counters = {}
    
    function converter:newname(typ)
        counters[typ] = (counters[typ] or 0) + 1
        return string.format("%s_%d", typ, counters[typ])
    end
    
    function converter:saveobj(obj, parentvar)
        local code = ""
        local name = self:newname(obj.ClassName)
        
        code = code .. string.format("local %s = Instance.new(%q)\n", name, obj.ClassName)
        code = code .. string.format("%s.Parent = %s\n", name, parentvar or "game.CoreGui")
        
        for _, prop in next, propertylist do
            local ok, val = pcall(function() return obj[prop] end)
            if ok and val ~= nil then
                local ser = serializers[typeof(val)]
                if ser then
                    code = code .. string.format("%s.%s = %s\n", name, prop, ser(val))
                end
            end
        end
        
        for _, child in ipairs(obj:GetChildren()) do
            code = code .. self:saveobj(child, name)
        end
        
        return code
    end
    
    function converter:write(obj, path)
        local code = self:saveobj(obj)
        writefile(path, code)
    end
end

