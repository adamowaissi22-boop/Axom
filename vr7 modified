    function brookbring(targetname, returnflag)
        local targetplayer = game.Players[targetname]
        local platform
        if game.Workspace:FindFirstChild("Platform") then
            platform = game.Workspace:FindFirstChild("Platform")
        else
            platform = Instance.new("Part", workspace)
            platform.Name = "Platform"
            platform.Anchored = true
            platform.Size = Vector3.new(200, 1, 200)
            platform.CFrame = CFrame.new(0, -500, 0)
            platform.CanCollide = true
            platform.Transparency = 1
        end
        local startcframe = game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame
        local looptimer = 0
        local waveangle = 0
        while true do
            task.wait()
            looptimer = looptimer + 1
            local sofa = getsofa()
            if not sofa then
                sendnotify("axorcy", "could not find couch tool", 5)
                break
            end
            local targetseat = nil
            if sofa.Seat1.Occupant ~= nil then
                if sofa.Seat1.Occupant and sofa.Seat1.Occupant == targetplayer.Character.Humanoid then
                    targetseat = sofa.Seat1
                elseif sofa.Seat1.Occupant and sofa.Seat1.Occupant ~= targetplayer.Character.Humanoid then
                    if sofa.Seat2.Occupant ~= nil then
                        if sofa.Seat2.Occupant and sofa.Seat2.Occupant == targetplayer.Character.Humanoid then
                            targetseat = sofa.Seat2
                        end
                    else
                        targetseat = sofa.Seat2
                    end
                end
            else
                targetseat = sofa.Seat1
            end
            if targetplayer.Character.Humanoid.Sit and targetplayer.Character.Humanoid.SeatPart == targetseat then
                if returnflag then
                    game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = startcframe
                    game.Players.LocalPlayer.Character.Humanoid:ChangeState("GettingUp")
                else
                    game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = platform.CFrame * CFrame.new(0, 5, 0)
                end
                wait(1)
                sofa.Parent = game.Players.LocalPlayer.Backpack
                break
            end
            if targetplayer.Character.Humanoid.Sit and targetplayer.Character.Humanoid.SeatPart ~= targetseat then
                sendnotify("axorcy", "target sat on wrong seat", 5)
                break
            end
            if sofa.Parent ~= game.Players.LocalPlayer.Character then
                sofa.Parent = game.Players.LocalPlayer.Character
            end
            local verticaloffset = math.sin(waveangle) * 4
            waveangle = waveangle + 0.2
            local targetpos = targetplayer.Character.HumanoidRootPart.Position + Vector3.new(0, -4.5 + verticaloffset, 0) + targetplayer.Character.HumanoidRootPart.CFrame.LookVector * -0.7 + targetplayer.Character.HumanoidRootPart.Velocity * Vector3.new(0.2, 0, 0.2)
            local lookdirection = (targetplayer.Character.HumanoidRootPart.CFrame.LookVector * Vector3.new(1, 0, 1)).Unit
            targetseat.CFrame = CFrame.new(targetpos, targetpos - lookdirection)
            if looptimer >= 200 then
                break
            end
        end
        game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = startcframe
        game.Players.LocalPlayer.Character.Humanoid:ChangeState("GettingUp")
    end
