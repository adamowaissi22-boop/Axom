    function cuffbring()
        if getgenv().Cuff.bring then
            local cufftool = getcuff()
            if not cufftool then
                game:GetService("StarterGui"):SetCore("SendNotification", {
                    Title = "axorcy",
                    Text = "cuff tool not found",
                    Duration = 5
                })
                return
            end
            local deathtimes = {}
            local connections = {}
            local function trackplayerdeath(player)
                local function ondeath(character)
                    local humanoid = character:FindFirstChildOfClass("Humanoid")
                    if humanoid then
                        local deathconn = humanoid.Died:Connect(function()
                            deathtimes[player] = os.time()
                        end)
                        table.insert(connections, deathconn)
                    end
                end
                if player.Character then
                    ondeath(player.Character)
                end
                local addedconn = player.CharacterAdded:Connect(ondeath)
                table.insert(connections, addedconn)
            end
            for _, player in ipairs(game.Players:GetPlayers()) do
                trackplayerdeath(player)
            end
            local playeraddedconn = game.Players.PlayerAdded:Connect(trackplayerdeath)
            table.insert(connections, playeraddedconn)
            task.spawn(function()
                if getgenv().Cuff.throw then
                    local startcframe = game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame
                    while getgenv().Cuff.throw do
                        wait()
                        pcall(function()
                            game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(0, 1000000, 0) * CFrame.Angles(math.rad(-90), 0, 0)
                            game.Players.LocalPlayer.Character.HumanoidRootPart.AssemblyLinearVelocity = Vector3.new()
                            game.Players.LocalPlayer.Character.Humanoid.Sit = true
                        end)
                    end
                    pcall(function()
                        game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = startcframe
                        game.Players.LocalPlayer.Character.Humanoid.Sit = false
                    end)
                end
            end)
            while getgenv().Cuff.bring do
                wait()
                for _, player in ipairs(game.Players:GetPlayers()) do
                    if not getgenv().Cuff.bring then
                        break
                    end
                    if player ~= game.Players.LocalPlayer and player.Character and (not player.Character:FindFirstChild("ForceField") and (not deathtimes[player] or os.time() - deathtimes[player] > 8)) then
                        pcall(function()
                            if cufftool and cufftool.Parent == game.Players.LocalPlayer.Backpack then
                                cufftool.Parent = game.Players.LocalPlayer.Character
                            end
                            cufftool.RemoteEvent:FireServer(player.Character.HumanoidRootPart, "Cuff")
                            task.wait(1.5)
                        end)
                    end
                end
            end
            for _, conn in ipairs(connections) do
                if conn and conn.Connected then
                    conn:Disconnect()
                end
            end
        end
    end
