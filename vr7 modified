        local teleportservice = game:GetService("TeleportService")
        local localplayer = game:GetService("Players").LocalPlayer
        local placeid = game.PlaceId
        local currentjobid = game.JobId
        local folder = "ServerHop"
        local filepath = string.format("%s\\%s.json", folder, tostring(placeid))
        local data = {
            Start = tick(),
            Jobs = {}
        }
        if not isfolder(folder) then
            makefolder(folder)
        end
        local savedata
        if isfile(filepath) then
            savedata = httpservice:JSONDecode(readfile(filepath))
            if tick() - savedata.Start >= config.MaxStore then
                savedata = data
            end
        else
            savedata = data
        end
        if not table.find(savedata.Jobs, currentjobid) then
            table.insert(savedata.Jobs, currentjobid)
        end
        writefile(filepath, httpservice:JSONEncode(savedata))
        local cursor = ""
        local servers = {}
        while cursor and (#servers <= 0 and task.wait(config.CheckInterval / 1000)) do
            local response = (request or httpservice.RequestAsync)({
                Url = "https://games.roblox.com/v1/games/" .. placeid .. "/servers/Public?sortOrder=Desc&limit=100&excludeFullGames=true&cursor=" .. cursor,
                Method = "GET"
            })
            local success, decoded = pcall(function()
                return httpservice:JSONDecode(response.Body)
            end)
            if not (success and (decoded and decoded.data)) then
                break
            end
            for _, server in pairs(decoded.data) do
                if typeof(server) == "table" and (server.id and (tonumber(server.playing) and (tonumber(server.maxPlayers) and (server.playing < server.maxPlayers and not table.find(savedata.Jobs, server.id))))) then
                    table.insert(servers, 1, server.id)
                end
            end
            cursor = decoded.nextPageCursor or nil
        end
        while #servers > 0 and task.wait(config.TeleportInterval / 1000) do
            teleportservice:TeleportToPlaceInstance(placeid, servers[math.random(1, #servers)], localplayer)
        end
    end)
