    function getnearplayers(player, radius)
        local players = game:GetService("Players")
        local nearlist = {}
        local character = player.Character
        if not character then
            return nearlist
        end
        local rootpart = character:FindFirstChild("HumanoidRootPart")
        if not rootpart then
            return nearlist
        end
        for _, otherplayer in ipairs(players:GetPlayers()) do
            if otherplayer ~= player then
                local otherchar = otherplayer.Character
                if otherchar then
                    local otherroot = otherchar:FindFirstChild("HumanoidRootPart")
                    if otherroot then
                        local distance = (rootpart.Position - otherroot.Position).Magnitude
                        if distance <= radius then
                            table.insert(nearlist, {
                                player = otherplayer,
                                distance = distance
                            })
                        end
                    end
                end
            end
        end
        table.sort(nearlist, function(a, b)
            return a.distance < b.distance
        end)
        local result = {}
        for _, item in ipairs(nearlist) do
            table.insert(result, item.player)
        end
        return result
    end
    local function reversetext(text)
        local chars = {}
        for char in text:gmatch(".") do
            table.insert(chars, char)
        end
        local reversed = {}
        for i = #chars, 1, -1 do
            table.insert(reversed, chars[i])
        end
        return table.concat(reversed)
    end
