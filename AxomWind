function Utilities.apply(instance, classString)
    local classes = {}
    for word in string.gmatch(classString, "%S+") do
        classes[word] = true
    end
    
    for class, _ in pairs(classes) do
        if class:match("^p%-") then
            local value = class:sub(3)
            if spacing[value] then
                instance.Padding = UDim.new(0, spacing[value])
            end
        elseif class:match("^px%-") then
            local value = class:sub(4)
            if spacing[value] then
                instance.PaddingLeft = UDim.new(0, spacing[value])
                instance.PaddingRight = UDim.new(0, spacing[value])
            end
        elseif class:match("^py%-") then
            local value = class:sub(4)
            if spacing[value] then
                instance.PaddingTop = UDim.new(0, spacing[value])
                instance.PaddingBottom = UDim.new(0, spacing[value])
            end
        elseif class:match("^pt%-") then
            local value = class:sub(4)
            if spacing[value] then
                instance.PaddingTop = UDim.new(0, spacing[value])
            end
        elseif class:match("^pr%-") then
            local value = class:sub(4)
            if spacing[value] then
                instance.PaddingRight = UDim.new(0, spacing[value])
            end
        elseif class:match("^pb%-") then
            local value = class:sub(4)
            if spacing[value] then
                instance.PaddingBottom = UDim.new(0, spacing[value])
            end
        elseif class:match("^pl%-") then
            local value = class:sub(4)
            if spacing[value] then
                instance.PaddingLeft = UDim.new(0, spacing[value])
            end
        elseif class:match("^m%-") then
            local value = class:sub(3)
            if spacing[value] then
                instance.Margin = UDim.new(0, spacing[value])
            end
        elseif class:match("^mx%-") then
            local value = class:sub(4)
            if spacing[value] then
                instance.MarginLeft = UDim.new(0, spacing[value])
                instance.MarginRight = UDim.new(0, spacing[value])
            end
        elseif class:match("^my%-") then
            local value = class:sub(4)
            if spacing[value] then
                instance.MarginTop = UDim.new(0, spacing[value])
                instance.MarginBottom = UDim.new(0, spacing[value])
            end
        elseif class:match("^mt%-") then
            local value = class:sub(4)
            if spacing[value] then
                instance.MarginTop = UDim.new(0, spacing[value])
            end
        elseif class:match("^mr%-") then
            local value = class:sub(4)
            if spacing[value] then
                instance.MarginRight = UDim.new(0, spacing[value])
            end
        elseif class:match("^mb%-") then
            local value = class:sub(4)
            if spacing[value] then
                instance.MarginBottom = UDim.new(0, spacing[value])
            end
        elseif class:match("^ml%-") then
            local value = class:sub(4)
            if spacing[value] then
                instance.MarginLeft = UDim.new(0, spacing[value])
            end
        elseif class:match("^w%-") then
            local value = class:sub(3)
            if value == "full" then
                instance.Size = UDim2.new(1, 0, instance.Size.Y.Scale, instance.Size.Y.Offset)
            elseif value == "screen" then
                instance.Size = UDim2.new(0, 0, instance.Size.Y.Scale, instance.Size.Y.Offset)
            elseif spacing[value] then
                instance.Size = UDim2.new(0, spacing[value], instance.Size.Y.Scale, instance.Size.Y.Offset)
            end
        elseif class:match("^h%-") then
            local value = class:sub(3)
            if value == "full" then
                instance.Size = UDim2.new(instance.Size.X.Scale, instance.Size.X.Offset, 1, 0)
            elseif value == "screen" then
                instance.Size = UDim2.new(instance.Size.X.Scale, instance.Size.X.Offset, 0, 0)
            elseif spacing[value] then
                instance.Size = UDim2.new(instance.Size.X.Scale, instance.Size.X.Offset, 0, spacing[value])
            end
        elseif class:match("^bg%-") then
            local colorPath = class:sub(4)
            local parts = {}
            for part in string.gmatch(colorPath, "[^%-]+") do
                table.insert(parts, part)
            end
            if #parts == 2 then
                local colorFamily = parts[1]
                local shade = tonumber(parts[2])
                if colors[colorFamily] and colors[colorFamily][shade] then
                    instance.BackgroundColor3 = colors[colorFamily][shade]
                end
            elseif colors[colorPath] then
                instance.BackgroundColor3 = colors[colorPath]
            end
        elseif class:match("^text%-") then
            local colorPath = class:sub(6)
            local parts = {}
            for part in string.gmatch(colorPath, "[^%-]+") do
                table.insert(parts, part)
            end
            if #parts == 2 then
                local colorFamily = parts[1]
                local shade = tonumber(parts[2])
                if colors[colorFamily] and colors[colorFamily][shade] then
                    instance.TextColor3 = colors[colorFamily][shade]
                end
            elseif colors[colorPath] then
                instance.TextColor3 = colors[colorPath]
            end
        elseif class:match("^text%-size%-") then
            local size = class:sub(11)
            if fontSize[size] then
                instance.TextSize = fontSize[size]
            end
        elseif class:match("^font%-") then
            local weight = class:sub(6)
            if fontWeight[weight] then
                instance.TextWeight = fontWeight[weight]
            end
        elseif class:match("^rounded%-") then
            local radius = class:sub(8)
            if radius == "full" then
                instance.BorderRadius = UDim.new(0, borderRadius.full)
            elseif borderRadius[radius] then
                instance.BorderRadius = UDim.new(0, borderRadius[radius])
            end
        elseif class:match("^shadow%-") then
            local shadowType = class:sub(7)
            if shadow[shadowType] then
                local s = shadow[shadowType]
                instance.ShadowColor = Color3.new(0, 0, 0)
                instance.ShadowSize = UDim.new(0, s[2] or 0)
                instance.ShadowPosition = Vector2.new(s[1] or 0, s[3] or 0)
            end
        elseif class == "flex" then
            instance.LayoutOrder = 1
        elseif class == "grid" then
            instance.LayoutOrder = 2
        elseif class == "hidden" then
            instance.Visible = false
        elseif class == "visible" then
            instance.Visible = true
        elseif class == "opacity-0" then
            instance.BackgroundTransparency = 1
            instance.TextTransparency = 1
        elseif class == "opacity-50" then
            instance.BackgroundTransparency = 0.5
            instance.TextTransparency = 0.5
        elseif class == "opacity-100" then
            instance.BackgroundTransparency = 0
            instance.TextTransparency = 0
        elseif class == "border" then
            instance.BorderSizePixel = 1
            instance.BorderColor3 = colors.gray[200]
        elseif class == "border-2" then
            instance.BorderSizePixel = 2
        elseif class == "border-4" then
            instance.BorderSizePixel = 4
        elseif class == "border-transparent" then
            instance.BorderColor3 = colors.transparent
        end
    end
end

function Utilities.style(instance, classString)
    Utilities.apply(instance, classString)
    return instance
end

return Utilities
