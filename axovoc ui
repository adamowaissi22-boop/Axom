				pickerFrame.Visible = not pickerFrame.Visible
			end)
			
			UserInputService.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					local pos = input.Position
					local colorAbsPos = color.AbsolutePosition
					local colorAbsSize = color.AbsoluteSize
					local pickerAbsPos = pickerFrame.AbsolutePosition
					local pickerAbsSize = pickerFrame.AbsoluteSize
					
					if not (pos.X >= colorAbsPos.X and pos.X <= colorAbsPos.X + colorAbsSize.X and pos.Y >= colorAbsPos.Y and pos.Y <= colorAbsPos.Y + colorAbsSize.Y) and
					   not (pos.X >= pickerAbsPos.X and pos.X <= pickerAbsPos.X + pickerAbsSize.X and pos.Y >= pickerAbsPos.Y and pos.Y <= pickerAbsPos.Y + pickerAbsSize.Y) then
						pickerFrame.Visible = false
					end
				end
			end)
			
			color.MouseEnter:Connect(function()
				Tween(color, {BackgroundColor3 = CurrentTheme.BackgroundHover}, 0.2)
			end)
			
			color.MouseLeave:Connect(function()
				Tween(color, {BackgroundColor3 = CurrentTheme.BackgroundTertiary}, 0.2)
			end)
			
			table.insert(tab.Elements, {
				UpdateTheme = function()
					color.BackgroundColor3 = CurrentTheme.BackgroundTertiary
					label.TextColor3 = CurrentTheme.TextPrimary
					pickerFrame.BackgroundColor3 = CurrentTheme.BackgroundSecondary
					if iconLabel then iconLabel.ImageColor3 = CurrentTheme.TextSecondary end
				end,
				Set = function(c)
					selectedColor = c
					colorDisplay.BackgroundColor3 = c
					hue, saturation, value = rgbToHsv(c)
					hueKnob.Position = UDim2.new(hue, -math.floor(2 * scale), 0.5, -math.floor(12 * scale))
					svKnob.Position = UDim2.new(saturation, -math.floor(6 * scale), 1 - value, -math.floor(6 * scale))
					svSquare.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)
					whiteOverlay.BackgroundTransparency = 1 - saturation
					blackOverlay.BackgroundTransparency = 1 - value
					callback(c)
				end,
				Get = function() return selectedColor end
			})
			
			return color
		end
		
		function tab:AddLabel(config)
			config = config or {}
			local labelText = config.Text or "Label"
			local size = config.Size or 14
			
			local labelFrame = Create("Frame", {
				Size = UDim2.new(1, 0, 0, math.floor((size + 16) * scale)),
				BackgroundTransparency = 1,
				Parent = tabContent
			})
			
			local label = Create("TextLabel", {
				Size = UDim2.new(1, -math.floor(32 * scale), 1, 0),
				Position = UDim2.new(0, math.floor(16 * scale), 0, 0),
				BackgroundTransparency = 1,
				Text = labelText,
				TextColor3 = CurrentTheme.TextSecondary,
				TextSize = GetFontSize(size),
				Font = Enum.Font.Gotham,
				TextXAlignment = Enum.TextXAlignment.Left,
				Parent = labelFrame
			})
			
			table.insert(tab.Elements, {
				UpdateTheme = function()
					label.TextColor3 = CurrentTheme.TextSecondary
				end,
				Set = function(text)
					label.Text = text
				end
			})
			
			return label
		end
		
		function tab:AddDivider(config)
			config = config or {}
			local text = config.Text
			
			local dividerFrame = Create("Frame", {
				Size = UDim2.new(1, 0, 0, text and math.floor(30 * scale) or math.floor(20 * scale)),
				BackgroundTransparency = 1,
				Parent = tabContent
			})
			
			local line = Create("Frame", {
				Size = UDim2.new(1, -math.floor(32 * scale), 0, math.floor(1 * scale)),
				Position = UDim2.new(0, math.floor(16 * scale), 0.5, 0),
				BackgroundColor3 = CurrentTheme.Border,
				BorderSizePixel = 0,
				Parent = dividerFrame
			})
			
			if text then
				local label = Create("TextLabel", {
					Size = UDim2.new(0, math.floor(100 * scale), 0, math.floor(20 * scale)),
					Position = UDim2.new(0.5, -math.floor(50 * scale), 0.5, -math.floor(10 * scale)),
					BackgroundColor3 = CurrentTheme.Background,
					BackgroundTransparency = 1,
					Text = text,
					TextColor3 = CurrentTheme.TextMuted,
					TextSize = GetFontSize(12),
					Font = Enum.Font.Gotham,
					Parent = dividerFrame
				})
				
				table.insert(tab.Elements, {
					UpdateTheme = function()
						line.BackgroundColor3 = CurrentTheme.Border
						label.TextColor3 = CurrentTheme.TextMuted
					end
				})
			else
				table.insert(tab.Elements, {
					UpdateTheme = function()
						line.BackgroundColor3 = CurrentTheme.Border
					end
				})
			end
			
			return dividerFrame
		end
		
		function tab:AddSection(config)
			config = config or {}
			local sectionText = config.Text or "Section"
			local default = config.Default ~= false
			
			local sectionFrame = Create("Frame", {
				Size = UDim2.new(1, 0, 0, math.floor(44 * scale)),
				BackgroundTransparency = 1,
				Parent = tabContent
			})
			
			local section = Create("TextButton", {
				Size = UDim2.new(1, 0, 1, 0),
				BackgroundColor3 = CurrentTheme.BackgroundTertiary,
				Text = "",
				AutoButtonColor = false,
				Parent = sectionFrame
			})
			Create("UICorner", {CornerRadius = UDim.new(0, math.floor(12 * scale)), Parent = section})
			Create("UIStroke", {
				Color = CurrentTheme.Border,
				Thickness = math.max(1, math.floor(1 * scale)),
				Transparency = 0.5,
				Parent = section
			})
			
			local arrow = Create("ImageLabel", {
				Size = UDim2.new(0, math.floor(16 * scale), 0, math.floor(16 * scale)),
				Position = UDim2.new(0, math.floor(16 * scale), 0.5, -math.floor(8 * scale)),
				BackgroundTransparency = 1,
				Image = "rbxassetid://3926305904",
				ImageRectOffset = default and Vector2.new(884, 324) or Vector2.new(804, 364),
				ImageRectSize = Vector2.new(36, 36),
				ImageColor3 = CurrentTheme.TextMuted,
				Parent = section
			})
			
			local label = Create("TextLabel", {
				Size = UDim2.new(1, -math.floor(92 * scale), 1, 0),
				Position = UDim2.new(0, math.floor(44 * scale), 0, 0),
				BackgroundTransparency = 1,
				Text = sectionText,
				TextColor3 = CurrentTheme.TextPrimary,
				TextSize = GetFontSize(15),
				Font = Enum.Font.GothamSemibold,
				TextXAlignment = Enum.TextXAlignment.Left,
				Parent = section
			})
			
			local expanded = default
			local content = Create("Frame", {
				Size = UDim2.new(1, 0, 0, 0),
				BackgroundTransparency = 1,
				ClipsDescendants = true,
				Visible = expanded,
				Parent = tabContent
			})
			
			local contentLayout = Create("UIListLayout", {
				Padding = UDim.new(0, math.floor((isMobile and 12 or 16) * scale)),
				SortOrder = Enum.SortOrder.LayoutOrder,
				Parent = content
			})
			
			local contentPadding = Create("UIPadding", {
				PaddingLeft = UDim.new(0, math.floor(16 * scale)),
				PaddingRight = UDim.new(0, math.floor(16 * scale)),
				PaddingTop = UDim.new(0, expanded and math.floor(16 * scale) or 0),
				PaddingBottom = UDim.new(0, expanded and math.floor(16 * scale) or 0),
				Parent = content
			})
			
			contentLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
				if expanded then
					content.Size = UDim2.new(1, 0, 0, contentLayout.AbsoluteContentSize.Y + math.floor(32 * scale))
					sectionFrame.Size = UDim2.new(1, 0, 0, math.floor(44 * scale))
				end
			end)
			
			function section:AddButton(c) return tab:AddButton(c, content) end
			function section:AddToggle(c) return tab:AddToggle(c, content) end
			function section:AddSlider(c) return tab:AddSlider(c, content) end
			function section:AddDropdown(c) return tab:AddDropdown(c, content) end
			function section:AddTextbox(c) return tab:AddTextbox(c, content) end
			function section:AddKeybind(c) return tab:AddKeybind(c, content) end
			function section:AddColorPicker(c) return tab:AddColorPicker(c, content) end
			function section:AddLabel(c) return tab:AddLabel(c, content) end
			function section:AddDivider(c) return tab:AddDivider(c, content) end
			
			section.MouseButton1Click:Connect(function()
				expanded = not expanded
				content.Visible = expanded
				arrow.ImageRectOffset = expanded and Vector2.new(884, 324) or Vector2.new(804, 364)
				contentPadding.PaddingTop = UDim.new(0, expanded and math.floor(16 * scale) or 0)
				contentPadding.PaddingBottom = UDim.new(0, expanded and math.floor(16 * scale) or 0)
				if expanded then
					content.Size = UDim2.new(1, 0, 0, contentLayout.AbsoluteContentSize.Y + math.floor(32 * scale))
					sectionFrame.Size = UDim2.new(1, 0, 0, math.floor(44 * scale))
				else
					content.Size = UDim2.new(1, 0, 0, 0)
				end
			end)
			
			section.MouseEnter:Connect(function()
				Tween(section, {BackgroundColor3 = CurrentTheme.BackgroundHover}, 0.2)
			end)
			
			section.MouseLeave:Connect(function()
				Tween(section, {BackgroundColor3 = CurrentTheme.BackgroundTertiary}, 0.2)
			end)
			
			table.insert(tab.Elements, {
				UpdateTheme = function()
					section.BackgroundColor3 = CurrentTheme.BackgroundTertiary
					label.TextColor3 = CurrentTheme.TextPrimary
					arrow.ImageColor3 = CurrentTheme.TextMuted
				end
			})
			
			return section
		end
		
		tabBtn.MouseButton1Click:Connect(function() tab:Select() end)
		
		if not isMobile then
			tabBtn.MouseEnter:Connect(function()
				if window.ActiveTab ~= tab then
					Tween(tabBtn, {BackgroundTransparency = 0.85}, 0.2)
				end
			end)
			tabBtn.MouseLeave:Connect(function()
				if window.ActiveTab ~= tab then
					Tween(tabBtn, {BackgroundTransparency = 1}, 0.2)
				end
			end)
		end
		
		table.insert(window.Tabs, tab)
		if #window.Tabs == 1 then
			tab:Select()
			if isMobile and mobileTabBar then
				mobileTabBar.Visible = true
			end
		end
		return tab
	end
	
	table.insert(ActiveWindows, window)
	return window
end

return Axovoc
