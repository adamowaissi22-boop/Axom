			function section:AddTextBox(textboxConfig)
				textboxConfig = textboxConfig or {}
				local boxText = textboxConfig.Text or "Input"
				local boxPlaceholder = textboxConfig.Placeholder or "Type here..."
				local boxDefault = textboxConfig.Default or ""
				local boxCallback = textboxConfig.Callback or function() end
				
				local frame = Create("Frame", {
					Size = UDim2.new(1, 0, 0, 76),
					BackgroundTransparency = 1,
					Parent = self.Container
				})
				
				local lbl = Create("TextLabel", {
					Size = UDim2.new(1, 0, 0, 20),
					BackgroundTransparency = 1,
					Text = boxText,
					TextColor3 = CurrentTheme.TextPrimary,
					TextSize = 14,
					Font = Enum.Font.Gotham,
					TextXAlignment = Enum.TextXAlignment.Left,
					Parent = frame
				})
				
				local box = Create("TextBox", {
					Size = UDim2.new(1, 0, 0, 44),
					Position = UDim2.new(0, 0, 0, 28),
					BackgroundColor3 = CurrentTheme.BackgroundTertiary,
					Text = boxDefault,
					PlaceholderText = boxPlaceholder,
					TextColor3 = CurrentTheme.TextPrimary,
					PlaceholderColor3 = CurrentTheme.TextMuted,
					TextSize = 14,
					Font = Enum.Font.Gotham,
					ClearTextOnFocus = false,
					Parent = frame
				})
				Create("UICorner", {CornerRadius = UDim.new(0, 10), Parent = box})
				
				local boxPadding = Create("UIPadding", {
					PaddingLeft = UDim.new(0, 16),
					PaddingRight = UDim.new(0, 16),
					Parent = box
				})
				
				box.FocusLost:Connect(function()
					boxCallback(box.Text)
				end)
				
				local element = {
					Instance = frame,
					Value = boxDefault,
					SetValue = function(self, text)
						box.Text = text
						self.Value = text
						boxCallback(text)
					end,
					ThemeElements = {
						{Instance = lbl, Property = "TextPrimary"},
						{Instance = box, Property = "BackgroundTertiary"}
					}
				}
				
				function element:UpdateTheme()
					lbl.TextColor3 = CurrentTheme.TextPrimary
					box.BackgroundColor3 = CurrentTheme.BackgroundTertiary
					box.TextColor3 = CurrentTheme.TextPrimary
					box.PlaceholderColor3 = CurrentTheme.TextMuted
				end
				
				table.insert(self.Elements, element)
				return element
			end
			
