					TextSize = 14,
					Font = Enum.Font.GothamBold,
					TextXAlignment = Enum.TextXAlignment.Right,
					Parent = topRow
				})
				
				local track = Create("Frame", {
					Size = UDim2.new(1, 0, 0, 6),
					Position = UDim2.new(0, 0, 0, 40),
					BackgroundColor3 = CurrentTheme.BackgroundTertiary,
					BorderSizePixel = 0,
					Parent = frame
				})
				Create("UICorner", {CornerRadius = UDim.new(1, 0), Parent = track})
				
				local fill = Create("Frame", {
					Size = UDim2.new((sliderDefault - sliderMin) / (sliderMax - sliderMin), 0, 1, 0),
					BackgroundColor3 = CurrentTheme.Accent,
					BorderSizePixel = 0,
					Parent = track
				})
				Create("UICorner", {CornerRadius = UDim.new(1, 0), Parent = fill})
				
				local knob = Create("Frame", {
					Size = UDim2.new(0, 18, 0, 18),
					Position = UDim2.new((sliderDefault - sliderMin) / (sliderMax - sliderMin), -9, 0.5, -9),
					BackgroundColor3 = Color3.fromRGB(255, 255, 255),
					Parent = track
				})
				Create("UICorner", {CornerRadius = UDim.new(1, 0), Parent = knob})
				CreateShadow(knob, 0.2, 2)
				
				local dragging = false
				local value = sliderDefault
				
				local function update(input)
					local pos = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
					value = math.floor(sliderMin + (pos * (sliderMax - sliderMin)))
					valLbl.Text = value .. sliderSuffix
					fill.Size = UDim2.new(pos, 0, 1, 0)
					knob.Position = UDim2.new(pos, -9, 0.5, -9)
					sliderCallback(value)
				end
				
				knob.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						dragging = true
					end
				end)
				track.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						update(input)
						dragging = true
					end
				end)
				UserInputService.InputChanged:Connect(function(input)
					if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
						update(input)
					end
				end)
				UserInputService.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						dragging = false
					end
				end)
				
				local element = {
					Instance = frame,
					Value = value,
					ThemeElements = {
						{Instance = lbl, Property = "TextPrimary"},
						{Instance = valLbl, Property = "Accent"},
						{Instance = track, Property = "BackgroundTertiary"},
						{Instance = fill, Property = "Accent"}
					}
				}
				
				function element:UpdateTheme()
					lbl.TextColor3 = CurrentTheme.TextPrimary
					valLbl.TextColor3 = CurrentTheme.Accent
					track.BackgroundColor3 = CurrentTheme.BackgroundTertiary
					fill.BackgroundColor3 = CurrentTheme.Accent
				end
				
				table.insert(self.Elements, element)
				return element
			end
			
