			minimizedBtn.Position = UDim2.new(0, math.clamp(mainFrame.AbsolutePosition.X, 20, Mouse.ViewSizeX - 180), 0, math.clamp(mainFrame.AbsolutePosition.Y, 20, Mouse.ViewSizeY - 60))
