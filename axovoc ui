local function Create(instanceType, properties)
	local instance = Instance.new(instanceType)
	for property, value in pairs(properties or {}) do
		instance[property] = value
	end
	return instance
end

local function Tween(instance, properties, duration, easingStyle, easingDirection)
	local tween = TweenService:Create(instance, TweenInfo.new(duration or 0.3, easingStyle or Enum.EasingStyle.Quart, easingDirection or Enum.EasingDirection.Out), properties)
	tween:Play()
	return tween
end

local function CreateShadow(parent, intensity, offset)
	local shadow = Create("ImageLabel", {
		Name = "Shadow",
		AnchorPoint = Vector2.new(0.5, 0.5),
		BackgroundTransparency = 1,
		Position = UDim2.new(0.5, 0, 0.5, offset or 4),
		Size = UDim2.new(1, 24, 1, 24),
		Image = "rbxassetid://6014261993",
		ImageColor3 = CurrentTheme.Shadow,
		ImageTransparency = (intensity or 0.5),
		ScaleType = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(49, 49, 450, 450),
		ZIndex = parent.ZIndex - 1,
		Parent = parent
	})
	return shadow
end

local function MakeDraggable(frame, handle)
	local dragging = false
	local dragInput, dragStart, startPos
	
	local function update(input)
		local delta = input.Position - dragStart
		local newX = startPos.X.Offset + delta.X
		local newY = startPos.Y.Offset + delta.Y
		frame.Position = UDim2.new(startPos.X.Scale, newX, startPos.Y.Scale, newY)
	end
	
	handle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = frame.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)
	
	handle.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)
	
	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			update(input)
		end
	end)
end

local function GetScreenSize()
	return workspace.CurrentCamera.ViewportSize
end

local function GetDeviceType()
	local screenSize = GetScreenSize()
	local width = screenSize.X
	
	if UserInputService.TouchEnabled and not UserInputService.MouseEnabled then
		if width < 600 then
			return "Phone"
		elseif width < 1024 then
			return "Tablet"
		else
			return "LargeTablet"
		end
	else
		if width < 1366 then
			return "SmallLaptop"
		elseif width < 1920 then
			return "Laptop"
		else
			return "Desktop"
		end
	end
end

local function GetResponsiveSize()
	local device = GetDeviceType()
	local screenSize = GetScreenSize()
	
	local sizes = {
		Phone = {Width = screenSize.X * 0.9, Height = screenSize.Y * 0.7},
		Tablet = {Width = 500, Height = 650},
		LargeTablet = {Width = 600, Height = 750},
		SmallLaptop = {Width = 700, Height = 500},
		Laptop = {Width = 800, Height = 550},
		Desktop = {Width = 900, Height = 600}
	}
	
	local config = sizes[device]
	
	config.Width = math.min(config.Width, screenSize.X - 40)
	config.Height = math.min(config.Height, screenSize.Y - 80)
	
	return config.Width, config.Height
end

local function GetScaleFactor()
	local screenSize = GetScreenSize()
	local baseWidth = 1920
	local scale = math.min(1.2, math.max(0.7, screenSize.X / baseWidth))
	return scale
end

local function GetFontSize(baseSize)
	local scale = GetScaleFactor()
	return math.floor(baseSize * scale)
end

local function GetCornerRadius(base)
	local scale = GetScaleFactor()
	return UDim.new(0, math.floor(base * scale))
end

function Axovoc:SetTheme(themeName)
	if Themes[themeName] then
		CurrentTheme = Themes[themeName]
		for _, window in pairs(ActiveWindows) do
			if window.UpdateTheme then
				window:UpdateTheme()
			end
		end
	end
end

function Axovoc:GetThemes()
	local list = {}
	for name, _ in pairs(Themes) do
		table.insert(list, name)
	end
	return list
end

