				local h, s, v = 0, 0, max
				local d = max - min
				if max ~= 0 then s = d / max end
				if max ~= min then
					if max == r then h = (g - b) / d + (g < b and 6 or 0)
					elseif max == g then h = (b - r) / d + 2
