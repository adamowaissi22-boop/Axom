	function window:UpdateTheme()
		for _, element in pairs(self.ThemeElements) do
			if element.Instance and element.Instance.Parent then
				local value = CurrentTheme[element.Property]
				if element.Instance:IsA("TextLabel") or element.Instance:IsA("TextButton") then
					if element.Property:find("Text") then
						element.Instance.TextColor3 = value
					else
						element.Instance.BackgroundColor3 = value
					end
				elseif element.Instance:IsA("ImageLabel") then
					element.Instance.ImageColor3 = value
				elseif element.Instance:IsA("UIStroke") then
					element.Instance.Color = value
				else
					element.Instance.BackgroundColor3 = value
				end
			end
		end
		for _, tab in pairs(self.Tabs) do
			if tab.UpdateTheme then tab:UpdateTheme() end
		end
	end
	
