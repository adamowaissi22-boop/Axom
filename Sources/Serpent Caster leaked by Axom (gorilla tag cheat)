        private void UpdateFog()
        {
            if (!enableFogFollow) return;
            fogUpdateTimer -= Time.deltaTime;
            if (fogUpdateTimer > 0) return;
            fogUpdateTimer = 0.1f;
        }

        private void TrackPlayerVelocities()
        {
            if (targetPlayer == null) return;
            velocity = (targetPlayer.transform.position - lastPlayerPos) / Time.deltaTime;
            lastPlayerPos = targetPlayer.transform.position;

            float spd = velocity.magnitude;
            if (spd > peakSpeed) peakSpeed = spd;
            bpiSmoothedSpeed = Mathf.Lerp(bpiSmoothedSpeed, spd, lerpValueBody);
        }

        private void RefreshVRRigs()
        {
            vrigRefreshTimer -= Time.deltaTime;
            if (vrigRefreshTimer > 0 && !rigsDirty) return;
            vrigRefreshTimer = 1f;
            rigsDirty = false;
            vrrigs.Clear();
            vrrigs.AddRange(FindObjectsByType<GTPlayer>(FindObjectsSortMode.None));
        }

