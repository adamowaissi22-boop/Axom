        private void RefreshFontList()
        {
            availableFonts.Clear();
            availableFontNames.Clear();
            if (!Directory.Exists(fontFolderPath)) return;
            string[] files = Directory.GetFiles(fontFolderPath, "*.ttf");
            foreach (string f in files)
            {
                availableFonts.Add(f);
                availableFontNames.Add(Path.GetFileNameWithoutExtension(f));
            }
        }

