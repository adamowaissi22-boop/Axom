        private IEnumerator ValidateKeyCoroutine()
        {
            string keyPath = Path.Combine(Paths.PluginPath, "SerpentCaster", "Key.txt");
            if (!File.Exists(keyPath))
            {
                Logger.LogError("âŒ Key.txt not found at: " + keyPath);
                yield break;
            }

            loadedKey = File.ReadAllText(keyPath).Trim();

            using UnityWebRequest request = UnityWebRequest.Post(serverUrl, new WWWForm());
            request.downloadHandler = new DownloadHandlerBuffer();
            yield return request.SendWebRequest();

            if (request.result != UnityWebRequest.Result.Success)
            {
                Logger.LogError("Coroutine validation error: " + request.error);
                yield break;
            }

            string response = request.downloadHandler.text;
            bool parsed;
            try
            {
                parsed = bool.Parse(response);
            }
            catch
            {
                Logger.LogError("Coroutine: Failed to parse validation response.");
                yield break;
            }

            if (parsed)
            {
                keyIsValid = true;
                Logger.LogWarning("âœ… Valid key detected. Enabling mod features.");
            }
            else
            {
                keyIsValid = false;
                Logger.LogWarning("âŒ Invalid or expired key. Mod features disabled.");
            }
        }

        private async Task<bool> ValidateKeyAsync(string key)
        {
            using UnityWebRequest request = UnityWebRequest.Post(serverUrl, new WWWForm());
            request.downloadHandler = new DownloadHandlerBuffer();
            var asyncOp = request.SendWebRequest();
            while (!asyncOp.isDone)
                await Task.Yield();

            if (request.result != UnityWebRequest.Result.Success)
                return false;

            return bool.TryParse(request.downloadHandler.text, out bool result) && result;
        }

