        private void HandleWASD()
        {
            if (!wasd) return;
            Vector3 move = Vector3.zero;
            if (Keyboard.current.wKey.isPressed) move += Camera.main.transform.forward;
            if (Keyboard.current.sKey.isPressed) move -= Camera.main.transform.forward;
            if (Keyboard.current.aKey.isPressed) move -= Camera.main.transform.right;
            if (Keyboard.current.dKey.isPressed) move += Camera.main.transform.right;
            GorillaTagger.Instance.GetComponent<Rigidbody>().linearVelocity += move * speed;
        }

