            PlayerPrefs.SetInt  (key + "_enableFogFollow", enableFogFollow ? 1 : 0);
            PlayerPrefs.SetFloat(key + "_fogDepthFade",  fogDepthFade);
            PlayerPrefs.SetFloat(key + "_fogHeightFade", fogHeightFade);
            PlayerPrefs.SetInt  (key + "_currentFontIdx",  currentFontIdx);
            PlayerPrefs.SetString(key + "_currentFontName", currentFontName ?? "");
            PlayerPrefs.Save();

            if (!presetNames.Contains(name)) presetNames.Add(name);
            SavePresetList();
        }

        private void LoadPreset(string name)
        {
            string key = PRESET_PREFIX + name;
            fov              = PlayerPrefs.GetFloat(key + "_fov", 90f);
            clipping         = PlayerPrefs.GetFloat(key + "_clipping", 0.05f);
            smoothing        = PlayerPrefs.GetFloat(key + "_smoothing", 0.1f);
            smoothingType    = PlayerPrefs.GetInt  (key + "_smoothingType", 0);
            offsetX          = PlayerPrefs.GetFloat(key + "_offsetX", 0f);
            offsetY          = PlayerPrefs.GetFloat(key + "_offsetY", 0f);
            offsetZ          = PlayerPrefs.GetFloat(key + "_offsetZ", 0f);
            specLookAt       = PlayerPrefs.GetInt  (key + "_specLookAt", 0) == 1;
            bodyLerping      = PlayerPrefs.GetInt  (key + "_bodyLerping", 0) == 1;
            codeJoin         = PlayerPrefs.GetString(key + "_codeJoin", "");
            micOn            = PlayerPrefs.GetInt  (key + "_micOn", 0) == 1;
            autoswitch       = PlayerPrefs.GetInt  (key + "_autoswitch", 0) == 1;
            nametags         = PlayerPrefs.GetInt  (key + "_nametags", 0) == 1;
            nametagHeight    = PlayerPrefs.GetFloat(key + "_nametagHeight", 0.3f);
            velocitycounter  = PlayerPrefs.GetInt  (key + "_velocitycounter", 0) == 1;
            wasd             = PlayerPrefs.GetInt  (key + "_wasd", 0) == 1;
            basicPlayerInfo  = PlayerPrefs.GetInt  (key + "_basicPlayerInfo", 0) == 1;
            basicPlayerInfoScale = PlayerPrefs.GetFloat(key + "_basicPlayerInfoScale", 1f);
            spheresEnabled   = PlayerPrefs.GetInt  (key + "_spheresEnabled", 0) == 1;
            sphereSize       = PlayerPrefs.GetFloat(key + "_sphereSize", 0.1f);
            sOffsetX         = PlayerPrefs.GetFloat(key + "_sOffsetX", 0f);
            sOffsetY         = PlayerPrefs.GetFloat(key + "_sOffsetY", 0f);
            sOffsetZ         = PlayerPrefs.GetFloat(key + "_sOffsetZ", 0f);
            sphereSmoothing  = PlayerPrefs.GetFloat(key + "_sphereSmoothing", 0.15f);
            enableFogFollow  = PlayerPrefs.GetInt  (key + "_enableFogFollow", 0) == 1;
            fogDepthFade     = PlayerPrefs.GetFloat(key + "_fogDepthFade", 5f);
            fogHeightFade    = PlayerPrefs.GetFloat(key + "_fogHeightFade", 3f);
            currentFontIdx   = PlayerPrefs.GetInt  (key + "_currentFontIdx", -1);
            currentFontName  = PlayerPrefs.GetString(key + "_currentFontName", "");
        }

        private void DeletePreset(string name)
        {
            string key = PRESET_PREFIX + name;
            PlayerPrefs.DeleteKey(key);
            presetNames.Remove(name);
            SavePresetList();
        }

        private void LoadPresetList()
        {
            string raw = PlayerPrefs.GetString(PRESET_LIST_KEY, "");
            if (!string.IsNullOrEmpty(raw))
                presetNames.AddRange(raw.Split(','));
        }

        private void SavePresetList()
        {
            PlayerPrefs.SetString(PRESET_LIST_KEY, string.Join(",", presetNames));
            PlayerPrefs.Save();
        }

        private void BuildStyles()
        {
            stylesCached = true;
        }

        void OnDestroy()  { }
        void OnDisable()  { }
        void OnEnable()   { }
    }

