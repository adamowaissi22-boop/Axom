local function getalllandmodels()
    local alllands = {}
    local map = workspace:WaitForChild("Map")
    
    local lands = map:FindFirstChild("Lands")
    local ownerlands = map:FindFirstChild("OwnerLands")
    
    if lands then
        local sizes = { "XL", "Large", "Medium", "Small" }
        for _, size in ipairs(sizes) do
            local sizefolder = lands:FindFirstChild(size)
            if sizefolder then
                for _, land in ipairs(sizefolder:GetChildren()) do
                    table.insert(alllands, land)
                end
            end
        end
    end
    
    if ownerlands then
        local sizes = { "XL", "Large", "Medium", "Small" }
        for _, size in ipairs(sizes) do
            local sizefolder = ownerlands:FindFirstChild(size)
            if sizefolder then
                for _, land in ipairs(sizefolder:GetChildren()) do
                    table.insert(alllands, land)
                end
            end
        end
    end
    
    return alllands
end

local smallesprunning = false
local smallespconnection = nil
local smallesphighlights = {}

local function updatesmallesp()
    local alllands = getalllandmodels()
    for _, land in ipairs(alllands) do
        if land.Name:find("Small") or (land.Parent and land.Parent.Name == "Small") then
            if not smallesphighlights[land] then
                local highlight = Instance.new("Highlight")
                highlight.FillColor = Color3.fromRGB(255, 0, 0)
                highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                highlight.FillTransparency = 0.5
                highlight.Adornee = land
                highlight.Parent = land
                smallesphighlights[land] = highlight
            end
        end
    end
end

local function clearsmallesp()
    for land, highlight in pairs(smallesphighlights) do
        highlight:Destroy()
    end
    smallesphighlights = {}
end

