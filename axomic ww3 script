local autoupgrading = false
local autoupgradeconnection = nil

local function upgradealllands()
    local upgraderemote = game:GetService('ReplicatedStorage'):WaitForChild('src'):WaitForChild('Packages'):WaitForChild('Knit'):WaitForChild('Services'):WaitForChild('UpgradeService'):WaitForChild('RE'):WaitForChild('Upgrade')
    local ownerlands = workspace:WaitForChild('Map'):WaitForChild('OwnerLands')
    
    local ownersizes = { 'Small', 'Medium', 'Large', 'XL' }
    
    for _, size in ipairs(ownersizes) do
        local sizefolder = ownerlands:FindFirstChild(size)
        if sizefolder then
            for _, ownerland in ipairs(sizefolder:GetChildren()) do
                local ownername = ownerland.Name
                upgraderemote:FireServer(ownername)
                task.wait(0.05)
            end
        end
    end
end

