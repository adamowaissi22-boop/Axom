                    end
                    wait(1)
                end
            end)
        else
            punishPlayers[targetName] = false
        end
    end
})

CommandsTab:CreateToggle({
    Text = "Freeze",
    Default = false,
    Callback = function(enabled)
        freezeEnabled = enabled
        local targetName = targetTextBox:Get()
        local targetPlayer = targetName and Players:FindFirstChild(targetName)
        
        if not targetPlayer or not targetPlayer.Character then
            window:CreateNotification({
                Title = "Error",
                Description = "Select a target player first",
                Duration = 3
            })
            return
        end
        
        local btools = getBtoolsAPI()
        if not btools then return end
        
        if enabled then
            local partsList = {}
            for _, part in pairs(targetPlayer.Character:GetChildren()) do
                if part:IsA("BasePart") then
                    table.insert(partsList, {
                        Part = part,
                        Anchored = true
                    })
                end
            end
            
            if #partsList > 0 then
                local args = {
                    "SyncAnchor",
                    partsList
                }
                btools:InvokeServer(unpack(args))
            end
        else
            local partsList = {}
            for _, part in pairs(targetPlayer.Character:GetChildren()) do
                if part:IsA("BasePart") then
                    table.insert(partsList, {
                        Part = part,
                        Anchored = false
                    })
                end
            end
            
            if #partsList > 0 then
                local args = {
                    "SyncAnchor",
                    partsList
                }
                btools:InvokeServer(unpack(args))
            end
        end
    end
})

CommandsTab:CreateToggle({
    Text = "Invisible",
    Default = false,
    Callback = function(enabled)
        local btools = getBtoolsAPI()
        if not btools then return end
        
        invisibleEnabled = enabled
        
        if LocalPlayer.Character then
            if enabled then
                local partsList = {}
                for _, part in pairs(LocalPlayer.Character:GetChildren()) do
                    if part:IsA("BasePart") then
                        table.insert(partsList, {
                            Part = part,
                            Transparency = 1
                        })
                        visibleParts[part] = part.Transparency
                    end
                end
                
                local args = {
                    "SyncMaterial",
                    partsList
                }
                btools:InvokeServer(unpack(args))
            else
                for part, transparency in pairs(visibleParts) do
                    if part and part.Parent then
                        local args = {
                            "SyncMaterial",
                            {
                                {
                                    Part = part,
                                    Transparency = transparency
                                }
                            }
                        }
                        btools:InvokeServer(unpack(args))
                    end
                end
                visibleParts = {}
            end
        end
    end
})

