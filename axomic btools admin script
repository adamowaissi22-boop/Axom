MainTab:CreateButton({
    Text = "R63",
    Callback = function()
        local function getToolEndpoint()
            local tool = LocalPlayer.Backpack:FindFirstChild("Building Tools") or LocalPlayer.Character:FindFirstChild("Building Tools")
            return tool and tool:WaitForChild("SyncAPI"):WaitForChild("ServerEndpoint")
        end
        
        local partsList = {}
        local whiteColor = Color3.fromRGB(255, 255, 255)
        local pinkColor = Color3.fromRGB(255, 50, 120)
        
        local layout = {
            {name = "Chest_R", pos = Vector3.new(0.75, 0.25, -1.0), size = {2.1, 2.1, 2.1}, color = whiteColor, shape = "Ball", weight = 1},
            {name = "Chest_L", pos = Vector3.new(-0.75, 0.25, -1.0), size = {2.1, 2.1, 2.1}, color = whiteColor, shape = "Ball", weight = 1},
            {name = "Nip_R", pos = Vector3.new(0.75, 0.25, -2.0), size = {0.5, 0.5, 0.5}, color = whiteColor, shape = "Ball", weight = 1.2},
            {name = "Nip_L", pos = Vector3.new(-0.75, 0.25, -2.0), size = {0.5, 0.5, 0.5}, color = whiteColor, shape = "Ball", weight = 1.2},
            {name = "Back_R", pos = Vector3.new(0.9, -1.3, 0.8), size = {2.9, 2.9, 2.9}, color = whiteColor, shape = "Ball", weight = 0.5},
            {name = "Back_L", pos = Vector3.new(-0.9, -1.3, 0.8), size = {2.9, 2.9, 2.9}, color = whiteColor, shape = "Ball", weight = 0.5},
            {name = "Hose", pos = Vector3.new(0, -1.1, -1.5), size = {0.6, 0.6, 5.2}, color = whiteColor, shape = "Normal", weight = 2},
            {name = "Tip", pos = Vector3.new(0, -1.1, -4.4), size = {0.85, 0.85, 0.85}, color = pinkColor, shape = "Ball", weight = 2.5}
        }
        
        local function serverDelete()
            local endpoint = getToolEndpoint()
            if not endpoint or #partsList == 0 then return end
            local parts = {}
            for _, v in ipairs(partsList) do if v.part then table.insert(parts, v.part) end end
            pcall(function() endpoint:InvokeServer("Remove", parts) end)
            partsList = {}
        end
        
        local function spawnBody()
            local endpoint = getToolEndpoint()
            if not endpoint then return end
            local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            serverDelete()
            for _, data in ipairs(layout) do
                local targetCF = root.CFrame * CFrame.new(data.pos)
                local newPart = endpoint:InvokeServer("CreatePart", data.shape, targetCF, workspace)
                if newPart then
                    table.insert(partsList, {part = newPart, offset = data.pos, weight = data.weight})
                    task.spawn(function()
                        endpoint:InvokeServer("SyncColor", {{Part = newPart, Color = data.color}})
                        endpoint:InvokeServer("SyncResize", {{Part = newPart, CFrame = targetCF, Size = Vector3.new(data.size[1], data.size[2], data.size[3])}})
                        endpoint:InvokeServer("SyncCollision", {{Part = newPart, CanCollide = false}})
                        endpoint:InvokeServer("SyncAnchor", {{Part = newPart, Anchored = true}})
                    end)
                end
            end
        end
        
        local tool = Instance.new("Tool", LocalPlayer.Backpack)
        tool.Name = "R63 - Axom"
        tool.RequiresHandle = false
        tool.Equipped:Connect(spawnBody)
        tool.Unequipped:Connect(serverDelete)
        
        RunService.Heartbeat:Connect(function()
            local endpoint = getToolEndpoint()
            local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            
            if endpoint and root and hum and #partsList > 0 then
                local syncData = {}
                local t = tick()
                local isMoving = hum.MoveDirection.Magnitude > 0.1
                
                for _, item in ipairs(partsList) do
                    if item.part and item.part.Parent then
                        local multiplier = item.weight or 1
                        local xOffset, yOffset, zOffset = 0, 0, 0
                        
                        if isMoving then
                            yOffset = math.sin(t * 14) * (0.15 * multiplier)
                            xOffset = math.cos(t * 7) * (0.08 * multiplier)
                            zOffset = math.sin(t * 10) * (0.05 * multiplier)
                        else
                            yOffset = math.sin(t * 3) * (0.05 * multiplier)
                        end
                        
                        local finalPos = item.offset + Vector3.new(xOffset, yOffset, zOffset)
                        table.insert(syncData, {Part = item.part, CFrame = root.CFrame * CFrame.new(finalPos)})
                    end
                end
                endpoint:InvokeServer("SyncMove", syncData)
            end
        end)
        
        window:CreateNotification({
            Title = "R63 Activated",
            Description = "Tool added to backpack",
            Duration = 5
        })
    end
})

