local function ApplyTabState()
    local tabs = {
        ["Deobf"]    = {TabDeobf, PanelDeobf},
        ["EnvLog"]   = {TabEnvLog, PanelEnvLog},
        ["Funcs"]    = {TabFuncs, PanelFuncs},
        ["Settings"] = {TabSettings, PanelSettings},
    }
    for name, pair in pairs(tabs) do
        local btn, panel = pair[1], pair[2]
        if name == STATE.ActiveTab then
            btn.TextColor3 = COLORS.ACCENT
            btn.BackgroundColor3 = COLORS.PANEL2
            panel.Visible = true
        else
            btn.TextColor3 = COLORS.TABINACTIVE
            btn.BackgroundColor3 = COLORS.PANEL
            panel.Visible = false
        end
    end
    local offsets = {Deobf = 0, EnvLog = 1, Funcs = 2, Settings = 3}
    local idx = offsets[STATE.ActiveTab] or 0
    local tabW = (TabBar.AbsoluteSize.X > 0 and TabBar.AbsoluteSize.X or BASE_W) / 4
    TabIndicator.Position = UDim2.new(0, idx * tabW, 1, -2)
    TabIndicator.Size = UDim2.new(0, tabW, 0, 2)
end
local function ToggleSetting(key, btn)
    SETTINGS[key] = not SETTINGS[key]
    if SETTINGS[key] then
        btn.BackgroundColor3 = Color3.fromRGB(0, 60, 40)
        btn.TextColor3 = COLORS.ACCENT2
        local label = btn.Text:gsub("^%[.-%] ", "")
        btn.Text = "[ON]  " .. label
    else
        btn.BackgroundColor3 = Color3.fromRGB(50, 15, 20)
        btn.TextColor3 = COLORS.RED
        local label = btn.Text:gsub("^%[.-%]  ", "")
        btn.Text = "[OFF] " .. label
    end
end
local function MakeSettingBtn(parent, yPos, key, labelText)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -16, 0, 34)
    btn.Position = UDim2.new(0, 8, 0, yPos)
    btn.Font = Enum.Font.Code
    btn.TextSize = 13
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.AutoButtonColor = false
    MakeCorner(btn, 4)
    MakePadding(btn, 0, 0, 0, 10)
    MakeStroke(btn, COLORS.BORDER, 1)
    btn.Parent = parent
    if SETTINGS[key] then
        btn.BackgroundColor3 = Color3.fromRGB(0, 60, 40)
        btn.TextColor3 = COLORS.ACCENT2
        btn.Text = "[ON]  " .. labelText
    else
        btn.BackgroundColor3 = Color3.fromRGB(50, 15, 20)
        btn.TextColor3 = COLORS.RED
        btn.Text = "[OFF] " .. labelText
    end
    btn.MouseButton1Click:Connect(function()
        ToggleSetting(key, btn)
    end)
    btn.MouseEnter:Connect(function() btn.BackgroundTransparency = 0.2 end)
    btn.MouseLeave:Connect(function() btn.BackgroundTransparency = 0 end)
    return btn
end
local function MakeActionBtn(parent, text, xPos, yPos, w, h, accent)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, w, 0, h)
    btn.Position = UDim2.new(0, xPos, 0, yPos)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 12
    btn.Text = text
    btn.TextColor3 = accent or COLORS.ACCENT
    btn.BackgroundColor3 = COLORS.PANEL2
    btn.AutoButtonColor = false
    MakeCorner(btn, 4)
    MakeStroke(btn, accent or COLORS.ACCENT, 1)
    btn.Parent = parent
    btn.MouseEnter:Connect(function()
        btn.BackgroundColor3 = accent or COLORS.ACCENT
        btn.TextColor3 = COLORS.BLACK
    end)
    btn.MouseLeave:Connect(function()
        btn.BackgroundColor3 = COLORS.PANEL2
        btn.TextColor3 = accent or COLORS.ACCENT
    end)
    return btn
end
