local function ScanFunctions(code)
    local lines = {}
    local function add(s) table.insert(lines, s) end
    add("=== FUNCTION SCAN RESULTS ===")
    add("")
    add("--- [FUNCTION DEFINITIONS] ---")
    local defPatterns = {
        {"Named global",    "function%s+(%w[%w%.%:]*) *%(([^)]*)%)"},
        {"Named local",     "local%s+function%s+(%w+) *%(([^)]*)%)"},
        {"Anonymous assign","(%w+)%s*=%s*function *%(([^)]*)%)"},
        {"Local anon",      "local%s+(%w+)%s*=%s*function *%(([^)]*)%)"},
        {"Method",          "function%s+(%w+%:[%w%.%:]+) *%(([^)]*)%)"},
    }
    local totalDefs = 0
    for _, pat in ipairs(defPatterns) do
        local found = {}
        for name, params in code:gmatch(pat[2]) do
            table.insert(found, {name=name, params=params})
            totalDefs = totalDefs + 1
        end
        if #found > 0 then
            add("  ["..pat[1].."] ("..#found.."):")
            for _, f in ipairs(found) do
                local pclean = f.params:gsub("%s+", " "):match("^%s*(.-)%s*$")
                add("    "..f.name.."("..pclean..")")
            end
        end
    end
    add("  Total definitions: "..totalDefs)
    add("")
    add("--- [FUNCTION CALLS] ---")
    local calls = {}
    local callCounts = {}
    for fullcall in code:gmatch("([%w%.%:%[%]]+)%s*%(") do
        if fullcall ~= "function" and fullcall ~= "if" and fullcall ~= "while" and fullcall ~= "for" then
            callCounts[fullcall] = (callCounts[fullcall] or 0) + 1
            if not calls[fullcall] then calls[fullcall] = true; table.insert(calls, fullcall) end
        end
    end
    table.sort(calls, function(a, b)
        return (callCounts[a] or 0) > (callCounts[b] or 0)
    end)
    local shown = 0
    for _, call in ipairs(calls) do
        if shown >= 80 then add("  ... (80 limit)"); break end
        add("  "..call.." (called "..callCounts[call].."x)")
        shown = shown + 1
    end
    add("")
    add("--- [OBFUSCATED FUNCTION PATTERNS] ---")
    local obfPatterns = {
        {"getfenv access",     'getfenv%b()%[.-%]'},
        {"pcall wrapper",      'pcall%(function'},
        {"string.char decode", 'string%.char%('},
        {"loadstring exec",    'loadstring%('},
        {"table concat build", 'table%.concat%('},
        {"xor decode",         'string%.byte.*%^'},
        {"env getfenv",        'getfenv%(0%)'},
        {"rawget bypass",      'rawget%('},
        {"setfenv inject",     'setfenv%('},
        {"debug hook",         'debug%.sethook%('},
        {"base64 pattern",     '[A-Za-z0-9+/][A-Za-z0-9+/][A-Za-z0-9+/][A-Za-z0-9+/]=?=?'},
        {"number table",       '{%s*%d+%s*,%s*%d+'},
        {"hex string",         '0x%x%x%x%x'},
    }
    for _, p in ipairs(obfPatterns) do
        local count = 0
        for _ in code:gmatch(p[2]) do count = count + 1 end
        if count > 0 then
            add("  [!] "..p[1]..": "..count.." occurrence(s)")
        end
    end
    add("")
    add("--- [UPVALUE REFERENCES] ---")
    for upv in code:gmatch("upvalue_(%w+)") do
        add("  upvalue_"..upv)
    end
    add("")
    add("=== END FUNCTION SCAN ===")
    return table.concat(lines, "\n")
end
local function DetectObfType(code)
    if code:match("^\27Lua") then
        return "MoonSec V3 (Lua 5.1 Bytecode)"
    end
    if code:match("local%s+%w+%s*=%s*{%s*%d+%s*,%s*%d+%s*,") and
       code:match("string%.char") then
        return "WeAreDevs / Generic number-table obfuscation"
    end
    if code:match("loadstring") and code:match("string%.char") then
        return "Loadstring + string.char chain"
    end
    if code:match("[A-Za-z0-9+/]+=*") and #code:match("[A-Za-z0-9+/]+=*") > 100 then
        return "Base64 encoded payload"
    end
    if code:match("getfenv%(0%)") and code:match("string%.byte") then
        return "getfenv XOR / byte obfuscation"
    end
    if code:match("local%s+%w+%s*=%s*{") and code:match("%w+%[%d+%]") then
        return "String table / index obfuscation"
    end
    if code:match("0x%x%x%x%x") then
        return "Hex literal obfuscation"
    end
    if code:match("%(function%(%)(.-)end%)%(%)") then
        return "IIFE wrapper obfuscation"
    end
    return "Unknown / unrecognized pattern"
end
local function DoDeobfuscate()
    local code = InputBox.Text
    if not code or code:strip and code:strip() == "" or code == "" then
        SetStatus("Error: No input code provided", COLORS.RED)
        return
    end
    SetStatus("Processing...", COLORS.YELLOW)
    local result = ""
    local isMoonSec = code:match("^\27Lua") and SETTINGS.MoonSecMode
    local ok, err
    if isMoonSec then
        ok, err = pcall(function()
            result = MoonSec_Decompile(code)
        end)
        if not ok then
            result = "-- [MoonSec V3 Decompile Error]\n-- "..tostring(err)
        end
    else
        ok, err = pcall(function()
            result = WAD_Deobfuscate(code)
        end)
        if not ok then
            result = "-- [Deobfuscation Error]\n-- "..tostring(err)
        end
    end
    if result == "" then result = "-- No deobfuscatable content found." end
    OutputBox.Text = result
    local linesOut = 0
    for _ in result:gmatch("\n") do linesOut = linesOut + 1 end
    SetStatus("Done — "..linesOut.." lines output | "..(isMoonSec and "MoonSec V3 mode" or "WAD improved mode"), COLORS.ACCENT2)
end
