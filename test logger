local function WAD_DecodeEscapes(s)
    s = s:gsub("\\(%d%d?%d?)", function(n)
        return string.char(tonumber(n))
    end)
    s = s:gsub("\\x(%x%x)", function(h)
        return string.char(tonumber(h, 16))
    end)
    s = s:gsub("\\n", "\n")
    s = s:gsub("\\r", "\r")
    s = s:gsub("\\t", "\t")
    s = s:gsub('\\"', '"')
    s = s:gsub("\\'", "'")
    s = s:gsub("\\\\", "\\")
    return s
end
local function WAD_DecodeBase64(data)
