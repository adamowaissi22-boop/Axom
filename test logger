                local v = tonumber(n:match("%d+"))
                if v then table.insert(nums, v) end
            end
            if #nums > 0 then
                local result = ""
                for _, v in ipairs(nums) do result = result .. string.char(v) end
                return string.format("%q", result)
            end
            return "string.char(" .. args .. ")"
