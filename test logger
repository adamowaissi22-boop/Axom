local function MakeCodePanel(parent, labelText, xPos, yPos, w, h, editable)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0, w, 0, 18)
    lbl.Position = UDim2.new(0, xPos, 0, yPos)
    lbl.BackgroundTransparency = 1
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 10
    lbl.Text = labelText
    lbl.TextColor3 = COLORS.TEXT3
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 4
    lbl.Parent = parent
    local scroll = Instance.new("ScrollingFrame")
    scroll.Size = UDim2.new(0, w, 0, h)
    scroll.Position = UDim2.new(0, xPos, 0, yPos + 20)
    scroll.BackgroundColor3 = COLORS.CODEBG
    scroll.BorderSizePixel = 0
    scroll.ScrollBarThickness = 5
    scroll.ScrollBarImageColor3 = COLORS.BORDER2
    scroll.ZIndex = 4
    scroll.Parent = parent
    MakeCorner(scroll, 4)
    MakeStroke(scroll, COLORS.BORDER, 1)
    local box = Instance.new("TextBox")
    box.Size = UDim2.new(1, -10, 1, -10)
    box.Position = UDim2.new(0, 5, 0, 5)
    box.BackgroundTransparency = 1
    box.Font = Enum.Font.Code
    box.TextSize = 12
    box.Text = ""
    box.PlaceholderText = editable and "-- Paste obfuscated Luau/Lua code here..." or "-- Deobfuscated output will appear here..."
    box.PlaceholderColor3 = COLORS.TEXT3
    box.TextColor3 = COLORS.TEXT
    box.ClearTextOnFocus = false
    box.MultiLine = true
    box.TextWrapped = false
    box.TextXAlignment = Enum.TextXAlignment.Left
    box.TextYAlignment = Enum.TextYAlignment.Top
    box.Editable = editable
    box.ZIndex = 5
    box.Parent = scroll
    return lbl, scroll, box
end
