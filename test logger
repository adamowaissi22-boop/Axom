            end
        end
        return string.format("%q", table.concat(chars))
    end)
end
local function WAD_DecodeCharTable(code)
    return code:gsub("{([%s%d,]+)}", function(body)
        local nums = {}
        for n in body:gmatch("%d+") do
            table.insert(nums, tonumber(n))
        end
        if #nums > 3 then
            local valid = true
            for _, v in ipairs(nums) do
                if v > 255 then valid = false break end
            end
            if valid then
                local str = ""
                for _, v in ipairs(nums) do str = str .. string.char(v) end
                if str:match("^[%g%s]+$") then
                    return string.format("%q", str)
                end
            end
        end
        return "{" .. body .. "}"
    end)
end
local function WAD_ResolveGetfenvCalls(code)
