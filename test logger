            local i = tonumber(idx)
            if entries[i] then
                return string.format("%q", entries[i])
            end
            return varname .. "[" .. idx .. "]"
        end)
        result = result:gsub(varname .. "%[(%d+)%s*%-%s*(%d+)%]", function(a, b)
            local i = tonumber(a) - tonumber(b)
            if entries[i] then
                return string.format("%q", entries[i])
            end
            return varname .. "[" .. a .. "-" .. b .. "]"
        end)
        result = result:gsub(varname .. "%[(%d+)%s*%+%s*(%d+)%]", function(a, b)
            local i = tonumber(a) + tonumber(b)
            if entries[i] then
