    if t == "string" then
        if #v > 80 then return '"'..v:sub(1,80)..'..." ('..#v..' chars)' end
        return '"'..v:gsub("\n","\\n"):gsub("\t","\\t")..'"'
    elseif t == "number" then return tostring(v)
    elseif t == "boolean" then return tostring(v)
    elseif t == "nil" then return "nil"
    elseif t == "function" then
        local info = (debug and debug.getinfo) and pcall(function() return debug.getinfo(v) end) or nil
        return "<function>"
    elseif t == "table" then
        if depth >= 2 then return "<table depth limit>" end
        local parts, count = {}, 0
        local ok2 = pcall(function()
            for k, val in pairs(v) do
                if count >= 12 then table.insert(parts, "... (truncated)"); break end
                local ks = SafeToString(k)
                table.insert(parts, ks.."="..FormatValue(val, depth+1))
                count = count + 1
            end
        end)
        if not ok2 then return "<table:protected>" end
        return "{"..table.concat(parts, ", ").."}"
    elseif t == "userdata" or t == "Instance" then
        local ok3, name = pcall(function() return v.Name end)
        local ok4, cls  = pcall(function() return v.ClassName end)
        if ok3 and ok4 then return "<"..cls..':'..name..">"
        elseif ok3 then return "<userdata:"..name..">"
        else return "<"..t..">" end
    else return "<"..t..">" end
end
