local function getPlayers(input)
    local playersList = {}
    local lowerInput = input:lower()
    if lowerInput == "me" then
        table.insert(playersList, player)
    elseif lowerInput == "random" or lowerInput == "others" then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= player then
                table.insert(playersList, p)
            end
        end
        if #playersList > 0 and lowerInput == "random" then
            return {playersList[math.random(1, #playersList)]}
        end
    elseif lowerInput == "all" then
        for _, p in pairs(Players:GetPlayers()) do
            table.insert(playersList, p)
        end
    else
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower() == lowerInput or p.DisplayName:lower() == lowerInput then
                table.insert(playersList, p)
            end
        end
        if #playersList == 0 then
            for _, p in pairs(Players:GetPlayers()) do
                if p.Name:lower():sub(1, #lowerInput) == lowerInput or p.DisplayName:lower():sub(1, #lowerInput) == lowerInput then
                    table.insert(playersList, p)
                end
            end
        end
    end
    return playersList
end

local function getSinglePlayer(input)
    local players = getPlayers(input)
    if #players > 0 then
        return players[1]
    end
    return nil
end

