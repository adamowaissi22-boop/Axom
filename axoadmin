local function updateCommandDisplay(filter)
    for _, child in pairs(CommandDisplay:GetChildren()) do
        if child:IsA("TextLabel") then
            child:Destroy()
        end
    end
    
    local lowerFilter = filter:lower()
    for _, cmd in pairs(commandsTable) do
        local show = false
        if lowerFilter == "" then
            show = true
        elseif cmd.name:lower():sub(1, #lowerFilter) == lowerFilter then
            show = true
        else
            for _, alias in pairs(cmd.aliases) do
                if alias:lower():sub(1, #lowerFilter) == lowerFilter then
                    show = true
                    break
                end
            end
        end
        if show then
            local cmdLabel = Instance.new("TextLabel")
            cmdLabel.Size = UDim2.new(1, -10, 0, 28)
            cmdLabel.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
            cmdLabel.BackgroundTransparency = 0.6
            cmdLabel.Text = "  " .. cmd.name .. " - " .. cmd.description
            cmdLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
            cmdLabel.TextXAlignment = Enum.TextXAlignment.Left
            cmdLabel.Font = Enum.Font.Code
            cmdLabel.TextSize = 13
            cmdLabel.Parent = CommandDisplay
        end
    end
    DisplayLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        CommandDisplay.CanvasSize = UDim2.new(0, 0, 0, DisplayLayout.AbsoluteContentSize.Y + 10)
    end)
end

local function updateSuggestions(text)
    for _, child in pairs(SuggestionList:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    if text == "" then
        SuggestionFrame.Visible = false
        return
    end
    
    local matches = {}
    local lowerText = text:lower()
    for _, cmd in pairs(commandsTable) do
        if cmd.name:lower():sub(1, #lowerText) == lowerText then
            table.insert(matches, cmd.name)
        else
            for _, alias in pairs(cmd.aliases) do
                if alias:lower():sub(1, #lowerText) == lowerText then
                    table.insert(matches, cmd.name)
                    break
                end
            end
        end
    end
    
    if #matches > 0 then
        SuggestionFrame.Visible = true
        SuggestionFrame.Size = UDim2.new(1, -20, 0, math.min(#matches * 32 + 10, 150))
        for _, cmdName in ipairs(matches) do
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, -10, 0, 28)
            btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
            btn.BackgroundTransparency = 0.6
            btn.BorderSizePixel = 0
            btn.Text = cmdName
            btn.TextColor3 = Color3.fromRGB(0, 170, 255)
            btn.TextSize = 14
            btn.Font = Enum.Font.Code
            btn.Parent = SuggestionList
            btn.MouseButton1Click:Connect(function()
                CommandBox.Text = cmdName
                SuggestionFrame.Visible = false
                CommandBox:CaptureFocus()
            end)
        end
        SuggestionList.CanvasSize = UDim2.new(0, 0, 0, #matches * 30 + 10)
    else
        SuggestionFrame.Visible = false
    end
end

local function executeCommand(cmd)
    local args = {}
    for word in cmd:gmatch("%S+") do
        table.insert(args, word)
    end
    local command = args[1]:lower()
    local arg1 = args[2]
    local arg2 = args[3]
    local arg3 = args[4]
    
    if command == "fly" then
        if not flyActive then
            flyActive = true
            local char = player.Character
            if char then
                local humanoid = char:FindFirstChild("Humanoid")
                local root = getRoot(char)
                if humanoid and root then
                    humanoid.PlatformStand = true
                    local bg = Instance.new("BodyGyro")
                    local bv = Instance.new("BodyVelocity")
                    bg.Parent = root
                    bv.Parent = root
                    bg.MaxTorque = Vector3.new(0, 4000, 0)
                    bg.P = 1000
                    bg.D = 50
                    bv.MaxForce = Vector3.new(4000, 4000, 4000)
                    bv.Velocity = Vector3.new(0, 0, 0)
                    flyConnection = RunService.Heartbeat:Connect(function()
                        if not flyActive or not char or not root then return end
                        local move = Vector3.new(0, 0, 0)
                        if UserInputService:IsKeyDown(Enum.KeyCode.W) then move = move + camera.CFrame.LookVector end
                        if UserInputService:IsKeyDown(Enum.KeyCode.S) then move = move - camera.CFrame.LookVector end
                        if UserInputService:IsKeyDown(Enum.KeyCode.A) then move = move - camera.CFrame.RightVector end
                        if UserInputService:IsKeyDown(Enum.KeyCode.D) then move = move + camera.CFrame.RightVector end
                        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then move = move + Vector3.new(0, 1, 0) end
                        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then move = move - Vector3.new(0, 1, 0) end
                        if move.Magnitude > 0 then move = move.Unit * 50 end
                        bv.Velocity = move
                        bg.CFrame = camera.CFrame
                    end)
                end
            end
            notify("AxoAdmin", "Fly enabled")
        end
    elseif command == "unfly" then
        if flyActive then
            flyActive = false
            if flyConnection then flyConnection:Disconnect() flyConnection = nil end
            local char = player.Character
            if char then
                local humanoid = char:FindFirstChild("Humanoid")
                local root = getRoot(char)
                if humanoid and root then
                    humanoid.PlatformStand = false
                    for _, v in pairs(root:GetChildren()) do
                        if v:IsA("BodyGyro") or v:IsA("BodyVelocity") then v:Destroy() end
                    end
                end
            end
            notify("AxoAdmin", "Fly disabled")
        end
    elseif command == "vfly" or command == "vehiclefly" then
        if not vehicleFlyActive then
            vehicleFlyActive = true
            local seat = nil
            if player.Character and player.Character:FindFirstChild("Humanoid") then
                seat = player.Character.Humanoid.SeatPart
            end
            if seat and seat.Parent then
                local bv = Instance.new("BodyVelocity")
                bv.MaxForce = Vector3.new(4000, 4000, 4000)
                bv.Parent = seat
                vehicleFlyConnection = RunService.Heartbeat:Connect(function()
                    if not vehicleFlyActive or not seat or not seat.Parent then return end
                    local move = Vector3.new(0, 0, 0)
                    if UserInputService:IsKeyDown(Enum.KeyCode.W) then move = move + camera.CFrame.LookVector end
                    if UserInputService:IsKeyDown(Enum.KeyCode.S) then move = move - camera.CFrame.LookVector end
                    if UserInputService:IsKeyDown(Enum.KeyCode.A) then move = move - camera.CFrame.RightVector end
                    if UserInputService:IsKeyDown(Enum.KeyCode.D) then move = move + camera.CFrame.RightVector end
                    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then move = move + Vector3.new(0, 1, 0) end
                    if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then move = move - Vector3.new(0, 1, 0) end
                    if move.Magnitude > 0 then move = move.Unit * 100 end
                    bv.Velocity = move
