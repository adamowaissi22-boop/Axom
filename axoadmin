local function executeCommand(command)
    local args = command:split(" ")
    local cmd = args[1]:lower()
    local value = args[2]
    local value2 = args[3]
    local value3 = args[4]
    
    if cmd == "audiologger" or cmd == "soundlogger" then
        loadstring(game:HttpGet("https://raw.githubusercontent.com/infyiff/backup/main/audiologger.lua"))()
        notify("AudioLogger", "Loaded")
    elseif cmd == "console" then
        StarterGui:SetCore("DevConsoleVisible", true)
        notify("Console", "Opened")
    elseif cmd == "fly" then
        if not flyActive then
            flyActive = true
            local char = player.Character
            if char then
                local humanoid = char:FindFirstChild("Humanoid")
                local root = getRoot(char)
                if humanoid and root then
                    humanoid.PlatformStand = true
                    local bodyGyro = Instance.new("BodyGyro")
                    local bodyVelocity = Instance.new("BodyVelocity")
                    bodyGyro.Parent = root
                    bodyVelocity.Parent = root
                    bodyGyro.MaxTorque = Vector3.new(0, 4000, 0)
                    bodyGyro.P = 1000
                    bodyGyro.D = 50
                    bodyVelocity.MaxForce = Vector3.new(4000, 4000, 4000)
                    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
                    flyConnection = RunService.Heartbeat:Connect(function()
                        if not flyActive or not char or not root then return end
                        local moveDirection = Vector3.new(0, 0, 0)
                        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDirection = moveDirection + camera.CFrame.LookVector end
                        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDirection = moveDirection - camera.CFrame.LookVector end
                        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDirection = moveDirection - camera.CFrame.RightVector end
                        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDirection = moveDirection + camera.CFrame.RightVector end
                        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDirection = moveDirection + Vector3.new(0, 1, 0) end
                        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveDirection = moveDirection - Vector3.new(0, 1, 0) end
                        if moveDirection.Magnitude > 0 then moveDirection = moveDirection.Unit * 50 end
                        bodyVelocity.Velocity = moveDirection
                        bodyGyro.CFrame = camera.CFrame
                    end)
                end
            end
            notify("Fly", "Enabled")
        end
    elseif cmd == "unfly" then
        if flyActive then
            flyActive = false
            if flyConnection then flyConnection:Disconnect() flyConnection = nil end
            local char = player.Character
            if char then
                local humanoid = char:FindFirstChild("Humanoid")
                local root = getRoot(char)
                if humanoid and root then
                    humanoid.PlatformStand = false
                    for _, v in pairs(root:GetChildren()) do
                        if v:IsA("BodyGyro") or v:IsA("BodyVelocity") then v:Destroy() end
                    end
                end
            end
            notify("Fly", "Disabled")
        end
    elseif cmd == "invisible" then
        if player.Character then
            for _, v in pairs(player.Character:GetDescendants()) do
                if v:IsA("BasePart") then v.Transparency = 1 end
            end
            notify("Invisible", "Enabled")
        end
    elseif cmd == "visible" or cmd == "uninvisible" then
        if player.Character then
            for _, v in pairs(player.Character:GetDescendants()) do
                if v:IsA("BasePart") then v.Transparency = 0 end
            end
            notify("Visible", "Enabled")
        end
    elseif cmd == "naked" then
        if player.Character then
            for _, v in pairs(player.Character:GetDescendants()) do
                if v:IsA("Clothing") or v:IsA("Shirt") or v:IsA("Pants") or v:IsA("ShirtGraphic") then
                    v:Destroy()
                end
            end
            notify("Naked", "Applied")
        end
    elseif cmd == "unnaked" then
        notify("UnNaked", "Rejoin to restore clothes")
    elseif cmd == "headless" then
        if player.Character and player.Character:FindFirstChild("Head") then
            player.Character.Head.Size = Vector3.new(0.1, 0.1, 0.1)
            player.Character.Head.Transparency = 1
            for _, v in pairs(player.Character.Head:GetChildren()) do
                if v:IsA("Decal") or v:IsA("Texture") then v.Transparency = 1 end
            end
            notify("Headless", "Enabled")
        end
    elseif cmd == "unheadless" or cmd == "head" then
        if player.Character and player.Character:FindFirstChild("Head") then
            player.Character.Head.Size = Vector3.new(2, 1, 1)
            player.Character.Head.Transparency = 0
            for _, v in pairs(player.Character.Head:GetChildren()) do
                if v:IsA("Decal") or v:IsA("Texture") then v.Transparency = 0 end
            end
            notify("Head", "Restored")
        end
    elseif cmd == "age" then
        if value then
            local target = getPlayer(value)
            if target then
                local age = target.AccountAge
                notify("Age", target.DisplayName .. " is " .. age .. " days old")
            else
                notify("Error", "Player not found")
            end
        end
    elseif cmd == "copyposition" or cmd == "copypos" or cmd == "copycords" or cmd == "copycoordinates" then
        if player.Character and getRoot(player.Character) then
            local pos = getRoot(player.Character).Position
            local posStr = string.format("%.1f, %.1f, %.1f", pos.X, pos.Y, pos.Z)
            setclipboard(posStr)
            notify("Position", "Copied: " .. posStr)
        end
    elseif cmd == "tweentpto" or cmd == "tweento" then
        if value then
            local target = getPlayer(value)
            if target and target.Character and getRoot(target.Character) and player.Character and getRoot(player.Character) then
                local tween = TweenService:Create(getRoot(player.Character), TweenInfo.new(2, Enum.EasingStyle.Linear), {CFrame = getRoot(target.Character).CFrame})
                tween:Play()
                notify("Tween", "Moving to " .. target.DisplayName)
            else
                notify("Error", "Player not found")
            end
        end
    elseif cmd == "orbit" then
        if value then
            local target = getPlayer(value)
            if target and target.Character and getRoot(target.Character) and player.Character and getRoot(player.Character) then
                if orbitConnection then orbitConnection:Disconnect() end
                local angle = 0
                orbitConnection = RunService.Heartbeat:Connect(function()
                    if target and target.Character and getRoot(target.Character) and player.Character and getRoot(player.Character) then
                        angle = angle + 0.1
                        local radius = 5
                        local x = getRoot(target.Character).Position.X + math.cos(angle) * radius
                        local z = getRoot(target.Character).Position.Z + math.sin(angle) * radius
                        getRoot(player.Character).CFrame = CFrame.new(x, getRoot(target.Character).Position.Y + 2, z)
                    end
                end)
                notify("Orbit", "Orbiting " .. target.DisplayName)
            end
        end
    elseif cmd == "unorbit" then
        if orbitConnection then orbitConnection:Disconnect() orbitConnection = nil end
        notify("Orbit", "Disabled")
    elseif cmd == "bang" then
        if value then
            local target = getPlayer(value)
            if target and target.Character and getRoot(target.Character) and player.Character and getRoot(player.Character) then
                if bangConnection then bangConnection:Disconnect() end
                local humanoid = player.Character:FindFirstChildWhichIsA("Humanoid")
                if humanoid then
                    local anim = Instance.new("Animation")
                    anim.AnimationId = "rbxassetid://5918726674"
                    bangAnim = humanoid:LoadAnimation(anim)
                    bangAnim:Play()
                end
                bangConnection = RunService.Heartbeat:Connect(function()
                    if target and target.Character and getRoot(target.Character) and player.Character and getRoot(player.Character) then
                        getRoot(player.Character).CFrame = getRoot(target.Character).CFrame * CFrame.new(0, 0, 1.5)
                    end
                end)
                notify("Bang", "Banging " .. target.DisplayName)
            end
        end
    elseif cmd == "unbang" then
        if bangConnection then bangConnection:Disconnect() bangConnection = nil end
        if bangAnim then bangAnim:Stop() bangAnim = nil end
        notify("Bang", "Disabled")
    elseif cmd == "jerk" or cmd == "jerkoff" or cmd == "jerktool" then
        local humanoid = player.Character:FindFirstChildWhichIsA("Humanoid")
        if humanoid then
            local anim = Instance.new("Animation")
            anim.AnimationId = "rbxassetid://698251653"
            jerkAnim = humanoid:LoadAnimation(anim)
            jerkAnim:Play()
            jerkAnim:AdjustSpeed(0.7)
            notify("Jerk", "Enabled")
        end
    elseif cmd == "bunnyhop" or cmd == "bhop" then
        if bunnyHopConnection then bunnyHopConnection:Disconnect() end
        bunnyHopConnection = RunService.Heartbeat:Connect(function()
            local humanoid = player.Character:FindFirstChildWhichIsA("Humanoid")
            if humanoid and humanoid.MoveDirection.Magnitude > 0 then
                humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end)
        notify("BunnyHop", "Enabled")
    elseif cmd == "unbunnyhop" or cmd == "unbhop" then
        if bunnyHopConnection then bunnyHopConnection:Disconnect() bunnyHopConnection = nil end
        notify("BunnyHop", "Disabled")
    elseif cmd == "walkfling" or cmd == "touchfling" then
        if not walkFlingEnabled then
            walkFlingEnabled = true
            task.spawn(function()
                local char = player.Character
                local root = getRoot(char)
                local vel, movel = nil, 0.1
                while walkFlingEnabled do
                    RunService.Heartbeat:Wait()
                    char = player.Character
                    root = getRoot(char)
                    if root then
                        vel = root.Velocity
                        root.Velocity = vel * 10000 + Vector3.new(0, 10000, 0)
                        RunService.RenderStepped:Wait()
                        if root then root.Velocity = vel end
                        RunService.Stepped:Wait()
                        if root then root.Velocity = vel + Vector3.new(0, movel, 0) end
                        movel = -movel
                    end
                end
            end)
            notify("WalkFling", "Enabled")
        end
    elseif cmd == "unwalkfling" or cmd == "untouchfling" then
        walkFlingEnabled = false
        notify("WalkFling", "Disabled")
    elseif cmd == "antifling1" then
        loadstring(game:HttpGet("https://raw.githubusercontent.com/adamowaissi22-boop/Axom/refs/heads/main/AntiFling%20Script"))()
        notify("AntiFling1", "Enabled")
    elseif cmd == "swim" then
        local humanoid = player.Character:FindFirstChildWhichIsA("Humanoid")
        if humanoid then
            originalGravity = Workspace.Gravity
            Workspace.Gravity = 0
            humanoid:SetStateEnabled(Enum.HumanoidStateType.Swimming, true)
            humanoid:ChangeState(Enum.HumanoidStateType.Swimming)
            notify("Swim", "Enabled")
        end
    elseif cmd == "firstperson" or cmd == "firstp" or cmd == "1stperson" then
        player.CameraMode = Enum.CameraMode.LockFirstPerson
        notify("FirstPerson", "Enabled")
    elseif cmd == "thirdperson" or cmd == "3rdperson" or cmd == "3rdp" or cmd == "unfirstperon" or cmd == "un1stperson" or cmd == "un1stp" then
        player.CameraMode = Enum.CameraMode.Classic
        notify("ThirdPerson", "Enabled")
    elseif cmd == "view" or cmd == "spectate" then
        if value then
            local target = getPlayer(value)
            if target and target.Character and target.Character:FindFirstChildWhichIsA("Humanoid") then
                originalCameraSubject = camera.CameraSubject
                camera.CameraSubject = target.Character:FindFirstChildWhichIsA("Humanoid")
                notify("View", "Viewing " .. target.DisplayName)
            end
        end
    elseif cmd == "unview" or cmd == "unspectate" then
        if originalCameraSubject then
            camera.CameraSubject = originalCameraSubject
            originalCameraSubject = nil
        else
            camera.CameraSubject = player.Character:FindFirstChildWhichIsA("Humanoid")
        end
        notify("View", "Disabled")
    elseif cmd == "fov" then
        if value then
            local fov = tonumber(value)
            if fov then
                originalFOV = camera.FieldOfView
                camera.FieldOfView = fov
                notify("FOV", "Set to " .. fov)
            end
        end
    elseif cmd == "resetfov" then
        camera.FieldOfView = 70
        notify("FOV", "Reset to 70")
    elseif cmd == "resetcam" or cmd == "resetcamera" then
        camera.CameraType = Enum.CameraType.Custom
        camera.CameraSubject = player.Character:FindFirstChildWhichIsA("Humanoid")
        camera.FieldOfView = 70
        player.CameraMode = Enum.CameraMode.Classic
        notify("Camera", "Reset")
    elseif cmd == "audio" or cmd == "playaudio" or cmd == "sound" or cmd == "playsound" then
        if value then
            local cleanId = value:gsub("rbxassetid://", "")
            local volume = tonumber(value2) or 1
            if Workspace:FindFirstChild("AxomicAudio") then Workspace.AxomicAudio:Destroy() end
            local sound = Instance.new("Sound")
            sound.Name = "AxomicAudio"
            sound.SoundId = "rbxassetid://" .. cleanId
            sound.Volume = volume
            sound.Looped = true
            sound.Parent = Workspace
            sound:Play()
            notify("Audio", "Playing ID: " .. cleanId)
        end
    elseif cmd == "btools" or cmd == "buildingtools" then
        loadstring(game:HttpGet("https://raw.githubusercontent.com/infyiff/backup/refs/heads/main/f3x.lua"))()
        notify("BuildingTools", "Loaded")
    elseif cmd == "gear" then
        if value then
            local cleanId = value:gsub("rbxassetid://", "")
            local success, result = pcall(function()
                return game:GetObjects("rbxassetid://" .. cleanId)[1]
            end)
            if success and result then
                result.Parent = player.Backpack
                notify("Gear", "Added to backpack")
            end
        end
    elseif cmd == "clonetool" or cmd == "ctool" then
        local tool = player.Character:FindFirstChildOfClass("Tool") or player.Backpack:FindFirstChildOfClass("Tool")
        if tool then
            local clone = tool:Clone()
            clone.Parent = player.Backpack
            notify("CloneTool", "Cloned " .. tool.Name)
        else
            notify("Error", "No tool found")
        end
    elseif cmd == "copyavatar" or cmd == "copyoutfit" or cmd == "be" or cmd == "morph" or cmd == "char" then
        if value then
            local target = getPlayer(value)
            if target then
                local humanoid = player.Character:FindFirstChildWhichIsA("Humanoid")
                if humanoid then
                    local description = Players:GetHumanoidDescriptionFromUserId(target.UserId)
                    humanoid:ApplyDescription(description)
                    notify("CopyAvatar", "Copied " .. target.DisplayName .. "'s outfit")
                end
            end
        end
    elseif cmd == "boostfps" or cmd == "antilag" then
        if not boostFpsOn then
            boostFpsOn = true
            settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
            Lighting.Brightness = 1
            Lighting.FogEnd = 1000000
            Lighting.GlobalShadows = false
            for _, obj in pairs(Workspace:GetDescendants()) do
                if obj:IsA("BasePart") then obj.CastShadow = false end
                if obj:IsA("ParticleEmitter") or obj:IsA("Trail") then obj.Enabled = false end
            end
            notify("BoostFPS", "Enabled")
        end
    elseif cmd == "unboostfps" or cmd == "unantilag" then
        boostFpsOn = false
        settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
        Lighting.GlobalShadows = true
        notify("BoostFPS", "Disabled")
    elseif cmd == "aimbot" then
        aimbotEnabled = true
        aimbotConnection = RunService.Heartbeat:Connect(function()
            if not aimbotEnabled then return end
            local closest = nil
            local closestDist = aimbotFOV
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= player and p.Character and p.Character:FindFirstChild("Head") then
                    local headPos = p.Character.Head.Position
                    local screenPos, onScreen = camera:WorldToScreenPoint(headPos)
                    if onScreen then
                        local dist = (Vector2.new(mouse.X, mouse.Y) - Vector2.new(screenPos.X, screenPos.Y)).Magnitude
                        if dist < closestDist then
                            closestDist = dist
                            closest = p
                        end
                    end
                end
            end
            if closest and closest.Character and closest.Character:FindFirstChild("Head") then
                camera.CFrame = CFrame.lookAt(camera.CFrame.Position, closest.Character.Head.Position)
            end
        end)
        notify("Aimbot", "Enabled")
    elseif cmd == "unaimbot" then
        aimbotEnabled = false
        if aimbotConnection then aimbotConnection:Disconnect() aimbotConnection = nil end
        notify("Aimbot", "Disabled")
    elseif cmd == "walkonwalls" then
        if not walkOnWallsConnection then
            walkOnWallsConnection = RunService.Heartbeat:Connect(function()
                local humanoid = player.Character:FindFirstChildWhichIsA("Humanoid")
                if humanoid and humanoid.MoveDirection.Magnitude > 0 then
                    humanoid:ChangeState(Enum.HumanoidStateType.Climbing)
                end
            end)
            notify("WalkOnWalls", "Enabled")
        end
    elseif cmd == "unwalkonwalls" or cmd == "unwow" then
        if walkOnWallsConnection then walkOnWallsConnection:Disconnect() walkOnWallsConnection = nil end
        notify("WalkOnWalls", "Disabled")
    end
end

local function executeFromBox()
    if CommandBox.Text ~= "" then
        executeCommand(CommandBox.Text)
        CommandBox.Text = ""
    end
end

CommandBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then executeFromBox() end
end)

ExecuteButton.MouseButton1Click:Connect(executeFromBox)

UserInputService.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.F5 then
        MainFrame.Visible = not MainFrame.Visible
    end
end)

notify("Axomic CMD", "Press F5 to toggle UI | Type commands")
