MapsTab:CreateButton({
    Name = "CROSSROADS MAP",
    Callback = function()
        local RequestCommandSilent = game:GetService('ReplicatedStorage'):WaitForChild('HDAdminHDClient').Signals.RequestCommandSilent
        local player = game.Players.LocalPlayer
        local char = player.Character
        local backpack = player.Backpack
        local function getf3x()
            for _, v in ipairs(backpack:GetChildren()) do if v:FindFirstChild("SyncAPI") then return v end end
            for _, v in ipairs(char:GetChildren()) do if v:FindFirstChild("SyncAPI") then return v end end
            return nil
        end
        local f3x = getf3x()
        if not f3x then return end
        local syncapi = f3x.SyncAPI
        local serverendpoint = syncapi.ServerEndpoint
        fenv.mate = function(part, material)
            serverendpoint:InvokeServer('SyncMaterial', {{Part=part, Material=material}})
        end
        fenv.Resize = function(part, size, cframe)
            serverendpoint:InvokeServer('SyncResize', {{Part=part, CFrame=cframe, Size=size}})
        end
        fenv.floor = function(part, face)
            serverendpoint:InvokeServer('SyncTexture', {{TextureType='Texture', StudsPerTileU=2, Part=part, Face=face, StudsPerTileV=2, Texture='rbxassetid://83901588886686'}})
        end
        fenv.DestroyPart = function(part)
            serverendpoint:InvokeServer('Remove', {part})
        end
        RequestCommandSilent:InvokeServer(';punish all')
        task.wait(1)
        local model = game:GetObjects('rbxassetid://141621194')[1]
        model.Parent = game.Lighting
        for _, v in next, model:GetDescendants() do
            v.Anchored = true
        end
        task.wait(10)
        model.Parent = nil
        fenv.f3xbuildpart = function() end
        print('Finished build.')
        task.wait(5)
        wait(8)
        game:GetService('ReplicatedStorage'):WaitForChild('HDAdminHDClient').Signals.RequestCommandSilent:InvokeServer(';respawn all')
    end
})

