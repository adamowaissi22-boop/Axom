function updateSelectionBox(target)
    if not target or not selectionBox then return end
    selectionBox.Size = target.Size
    selectionBox.Position = target.Position
    selectionBox.Rotation = target.Rotation
    selectionBox.BackgroundTransparency = 0.85
    selectionBox.Visible = true
end

function clearSelection()
    currentSelected = nil
    selectionBox.Visible = false
    refreshPropertiesPanel(nil)
end

function refreshPropertiesPanel(selected)
    for _, child in pairs(propertiesFrame:GetChildren()) do
        if child:IsA("Frame") and child.Name == "PropFrame" then
            child:Destroy()
        end
    end
    
    if not selected or not editMode then
        local emptyLabel = Instance.new("TextLabel")
        emptyLabel.Name = "EmptyLabel"
        emptyLabel.Size = UDim2.new(1, -10, 0, 30)
        emptyLabel.Position = UDim2.new(0, 5, 0, 10)
        emptyLabel.BackgroundTransparency = 1
        emptyLabel.Text = "No element selected"
        emptyLabel.TextColor3 = Color3.fromRGB(150, 180, 200)
        emptyLabel.TextSize = 12
        emptyLabel.Font = Enum.Font.Gotham
        emptyLabel.Parent = propertiesFrame
        propertiesFrame.CanvasSize = UDim2.new(0, 0, 0, 50)
        return
    end
    
    local properties = {
        {name = "Name", property = "Name", type = "text"},
        {name = "Parent", property = "Parent", type = "parent"},
        {name = "Background Color", property = "BackgroundColor3", type = "color"},
        {name = "Background Transparency", property = "BackgroundTransparency", type = "number", min = 0, max = 1},
        {name = "Size X Offset", property = "Size", type = "sizeX"},
        {name = "Size Y Offset", property = "Size", type = "sizeY"},
        {name = "Position X Offset", property = "Position", type = "posX"},
        {name = "Position Y Offset", property = "Position", type = "posY"},
        {name = "Rotation", property = "Rotation", type = "number", min = -360, max = 360},
        {name = "Visible", property = "Visible", type = "bool"},
        {name = "ZIndex", property = "ZIndex", type = "number", min = 0, max = 10}
    }
    
    if selected:IsA("TextButton") or selected:IsA("TextLabel") or selected:IsA("TextBox") then
        table.insert(properties, {name = "Text", property = "Text", type = "text"})
        table.insert(properties, {name = "Text Color", property = "TextColor3", type = "color"})
        table.insert(properties, {name = "Text Size", property = "TextSize", type = "number", min = 8, max = 100})
        table.insert(properties, {name = "Text Transparency", property = "TextTransparency", type = "number", min = 0, max = 1})
        if selected:IsA("TextBox") then
            table.insert(properties, {name = "Clear Text On Focus", property = "ClearTextOnFocus", type = "bool"})
        end
    end
    
    if selected:IsA("ScrollingFrame") then
        table.insert(properties, {name = "Scroll Bar Thickness", property = "ScrollBarThickness", type = "number", min = 0, max = 20})
    end
    
    if selected:IsA("ImageLabel") then
        table.insert(properties, {name = "Image", property = "Image", type = "text"})
    end
    
    local yPos = 5
    for _, prop in pairs(properties) do
        local propFrame = Instance.new("Frame")
        propFrame.Name = "PropFrame"
        propFrame.Size = UDim2.new(1, -10, 0, 40)
        propFrame.Position = UDim2.new(0, 5, 0, yPos)
        propFrame.BackgroundTransparency = 1
        propFrame.Parent = propertiesFrame
        
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(0.45, -5, 1, 0)
        label.Position = UDim2.new(0, 0, 0, 0)
        label.BackgroundTransparency = 1
        label.Text = prop.name
        label.TextColor3 = Color3.fromRGB(200, 220, 240)
        label.TextSize = 11
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.Font = Enum.Font.Gotham
        label.Parent = propFrame
        
        if prop.type == "text" then
            local input = Instance.new("TextBox")
            input.Size = UDim2.new(0.55, -5, 1, -5)
            input.Position = UDim2.new(0.45, 5, 0, 2.5)
            input.BackgroundColor3 = Color3.fromRGB(20, 50, 70)
            input.TextColor3 = Color3.fromRGB(255, 255, 255)
            input.Text = tostring(selected[prop.property])
            input.ClearTextOnFocus = false
            input.Font = Enum.Font.Gotham
            input.TextSize = 11
            input.Parent = propFrame
            
            local inputCorner = Instance.new("UICorner")
            inputCorner.CornerRadius = UDim.new(0, 4)
            inputCorner.Parent = input
            
            input.FocusLost:Connect(function()
                if prop.property == "Name" then
                    selected.Name = input.Text
                elseif prop.property == "Text" then
                    selected.Text = input.Text
                elseif prop.property == "Image" then
                    selected.Image = input.Text
                end
                refreshPropertiesPanel(selected)
            end)
        elseif prop.type == "parent" then
            local dropdown = Instance.new("TextButton")
            dropdown.Size = UDim2.new(0.55, -5, 1, -5)
            dropdown.Position = UDim2.new(0.45, 5, 0, 2.5)
            dropdown.Text = tostring(selected.Parent.Name)
            dropdown.BackgroundColor3 = Color3.fromRGB(20, 50, 70)
            dropdown.TextColor3 = Color3.fromRGB(255, 255, 255)
            dropdown.Font = Enum.Font.Gotham
            dropdown.TextSize = 11
            dropdown.Parent = propFrame
            
            local dropdownCorner = Instance.new("UICorner")
            dropdownCorner.CornerRadius = UDim.new(0, 4)
            dropdownCorner.Parent = dropdown
            
            dropdown.MouseButton1Click:Connect(function()
                local menuFrame = Instance.new("ScrollingFrame")
                menuFrame.Size = scaleSize(140, 120)
                menuFrame.Position = UDim2.new(0, dropdown.AbsolutePosition.X, 0, dropdown.AbsolutePosition.Y + 35)
