function addComponentToWorkspace(componentClass, componentName)
    local newGui
    
    if componentClass == "UIGradient" or componentClass == "UICorner" or componentClass == "UIListLayout" or componentClass == "UIGridLayout" or componentClass == "UIPadding" then
        if currentSelected and currentSelected:IsA("GuiObject") then
            newGui = Instance.new(componentClass)
            newGui.Name = componentName
            newGui.Parent = currentSelected
            return newGui
        else
            return nil
        end
    end
    
    newGui = Instance.new(componentClass)
    newGui.Name = componentName .. "_" .. math.random(1000, 9999)
    newGui.Size = scaleSize(140, 90)
    
    local finalX = 30 + math.random(0, math.max(50, workspaceFrame.AbsoluteSize.X - 180))
    local finalY = 30 + math.random(0, math.max(50, workspaceFrame.AbsoluteSize.Y - 140))
    
    newGui.Position = UDim2.new(0, finalX, 0, finalY)
    newGui.BackgroundColor3 = Color3.fromRGB(70, 130, 180)
    newGui.BorderSizePixel = 1
    newGui.BorderColor3 = Color3.fromRGB(200, 220, 255)
    newGui.Parent = workspaceFrame
    
    local elementCorner = Instance.new("UICorner")
    elementCorner.CornerRadius = UDim.new(0, 4)
    elementCorner.Parent = newGui
    
    if componentClass == "TextButton" or componentClass == "TextLabel" or componentClass == "TextBox" then
        newGui.Text = componentName
        newGui.TextColor3 = Color3.fromRGB(255, 255, 255)
        newGui.BackgroundColor3 = Color3.fromRGB(60, 110, 150)
        newGui.Font = Enum.Font.Gotham
        newGui.TextSize = 14 * scale
    end
    
    if componentClass == "ScrollingFrame" then
        newGui.BackgroundColor3 = Color3.fromRGB(40, 80, 110)
        local scrollCorner = Instance.new("UICorner")
        scrollCorner.CornerRadius = UDim.new(0, 4)
        scrollCorner.Parent = newGui
        newGui.ScrollBarThickness = 6
    end
    
    newGui.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if editMode then
                currentSelected = newGui
                updateSelectionBox(newGui)
                refreshPropertiesPanel(newGui)
                
                local dragStartPos = nil
                local dragStartMouse = nil
                local dragging = false
                
                local moveConn
                moveConn = game:GetService("UserInputService").InputChanged:Connect(function(moveInput)
                    if dragging and dragStartPos and dragStartMouse and (moveInput.UserInputType == Enum.UserInputType.MouseMovement or moveInput.UserInputType == Enum.UserInputType.Touch) then
                        local delta = moveInput.Position - dragStartMouse
                        local newPos = UDim2.new(dragStartPos.X.Scale, dragStartPos.X.Offset + delta.X, dragStartPos.Y.Scale, dragStartPos.Y.Offset + delta.Y)
                        newGui.Position = newPos
                        updateSelectionBox(newGui)
                    end
                end)
                
                local dragConn
                dragConn = input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.Begin then
                        dragStartPos = newGui.Position
                        dragStartMouse = input.Position
                        dragging = true
                    elseif input.UserInputState == Enum.UserInputState.End then
                        dragging = false
                        dragConn:Disconnect()
                        moveConn:Disconnect()
                    end
                end)
            end
        end
    end)
    
    return newGui
end

function generateScript()
    local scriptLines = {"local screenGui = Instance.new(\"ScreenGui\")", "screenGui.Name = \"screengui\"", "screenGui.Parent = game:GetService(\"CoreGui\")", "screenGui.ResetOnSpawn = false", ""}
    
    local function serializeGui(gui, indent)
        local lines = {}
        local spaces = string.rep("    ", indent)
        local varName = gui.Name:gsub("%W", "")
        
        if #varName == 0 then varName = "gui_" .. math.random(1000, 9999) end
        
        lines[#lines + 1] = spaces .. "local " .. varName .. " = Instance.new(\"" .. gui.ClassName .. "\")"
        lines[#lines + 1] = spaces .. varName .. ".Name = \"" .. gui.Name .. "\""
        
        if gui:IsA("GuiObject") then
            lines[#lines + 1] = spaces .. varName .. ".Size = UDim2.new(" .. gui.Size.X.Scale .. ", " .. gui.Size.X.Offset .. ", " .. gui.Size.Y.Scale .. ", " .. gui.Size.Y.Offset .. ")"
            lines[#lines + 1] = spaces .. varName .. ".Position = UDim2.new(" .. gui.Position.X.Scale .. ", " .. gui.Position.X.Offset .. ", " .. gui.Position.Y.Scale .. ", " .. gui.Position.Y.Offset .. ")"
            lines[#lines + 1] = spaces .. varName .. ".BackgroundColor3 = Color3.new(" .. gui.BackgroundColor3.R .. ", " .. gui.BackgroundColor3.G .. ", " .. gui.BackgroundColor3.B .. ")"
            lines[#lines + 1] = spaces .. varName .. ".BackgroundTransparency = " .. gui.BackgroundTransparency
            lines[#lines + 1] = spaces .. varName .. ".BorderSizePixel = " .. gui.BorderSizePixel
            lines[#lines + 1] = spaces .. varName .. ".Rotation = " .. gui.Rotation
            lines[#lines + 1] = spaces .. varName .. ".Visible = " .. tostring(gui.Visible)
            if gui:IsA("ScrollingFrame") then
                lines[#lines + 1] = spaces .. varName .. ".ScrollBarThickness = " .. (gui.ScrollBarThickness or 6)
            end
        end
        
        if gui:IsA("TextButton") or gui:IsA("TextLabel") or gui:IsA("TextBox") then
            lines[#lines + 1] = spaces .. varName .. ".Text = \"" .. gui.Text .. "\""
            lines[#lines + 1] = spaces .. varName .. ".TextColor3 = Color3.new(" .. gui.TextColor3.R .. ", " .. gui.TextColor3.G .. ", " .. gui.TextColor3.B .. ")"
            lines[#lines + 1] = spaces .. varName .. ".TextSize = " .. gui.TextSize
            if gui:IsA("TextBox") then
                lines[#lines + 1] = spaces .. varName .. ".ClearTextOnFocus = " .. tostring(gui.ClearTextOnFocus)
            end
        end
        
        if gui:IsA("ImageLabel") then
            lines[#lines + 1] = spaces .. varName .. ".Image = \"" .. gui.Image .. "\""
        end
        
        for _, child in pairs(gui:GetChildren()) do
            if child:IsA("UIGradient") or child:IsA("UICorner") or child:IsA("UIListLayout") or child:IsA("UIGridLayout") or child:IsA("UIPadding") then
                lines[#lines + 1] = spaces .. "local child = Instance.new(\"" .. child.ClassName .. "\")"
                lines[#lines + 1] = spaces .. "child.Parent = " .. varName
                if child:IsA("UICorner") and child.CornerRadius then
                    lines[#lines + 1] = spaces .. "child.CornerRadius = UDim.new(0, " .. (child.CornerRadius.Offset or 8) .. ")"
                end
            end
        end
        
        lines[#lines + 1] = spaces .. varName .. ".Parent = screenGui"
        
        for _, child in pairs(gui:GetChildren()) do
            if child:IsA("GuiObject") and child ~= selectionBox then
                local childLines = serializeGui(child, indent + 1)
                for _, line in pairs(childLines) do
                    lines[#lines + 1] = line
                end
            end
        end
        
        return lines
    end
    
    for _, child in pairs(workspaceFrame:GetChildren()) do
        if child:IsA("GuiObject") and child ~= selectionBox then
            local guiLines = serializeGui(child, 0)
            for _, line in pairs(guiLines) do
                scriptLines[#scriptLines + 1] = line
            end
            scriptLines[#scriptLines + 1] = ""
        end
    end
    
    local outputBox = Instance.new("TextBox")
    outputBox.Size = UDim2.new(0.8, 0, 0.4, 0)
    outputBox.Position = UDim2.new(0.1, 0, 0.3, 0)
    outputBox.BackgroundColor3 = Color3.fromRGB(10, 30, 45)
    outputBox.TextColor3 = Color3.fromRGB(200, 220, 240)
    outputBox.TextXAlignment = Enum.TextXAlignment.Left
    outputBox.TextYAlignment = Enum.TextYAlignment.Top
    outputBox.Text = table.concat(scriptLines, "\n")
    outputBox.ClearTextOnFocus = false
    outputBox.Font = Enum.Font.Code
    outputBox.TextSize = 11 * scale
    outputBox.MultiLine = true
    outputBox.ZIndex = 100
    outputBox.Parent = mainFrame
    
    local outputCorner = Instance.new("UICorner")
    outputCorner.CornerRadius = UDim.new(0, 6)
    outputCorner.Parent = outputBox
    
    local closeOutput = Instance.new("TextButton")
    closeOutput.Size = scaleSize(30, 30)
    closeOutput.Position = UDim2.new(0.8, -35, 0.3, 5)
    closeOutput.Text = "X"
    closeOutput.TextColor3 = Color3.fromRGB(255, 255, 255)
    closeOutput.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    closeOutput.BorderSizePixel = 0
    closeOutput.Font = Enum.Font.GothamBold
    closeOutput.TextSize = 14 * scale
    closeOutput.Parent = mainFrame
    
    local closeOutputCorner = Instance.new("UICorner")
    closeOutputCorner.CornerRadius = UDim.new(0, 4)
    closeOutputCorner.Parent = closeOutput
    
    closeOutput.MouseButton1Click:Connect(function()
        outputBox:Destroy()
        closeOutput:Destroy()
    end)
    
    task.wait(5)
    if outputBox and outputBox.Parent then
        outputBox:Destroy()
        closeOutput:Destroy()
    end
end

