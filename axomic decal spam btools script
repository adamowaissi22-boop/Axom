spam.MouseButton1Click:Connect(function()
    local p = game.Players.LocalPlayer
    local t
    for _,v in p:GetDescendants() do if v.Name == "SyncAPI" then t = v.Parent end end
    for _,v in game.ReplicatedStorage:GetDescendants() do if v.Name == "SyncAPI" then t = v.Parent end end
    local r = t.SyncAPI.ServerEndpoint
    
    local function _(a) r:InvokeServer(unpack(a)) end
    
    local function col(p,b) _({"SyncCollision",{{["Part"]=p,["CanCollide"]=b}}}) end
    local function anc(p,b) _({"SyncAnchor",{{["Part"]=p,["Anchored"]=b}}}) end
    local function kill(p) _({"Remove",{p}}) end
    local function lock(p,b) _({"SetLocked",{p},b}) end
    local function dec(p,s) _({"CreateTextures",{{["Part"]=p,["Face"]=s,["TextureType"]="Decal"}}}) end
    local function add(p,a,s) _({"SyncTexture",{{["Part"]=p,["Face"]=s,["TextureType"]="Decal",["Texture"]="rbxassetid://"..a}}}) end
    
    local function nuke(id)
        local parts = {}
        for _,v in game.workspace:GetDescendants() do if v:IsA("BasePart") then table.insert(parts, v) end end
        for _,v in pairs(parts) do
            lock(v, false)
            local faces = {Enum.NormalId.Front, Enum.NormalId.Back, Enum.NormalId.Right, Enum.NormalId.Left, Enum.NormalId.Bottom, Enum.NormalId.Top}
            for _,face in pairs(faces) do
                spawn(function()
                    dec(v, face)
                    add(v, id, face)
                end)
            end
        end
    end
    
    nuke(71007442178709)
end)
