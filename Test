        Page.Visible = true
        Btn.BackgroundColor3 = Themes[CurrentTheme].Accent
        Btn.TextColor3 = Color3.fromRGB(255,255,255)
    end)
    if #TabBar:GetChildren() == 1 then Btn.MouseButton1Click:Fire() end
