	Instance.new("UIPadding", Page).PaddingLeft = UDim.new(0,5)
	Instance.new("UIPadding", Page).PaddingRight = UDim.new(0,5)
	
	table.insert(Tabs, {Btn = TabBtn, Page = Page})
	
	TabBtn.MouseButton1Click:Connect(function()
		for _,t in ipairs(Tabs) do
			t.Page.Visible = false
			TweenService:Create(t.Btn, TweenInfo.new(0.2), {BackgroundColor3 = Theme.Sc}):Play()
		end
		Page.Visible = true
		TweenService:Create(TabBtn, TweenInfo.new(0.2), {BackgroundColor3 = Theme.Ac}):Play()
		CurrentPage = Page
	end)
	
	if #Tabs == 1 then
