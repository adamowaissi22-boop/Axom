local keywordsList = {}
for category, words in pairs(keywords) do
    for _, word in ipairs(words) do
        keywordsList[word] = category
    end
end

local function extractIntent(prompt)
    local wants = {}
    local dontWants = {}
    
    local lowerPrompt = string.lower(prompt)
    
    local negationRegex = "(" .. table.concat(negationPatterns, "|") .. ")%s+(%S+)"
    
    for negationType, term in string.gmatch(lowerPrompt, negationRegex) do
        for word, category in pairs(keywordsList) do
            if string.find(term, word) then
                table.insert(dontWants, category)
                break
            end
        end
    end
    
    for word, category in pairs(keywordsList) do
        local isNegated = false
        for _, dontWant in ipairs(dontWants) do
            if dontWant == category then
                isNegated = true
                break
            end
        end
        if not isNegated and string.find(lowerPrompt, word) then
            local hasNegationBefore = false
            for _, pattern in ipairs(negationPatterns) do
                local pos = string.find(lowerPrompt, pattern .. "%s+" .. word)
                if pos then
                    hasNegationBefore = true
                    break
                end
            end
            if not hasNegationBefore then
                table.insert(wants, category)
            end
        end
    end
    
    return wants, dontWants
end

