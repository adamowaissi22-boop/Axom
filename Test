					if configKey then
						self:SetConfigValue(configKey, {r = math.floor(c.R * 255), g = math.floor(c.G * 255), b = math.floor(c.B * 255)})
					end
				end
			}
		end,
		
		AddPlayerSelector = function(self, parent, callback)
			local holder = Instance.new("Frame")
			holder.BackgroundColor3 = self.Theme.Element
			holder.Size = UDim2.new(1, 0, 0, 240)
			holder.Parent = parent
			holder.LayoutOrder = #parent:GetChildren()
			Instance.new("UICorner", holder).CornerRadius = UDim.new(0, 8)
			
			local search = Instance.new("TextBox")
			search.BackgroundColor3 = self.Theme.Secondary
			search.Position = UDim2.new(0, 15, 0, 12)
			search.Size = UDim2.new(1, -30, 0, 38)
			search.Font = Enum.Font.Gotham
			search.PlaceholderText = "Search players..."
			search.Text = ""
			search.TextColor3 = self.Theme.Text
			search.TextSize = 13
			search.Parent = holder
			Instance.new("UICorner", search).CornerRadius = UDim.new(0, 6)
			
			local scroll = Instance.new("ScrollingFrame")
			scroll.BackgroundTransparency = 1
			scroll.Position = UDim2.new(0, 15, 0, 60)
			scroll.Size = UDim2.new(1, -30, 1, -75)
			scroll.ScrollBarThickness = 4
			scroll.ScrollBarImageColor3 = self.Theme.Accent
			scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
			scroll.Parent = holder
			
			local listLayout = Instance.new("UIListLayout", scroll)
			listLayout.Padding = UDim.new(0, 6)
			
			table.insert(self.Elements, {
				UpdateTheme = function(_, newTheme)
					holder.BackgroundColor3 = newTheme.Element
					search.BackgroundColor3 = newTheme.Secondary
					search.TextColor3 = newTheme.Text
					scroll.ScrollBarImageColor3 = newTheme.Accent
				end
			})
			
			local function refresh(query)
				for _, c in ipairs(scroll:GetChildren()) do
					if c:IsA("TextButton") then c:Destroy() end
				end
				for _, plr in ipairs(Players:GetPlayers()) do
					if not query or plr.Name:lower():find(query:lower()) then
						local btn = Instance.new("TextButton")
						btn.BackgroundColor3 = self.Theme.Secondary
						btn.Size = UDim2.new(1, 0, 0, 38)
						btn.Font = Enum.Font.Gotham
						btn.Text = "  " .. plr.Name
						btn.TextColor3 = self.Theme.Text
						btn.TextSize = 13
						btn.TextXAlignment = Enum.TextXAlignment.Left
						btn.AutoButtonColor = false
						btn.Parent = scroll
						Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
						
						btn.MouseButton1Click:Connect(function()
							if callback then callback(plr) end
						end)
					end
				end
			end
			
			search:GetPropertyChangedSignal("Text"):Connect(function()
				refresh(search.Text)
			end)
			
			refresh()
			Players.PlayerAdded:Connect(refresh)
			Players.PlayerRemoving:Connect(refresh)
		end,
		
		AddLabel = function(self, parent, text)
			local lbl = Instance.new("TextLabel")
			lbl.BackgroundTransparency = 1
			lbl.Size = UDim2.new(1, 0, 0, 28)
			lbl.Font = Enum.Font.Gotham
			lbl.Text = text
			lbl.TextColor3 = self.Theme.TextDark
			lbl.TextSize = 13
			lbl.TextWrapped = true
			lbl.TextXAlignment = Enum.TextXAlignment.Left
			lbl.Parent = parent
			lbl.LayoutOrder = #parent:GetChildren()
			
			table.insert(self.Elements, {
				UpdateTheme = function(_, newTheme)
					lbl.TextColor3 = newTheme.TextDark
				end
			})
			
			return lbl
		end,
		
		AddParagraph = function(self, parent, text)
			local lbl = Instance.new("TextLabel")
			lbl.BackgroundTransparency = 1
			lbl.Size = UDim2.new(1, 0, 0, 55)
			lbl.Font = Enum.Font.Gotham
			lbl.Text = text
			lbl.TextColor3 = self.Theme.Text
			lbl.TextSize = 13
			lbl.TextWrapped = true
			lbl.TextXAlignment = Enum.TextXAlignment.Left
			lbl.TextYAlignment = Enum.TextYAlignment.Top
			lbl.Parent = parent
			lbl.LayoutOrder = #parent:GetChildren()
			
			table.insert(self.Elements, {
				UpdateTheme = function(_, newTheme)
					lbl.TextColor3 = newTheme.Text
				end
			})
			
			return lbl
		end,
		
		AddImage = function(self, parent, imageId, size)
			local img = Instance.new("ImageLabel")
			img.BackgroundTransparency = 1
			img.Size = size or UDim2.new(0, 120, 0, 120)
			img.Image = imageId or ""
			img.ScaleType = Enum.ScaleType.Fit
			img.Parent = parent
			img.LayoutOrder = #parent:GetChildren()
			Instance.new("UICorner", img).CornerRadius = UDim.new(0, 8)
			return img
		end,
		
		AddSearch = function(self, parent, placeholder, callback)
			local box = Instance.new("TextBox")
			box.BackgroundColor3 = self.Theme.Secondary
			box.Size = UDim2.new(1, 0, 0, 38)
			box.Font = Enum.Font.Gotham
			box.PlaceholderText = placeholder or "Search..."
			box.Text = ""
			box.TextColor3 = self.Theme.Text
			box.TextSize = 13
			box.Parent = parent
			box.LayoutOrder = #parent:GetChildren()
			Instance.new("UICorner", box).CornerRadius = UDim.new(0, 6)
			
			table.insert(self.Elements, {
				UpdateTheme = function(_, newTheme)
					box.BackgroundColor3 = newTheme.Secondary
					box.TextColor3 = newTheme.Text
				end
			})
			
			box:GetPropertyChangedSignal("Text"):Connect(function()
				if callback then callback(box.Text) end
			end)
			
			return box
		end,
		
		AddSettings = function(self, parent)
			local settingsTab = parent
			
			self:AddSection(settingsTab, "Appearance")
			
			local themeOptions = {}
			for name, _ in pairs(Themes) do
				table.insert(themeOptions, name)
			end
			
			self:AddDropdown(settingsTab, "UI Theme", themeOptions, function(selectedTheme)
				self:ApplyTheme(selectedTheme)
			end, "Theme")
			
			self:AddSection(settingsTab, "Configuration")
			
			self:AddButton(settingsTab, "Save Configuration", function()
				self:SaveConfig()
				self:Notify("Configuration saved!", 2)
			end)
			
			self:AddButton(settingsTab, "Load Configuration", function()
				local data = self:LoadConfig()
				if data then
					self:Notify("Configuration loaded!", 2)
					if data.Theme then
						self:ApplyTheme(data.Theme)
					end
				else
					self:Notify("No configuration found!", 2)
				end
			end)
			
			self:AddButton(settingsTab, "Reset Configuration", function()
				self.ConfigData = {}
				self:SaveConfig()
				self:Notify("Configuration reset!", 2)
			end)
			
			self:AddSection(settingsTab, "UI Settings")
			
			self:AddToggle(settingsTab, "Show Notifications", true, function(v)
				self:SetConfigValue("ShowNotifications", v)
			end, "ShowNotifications")
			
			self:AddSection(settingsTab, "Info")
			
			self:AddParagraph(settingsTab, "Axovoc UI Library v2.0\nMade for Roblox scripting community.\nUse the config system to save your preferences.")
		end,
		
		Notify = function(self, message, duration)
			if self:GetConfigValue("ShowNotifications") == false then return end
			local gui = main:FindFirstAncestorOfClass("ScreenGui")
			local notif = Instance.new("Frame")
			notif.BackgroundColor3 = self.Theme.Secondary
			notif.BackgroundTransparency = 0.1
			notif.Position = UDim2.new(0.5, -160, 0, -90)
			notif.Size = UDim2.new(0, 320, 0, 75)
			notif.ZIndex = 100
			notif.Parent = gui
			Instance.new("UICorner", notif).CornerRadius = UDim.new(0, 10)
			
			local stroke = Instance.new("UIStroke", notif)
			stroke.Color = self.Theme.Accent
			stroke.Thickness = 2
			
			local lbl = Instance.new("TextLabel")
			lbl.BackgroundTransparency = 1
			lbl.Size = UDim2.new(1, -20, 1, 0)
			lbl.Position = UDim2.new(0, 10, 0, 0)
			lbl.Font = Enum.Font.Gotham
			lbl.Text = message
			lbl.TextColor3 = self.Theme.Text
			lbl.TextSize = 14
			lbl.TextWrapped = true
			lbl.Parent = notif
			
			TweenService:Create(notif, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -160, 0, 25)}):Play()
			task.delay(duration or 3, function()
				TweenService:Create(notif, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -160, 0, -90)}):Play()
				task.wait(0.3)
				notif:Destroy()
			end)
		end
	}
	
	searchBox:GetPropertyChangedSignal("Text"):Connect(function()
		local query = searchBox.Text:lower()
		for _, tab in ipairs(window.Tabs) do
			if query == "" or tab.Name:lower():find(query) then
				tab.Button.Visible = true
			else
				tab.Button.Visible = false
			end
		end
	end)
	
	task.spawn(function()
		task.wait(0.5)
		local loaded = window:LoadConfig()
		if loaded then
			if loaded.Theme then
				window:ApplyTheme(loaded.Theme)
			end
		end
	end)
	
	return window
end

return AxovocUI
