function AxovocUI:CreateWindow(config)
	config = config or {}
	local themeName = config.Theme or "Default"
	local theme = Themes[themeName]
	local title = config.Title or "Axovoc UI"
	local key = config.Key
	local scriptName = config.ScriptName or "Axovoc UI"
	local configFolder = config.ConfigFolder or "AxovocConfigs"
	local saveName = config.SaveName or "Default"
	
	local gui = Instance.new("ScreenGui")
	gui.Name = "AxovocUI"
	gui.ResetOnSpawn = false
	gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	gui.Parent = LocalPlayer:WaitForChild("PlayerGui")
	
	local minimizedButton = Instance.new("TextButton")
	minimizedButton.Name = "MinBtn"
	minimizedButton.BackgroundColor3 = theme.Accent
	minimizedButton.BorderSizePixel = 0
	minimizedButton.Position = UDim2.new(0, 20, 0, 20)
	minimizedButton.Size = UDim2.new(0, 160, 0, 45)
	minimizedButton.Font = Enum.Font.GothamBold
	minimizedButton.Text = "Open " .. scriptName
	minimizedButton.TextColor3 = Color3.new(1, 1, 1)
	minimizedButton.TextSize = 14
	minimizedButton.Visible = false
	minimizedButton.AutoButtonColor = false
	minimizedButton.Parent = gui
	Instance.new("UICorner", minimizedButton).CornerRadius = UDim.new(0, 10)
	local minStroke = Instance.new("UIStroke", minimizedButton)
	minStroke.Color = theme.Border
	minStroke.Thickness = 2
	
	local main = Instance.new("Frame")
	main.Name = "Main"
	main.BackgroundColor3 = theme.Background
	main.BackgroundTransparency = theme.Transparency
	main.BorderSizePixel = 0
	main.Position = UDim2.new(0.5, -350, 0.5, -225)
	main.Size = UDim2.new(0, 700, 0, 450)
	main.Active = true
	main.ClipsDescendants = true
	main.Parent = gui
	Instance.new("UICorner", main).CornerRadius = UDim.new(0, 12)
	local mainStroke = Instance.new("UIStroke", main)
	mainStroke.Color = theme.Border
	mainStroke.Thickness = 1
	
	local resizeHandle = Instance.new("TextButton")
	resizeHandle.Name = "Resize"
	resizeHandle.BackgroundColor3 = theme.Accent
	resizeHandle.BackgroundTransparency = 0.5
	resizeHandle.BorderSizePixel = 0
	resizeHandle.Position = UDim2.new(1, -20, 1, -20)
	resizeHandle.Size = UDim2.new(0, 20, 0, 20)
	resizeHandle.Font = Enum.Font.Gotham
	resizeHandle.Text = ""
	resizeHandle.AutoButtonColor = false
	resizeHandle.Parent = main
	Instance.new("UICorner", resizeHandle).CornerRadius = UDim.new(0, 6)
	
	local resizeIcon = Instance.new("Frame")
	resizeIcon.BackgroundColor3 = theme.Text
	resizeIcon.BorderSizePixel = 0
	resizeIcon.Position = UDim2.new(0, 8, 0, 8)
	resizeIcon.Size = UDim2.new(0, 8, 0, 2)
	resizeIcon.Parent = resizeHandle
	local resizeIcon2 = Instance.new("Frame")
	resizeIcon2.BackgroundColor3 = theme.Text
	resizeIcon2.BorderSizePixel = 0
	resizeIcon2.Position = UDim2.new(0, 12, 0, 4)
	resizeIcon2.Size = UDim2.new(0, 4, 0, 2)
	resizeIcon2.Parent = resizeHandle
	
	local minWidth, minHeight = 550, 350
	local maxWidth, maxHeight = 1300, 850
	
	local resizing = false
	resizeHandle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			resizing = true
		end
	end)
	
	UserInputService.InputChanged:Connect(function(input)
		if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local newWidth = math.clamp(input.Position.X - main.AbsolutePosition.X, minWidth, maxWidth)
			local newHeight = math.clamp(input.Position.Y - main.AbsolutePosition.Y, minHeight, maxHeight)
			main.Size = UDim2.new(0, newWidth, 0, newHeight)
		end
	end)
	
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			resizing = false
		end
	end)
	
	if key then
		local keyFrame = Instance.new("Frame")
		keyFrame.BackgroundColor3 = theme.Background
		keyFrame.BackgroundTransparency = theme.Transparency
		keyFrame.BorderSizePixel = 0
		keyFrame.Position = UDim2.new(0.5, -175, 0.5, -120)
		keyFrame.Size = UDim2.new(0, 350, 0, 240)
		keyFrame.Parent = gui
		Instance.new("UICorner", keyFrame).CornerRadius = UDim.new(0, 12)
		Instance.new("UIStroke", keyFrame).Color = theme.Border
		
		local keyTitle = Instance.new("TextLabel")
		keyTitle.BackgroundTransparency = 1
		keyTitle.Position = UDim2.new(0, 0, 0, 25)
		keyTitle.Size = UDim2.new(1, 0, 0, 35)
		keyTitle.Font = Enum.Font.GothamBold
		keyTitle.Text = "Key System"
		keyTitle.TextColor3 = theme.Text
		keyTitle.TextSize = 22
		keyTitle.Parent = keyFrame
		
		local keyBox = Instance.new("TextBox")
		keyBox.BackgroundColor3 = theme.Element
		keyBox.Position = UDim2.new(0.5, -140, 0, 85)
		keyBox.Size = UDim2.new(0, 280, 0, 45)
		keyBox.Font = Enum.Font.Gotham
		keyBox.PlaceholderText = "Enter Key..."
		keyBox.Text = ""
		keyBox.TextColor3 = theme.Text
		keyBox.TextSize = 15
		keyBox.Parent = keyFrame
		Instance.new("UICorner", keyBox).CornerRadius = UDim.new(0, 8)
		Instance.new("UIStroke", keyBox).Color = theme.Border
		
		local submitBtn = Instance.new("TextButton")
		submitBtn.BackgroundColor3 = theme.Accent
		submitBtn.Position = UDim2.new(0.5, -120, 0, 155)
		submitBtn.Size = UDim2.new(0, 240, 0, 45)
		submitBtn.Font = Enum.Font.GothamBold
		submitBtn.Text = "Submit"
		submitBtn.TextColor3 = Color3.new(1, 1, 1)
		submitBtn.TextSize = 15
		submitBtn.AutoButtonColor = false
		submitBtn.Parent = keyFrame
		Instance.new("UICorner", submitBtn).CornerRadius = UDim.new(0, 8)
		
		local errorLbl = Instance.new("TextLabel")
		errorLbl.BackgroundTransparency = 1
		errorLbl.Position = UDim2.new(0, 0, 0, 210)
		errorLbl.Size = UDim2.new(1, 0, 0, 25)
		errorLbl.Font = Enum.Font.Gotham
		errorLbl.Text = ""
		errorLbl.TextColor3 = theme.Danger
		errorLbl.TextSize = 13
		errorLbl.Parent = keyFrame
		
		submitBtn.MouseButton1Click:Connect(function()
			if keyBox.Text == key then
				TweenService:Create(keyFrame, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -175, -0.5, -120)}):Play()
				task.wait(0.3)
				keyFrame:Destroy()
			else
				errorLbl.Text = "Invalid Key!"
				task.delay(2, function() errorLbl.Text = "" end)
			end
		end)
	end
	
	return self:BuildMain(main, minimizedButton, theme, themeName, title, scriptName, configFolder, saveName)
end

function AxovocUI:BuildMain(main, minimizedButton, theme, themeName, title, scriptName, configFolder, saveName)
	local titleBar = Instance.new("Frame")
	titleBar.Name = "TitleBar"
	titleBar.BackgroundColor3 = theme.Sidebar
	titleBar.BackgroundTransparency = theme.Transparency
	titleBar.BorderSizePixel = 0
	titleBar.Size = UDim2.new(1, 0, 0, 50)
	titleBar.Parent = main
	
	local titleCorner = Instance.new("UICorner", titleBar)
	titleCorner.CornerRadius = UDim.new(0, 12)
	
	local cornerFix = Instance.new("Frame")
	cornerFix.BackgroundColor3 = theme.Sidebar
	cornerFix.BackgroundTransparency = theme.Transparency
	cornerFix.BorderSizePixel = 0
	cornerFix.Position = UDim2.new(0, 0, 1, -10)
	cornerFix.Size = UDim2.new(1, 0, 0, 10)
	cornerFix.Parent = titleBar
	
	local titleLbl = Instance.new("TextLabel")
	titleLbl.BackgroundTransparency = 1
	titleLbl.Position = UDim2.new(0, 20, 0, 0)
	titleLbl.Size = UDim2.new(0, 250, 1, 0)
	titleLbl.Font = Enum.Font.GothamBold
	titleLbl.Text = title
	titleLbl.TextColor3 = theme.Text
	titleLbl.TextSize = 18
	titleLbl.TextXAlignment = Enum.TextXAlignment.Left
	titleLbl.Parent = titleBar
	
	local btnHolder = Instance.new("Frame")
	btnHolder.BackgroundTransparency = 1
	btnHolder.Position = UDim2.new(1, -100, 0, 12)
	btnHolder.Size = UDim2.new(0, 90, 0, 28)
	btnHolder.Parent = titleBar
	
	local minBtn = Instance.new("TextButton")
	minBtn.BackgroundColor3 = theme.Secondary
	minBtn.Size = UDim2.new(0, 35, 0, 28)
	minBtn.Position = UDim2.new(0, 0, 0, 0)
	minBtn.Font = Enum.Font.GothamBold
	minBtn.Text = "-"
	minBtn.TextColor3 = theme.Text
	minBtn.TextSize = 18
	minBtn.AutoButtonColor = false
	minBtn.Parent = btnHolder
	Instance.new("UICorner", minBtn).CornerRadius = UDim.new(0, 6)
	
	local closeBtn = Instance.new("TextButton")
	closeBtn.BackgroundColor3 = theme.Danger
	closeBtn.Size = UDim2.new(0, 35, 0, 28)
	closeBtn.Position = UDim2.new(0, 45, 0, 0)
	closeBtn.Font = Enum.Font.GothamBold
	closeBtn.Text = "X"
	closeBtn.TextColor3 = Color3.new(1, 1, 1)
	closeBtn.TextSize = 14
	closeBtn.AutoButtonColor = false
	closeBtn.Parent = btnHolder
	Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0, 6)
	
	local sidebar = Instance.new("Frame")
	sidebar.Name = "Sidebar"
	sidebar.BackgroundColor3 = theme.Sidebar
	sidebar.BackgroundTransparency = theme.Transparency
	sidebar.BorderSizePixel = 0
	sidebar.Position = UDim2.new(0, 0, 0, 50)
	sidebar.Size = UDim2.new(0, 200, 1, -50)
	sidebar.Parent = main
	
	local searchBox = Instance.new("TextBox")
	searchBox.BackgroundColor3 = theme.Element
	searchBox.Position = UDim2.new(0, 10, 0, 10)
	searchBox.Size = UDim2.new(1, -20, 0, 35)
	searchBox.Font = Enum.Font.Gotham
	searchBox.PlaceholderText = "Search tabs..."
	searchBox.Text = ""
	searchBox.TextColor3 = theme.Text
	searchBox.TextSize = 13
	searchBox.Parent = sidebar
	Instance.new("UICorner", searchBox).CornerRadius = UDim.new(0, 6)
	Instance.new("UIPadding", searchBox).PaddingLeft = UDim.new(0, 10)
	
	local tabList = Instance.new("ScrollingFrame")
	tabList.BackgroundTransparency = 1
	tabList.Position = UDim2.new(0, 10, 0, 55)
	tabList.Size = UDim2.new(1, -20, 1, -65)
	tabList.ScrollBarThickness = 0
	tabList.AutomaticCanvasSize = Enum.AutomaticSize.Y
	tabList.Parent = sidebar
	
	local listLayout = Instance.new("UIListLayout", tabList)
	listLayout.Padding = UDim.new(0, 5)
	
	local content = Instance.new("Frame")
	content.Name = "Content"
	content.BackgroundTransparency = 1
	content.Position = UDim2.new(0, 200, 0, 50)
	content.Size = UDim2.new(1, -200, 1, -50)
	content.Parent = main
	
	local pageHolder = Instance.new("Frame")
	pageHolder.BackgroundTransparency = 1
	pageHolder.Size = UDim2.new(1, 0, 1, 0)
	pageHolder.Parent = content
	
	local isMinimized = false
	
	minBtn.MouseButton1Click:Connect(function()
		isMinimized = true
		TweenService:Create(main, TweenInfo.new(0.3), {Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(main.Position.X.Scale, main.Position.X.Offset + main.AbsoluteSize.X / 2, main.Position.Y.Scale, main.Position.Y.Offset + main.AbsoluteSize.Y / 2)}):Play()
		task.delay(0.3, function()
			main.Visible = false
			minimizedButton.Visible = true
			minimizedButton.Position = UDim2.new(0, math.clamp(main.AbsolutePosition.X, 20, 1000), 0, math.clamp(main.AbsolutePosition.Y, 20, 500))
			TweenService:Create(minimizedButton, TweenInfo.new(0.3), {Size = UDim2.new(0, 160, 0, 45)}):Play()
		end)
	end)
	
	minimizedButton.MouseButton1Click:Connect(function()
		isMinimized = false
		minimizedButton.Visible = false
		main.Visible = true
		TweenService:Create(main, TweenInfo.new(0.3), {Size = UDim2.new(0, 700, 0, 450), Position = UDim2.new(0.5, -350, 0.5, -225)}):Play()
	end)
	
	closeBtn.MouseButton1Click:Connect(function()
		TweenService:Create(main, TweenInfo.new(0.3), {Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(main.Position.X.Scale, main.Position.X.Offset + main.AbsoluteSize.X / 2, main.Position.Y.Scale, main.Position.Y.Offset + main.AbsoluteSize.Y / 2)}):Play()
		task.delay(0.3, function()
			main:FindFirstAncestorOfClass("ScreenGui"):Destroy()
		end)
	end)
	
	local dragging, dragStart, startPos
	titleBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = main.Position
		end
	end)
	
	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end)
	
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	
	local minimizedDragging, minimizedDragStart, minimizedStartPos
	minimizedButton.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			minimizedDragging = true
			minimizedDragStart = input.Position
			minimizedStartPos = minimizedButton.Position
		end
	end)
	
	UserInputService.InputChanged:Connect(function(input)
		if minimizedDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - minimizedDragStart
			minimizedButton.Position = UDim2.new(minimizedStartPos.X.Scale, minimizedStartPos.X.Offset + delta.X, minimizedStartPos.Y.Scale, minimizedStartPos.Y.Offset + delta.Y)
		end
	end)
	
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			minimizedDragging = false
		end
	end)
	
	local configData = {}
	
	local function saveConfig()
		local json = HttpService:JSONEncode(configData)
		if writefile then
			pcall(function()
				if not isfolder(configFolder) then makefolder(configFolder) end
				writefile(configFolder .. "/" .. saveName .. ".json", json)
			end)
		end
	end
	
	local function loadConfig()
		if readfile then
			local success, data = pcall(function()
				if isfile(configFolder .. "/" .. saveName .. ".json") then
					return readfile(configFolder .. "/" .. saveName .. ".json")
				end
				return nil
			end)
			if success and data then
				configData = HttpService:JSONDecode(data)
				return configData
			end
		end
		return nil
	end
	
	local window = {
		Theme = theme,
		ThemeName = themeName,
		Main = main,
		TabList = tabList,
		PageHolder = pageHolder,
		Tabs = {},
		CurrentTab = nil,
		Elements = {},
		
		SaveConfig = function(self)
			saveConfig()
		end,
		
		LoadConfig = function(self)
			return loadConfig()
		end,
		
		SetConfigValue = function(self, key, value)
			configData[key] = value
			saveConfig()
		end,
		
		GetConfigValue = function(self, key)
			return configData[key]
		end,
		
		ApplyTheme = function(self, newThemeName)
			local newTheme = Themes[newThemeName]
			if not newTheme then return end
			self.Theme = newTheme
			self.ThemeName = newThemeName
			self:SetConfigValue("Theme", newThemeName)
			
			main.BackgroundColor3 = newTheme.Background
			main.BackgroundTransparency = newTheme.Transparency
			titleBar.BackgroundColor3 = newTheme.Sidebar
			titleBar.BackgroundTransparency = newTheme.Transparency
			cornerFix.BackgroundColor3 = newTheme.Sidebar
			cornerFix.BackgroundTransparency = newTheme.Transparency
			sidebar.BackgroundColor3 = newTheme.Sidebar
			sidebar.BackgroundTransparency = newTheme.Transparency
			searchBox.BackgroundColor3 = newTheme.Element
			searchBox.TextColor3 = newTheme.Text
			minimizedButton.BackgroundColor3 = newTheme.Accent
			main:FindFirstChildOfClass("UIStroke").Color = newTheme.Border
			
			for _, tab in ipairs(self.Tabs) do
				tab.Button.BackgroundColor3 = tab.Page.Visible and newTheme.Accent or newTheme.Element
				tab.Button:FindFirstChildOfClass("TextLabel").TextColor3 = newTheme.Text
				if tab.Icon then
					if tab.Icon:IsA("ImageLabel") then
						tab.Icon.ImageColor3 = newTheme.Text
					else
						tab.Icon.TextColor3 = newTheme.Text
					end
				end
			end
			
			for _, element in ipairs(self.Elements) do
				if element.UpdateTheme then
					element:UpdateTheme(newTheme)
				end
			end
		end,
		
		AddTab = function(self, name, icon)
			local tabBtn = Instance.new("Frame")
			tabBtn.BackgroundColor3 = self.Theme.Element
			tabBtn.Size = UDim2.new(1, 0, 0, 40)
			tabBtn.Parent = tabList
			Instance.new("UICorner", tabBtn).CornerRadius = UDim.new(0, 8)
			
			local iconLabel
			if icon then
				if icon:sub(1, 11) == "rbxassetid:" then
					iconLabel = Instance.new("ImageLabel")
					iconLabel.Image = icon
					iconLabel.BackgroundTransparency = 1
					iconLabel.Position = UDim2.new(0, 12, 0.5, -10)
					iconLabel.Size = UDim2.new(0, 20, 0, 20)
					iconLabel.ImageColor3 = self.Theme.Text
					iconLabel.Parent = tabBtn
				else
					iconLabel = Instance.new("TextLabel")
					iconLabel.BackgroundTransparency = 1
					iconLabel.Position = UDim2.new(0, 12, 0, 0)
					iconLabel.Size = UDim2.new(0, 25, 1, 0)
					iconLabel.Font = Enum.Font.Gotham
					iconLabel.Text = icon
					iconLabel.TextColor3 = self.Theme.Text
					iconLabel.TextSize = 16
					iconLabel.Parent = tabBtn
				end
			end
			
			local lbl = Instance.new("TextLabel")
			lbl.BackgroundTransparency = 1
			lbl.Position = icon and UDim2.new(0, 40, 0, 0) or UDim2.new(0, 15, 0, 0)
			lbl.Size = UDim2.new(1, -50, 1, 0)
			lbl.Font = Enum.Font.Gotham
			lbl.Text = name
			lbl.TextColor3 = self.Theme.Text
			lbl.TextSize = 14
			lbl.TextXAlignment = Enum.TextXAlignment.Left
			lbl.Parent = tabBtn
			
			local hit = Instance.new("TextButton")
			hit.BackgroundTransparency = 1
			hit.Size = UDim2.new(1, 0, 1, 0)
			hit.Text = ""
			hit.Parent = tabBtn
			
			local page = Instance.new("ScrollingFrame")
			page.BackgroundTransparency = 1
			page.Size = UDim2.new(1, 0, 1, 0)
			page.ScrollBarThickness = 4
			page.ScrollBarImageColor3 = self.Theme.Accent
			page.Visible = false
