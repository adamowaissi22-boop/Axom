        TabBtn.BackgroundColor3 = Themes[CurrentTheme].Accent
        TabBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    end)

    if #TabContainer:GetChildren() == 1 then
        TabBtn.MouseButton1Click:Fire()
    end

    return TabFrame
end

