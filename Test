local function Notify(msg, dur)
	local notif = Instance.new("Frame")
	notif.BackgroundColor3 = Theme.Sc
	notif.Position = UDim2.new(0.5,-150,0,-80)
	notif.Size = UDim2.new(0,300,0,60)
	notif.ZIndex = 100
	notif.Parent = Gui
	Instance.new("UICorner", notif).CornerRadius = UDim.new(0,8)
	Instance.new("UIStroke", notif).Color = Theme.Ac
	Instance.new("UIStroke", notif).Thickness = 2
	
	local nLbl = Instance.new("TextLabel")
	nLbl.BackgroundTransparency = 1
	nLbl.Size = UDim2.new(1,-20,1,0)
	nLbl.Position = UDim2.new(0,10,0,0)
	nLbl.Font = Enum.Font.Gotham
	nLbl.Text = msg
	nLbl.TextColor3 = Theme.Tx
	nLbl.TextSize = 14
	nLbl.TextWrapped = true
	nLbl.Parent = notif
	
	TweenService:Create(notif, TweenInfo.new(0.3), {Position = UDim2.new(0.5,-150,0,20)}):Play()
	task.delay(dur or 3, function()
		TweenService:Create(notif, TweenInfo.new(0.3), {Position = UDim2.new(0.5,-150,0,-80)}):Play()
		task.wait(0.3)
		notif:Destroy()
	end)
end

