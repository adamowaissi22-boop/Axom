        scriptCode = scriptCode .. "        newPlayer.CharacterAdded:Connect(function() createESP(newPlayer) end)\n"
        scriptCode = scriptCode .. "    end\n"
        scriptCode = scriptCode .. "end)\n"
    end
    
    return scriptCode
end

local function parseAndGenerate(prompt)
    local wants, dontWants = extractIntent(prompt)
    return generateScriptFromIntent(wants, dontWants, prompt)
end

local copyToClipboard = function(text)
    if syn and syn.clipboard then
        syn.clipboard.set(text)
    elseif setclipboard then
        setclipboard(text)
    elseif ClipboardService then
        ClipboardService(text)
    else
        return false
    end
    return true
end

local saveToFile = function(content, filename)
    local success, result = pcall(function()
        if writefile then
            writefile(filename, content)
            return true
        else
            return false
        end
    end)
    return success and result or false
end

