	Instance.new("UIStroke", picker).Color = Theme.Bo
	
	local sat = Instance.new("Frame")
	sat.BackgroundColor3 = Color3.fromHSV(Color3.toHSV(default),1,1)
	sat.Position = UDim2.new(0,10,0,10)
	sat.Size = UDim2.new(0.7,0,0,100)
	sat.Parent = picker
	Instance.new("UICorner", sat).CornerRadius = UDim.new(0,4)
	
	local satGrad = Instance.new("UIGradient", sat)
	satGrad.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, Color3.new(1,1,1)), ColorSequenceKeypoint.new(1, Color3.new(1,0,0))}
	
	local valGrad = Instance.new("UIGradient", sat)
	valGrad.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, Color3.new(0,0,0)), ColorSequenceKeypoint.new(1, Color3.new(0,0,0))}
	valGrad.Rotation = 90
	valGrad.Transparency = NumberSequence.new{NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(1, 1)}
	
	local hue = Instance.new("Frame")
	hue.BackgroundColor3 = Color3.new(1,1,1)
	hue.Position = UDim2.new(0.75,0,0,10)
	hue.Size = UDim2.new(0.2,0,0,100)
	hue.Parent = picker
	Instance.new("UICorner", hue).CornerRadius = UDim.new(0,4)
	
	local hueGrad = Instance.new("UIGradient", hue)
	hueGrad.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0, Color3.fromRGB(255,0,0)),
		ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255,255,0)),
		ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0,255,0)),
		ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0,255,255)),
		ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0,0,255)),
		ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255,0,255)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(255,0,0))
	}
	
	local open = false
	preview.MouseButton1Click:Connect(function()
		open = not open
		picker.Visible = open
		TweenService:Create(holder, TweenInfo.new(0.2), {Size = UDim2.new(1,0,0, open and 190 or 38)}):Play()
	end)
	
	return {Set = function(c) preview.BackgroundColor3 = c; if callback then callback(c) end end}
end

