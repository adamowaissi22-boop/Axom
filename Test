			local fill = Instance.new("Frame")
			fill.BackgroundColor3 = self.Theme.Accent
			fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
			fill.BorderSizePixel = 0
			fill.Parent = track
			Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
			
			local knob = Instance.new("Frame")
			knob.BackgroundColor3 = Color3.new(1, 1, 1)
			knob.Position = UDim2.new((default - min) / (max - min), -9, 0.5, -9)
			knob.Size = UDim2.new(0, 18, 0, 18)
			knob.ZIndex = 2
			knob.Parent = track
			Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
			Instance.new("UIStroke", knob).Color = self.Theme.Accent
			Instance.new("UIStroke", knob).Thickness = 2
			
			table.insert(self.Elements, {
				UpdateTheme = function(_, newTheme)
					holder.BackgroundColor3 = newTheme.Element
					lbl.TextColor3 = newTheme.Text
					valLbl.TextColor3 = newTheme.Accent
					track.BackgroundColor3 = newTheme.Secondary
					fill.BackgroundColor3 = newTheme.Accent
					knob:FindFirstChildOfClass("UIStroke").Color = newTheme.Accent
				end
			})
			
			if configKey then
				local saved = self:GetConfigValue(configKey)
				if saved ~= nil then default = math.clamp(saved, min, max) end
			end
			
			local dragging = false
			local function update(input)
				local pos = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
				local val = math.floor(min + (max - min) * pos)
				knob.Position = UDim2.new(pos, -9, 0.5, -9)
				fill.Size = UDim2.new(pos, 0, 1, 0)
				lbl.Text = text .. ": " .. val
				valLbl.Text = tostring(val)
				if callback then callback(val) end
				if configKey then self:SetConfigValue(configKey, val) end
				return val
			end
			
			track.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = true
					update(input)
				end
			end)
			
			UserInputService.InputChanged:Connect(function(input)
				if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
					update(input)
				end
			end)
			
			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = false
				end
			end)
			
			return {
				Value = function() return math.floor(min + (max - min) * fill.Size.X.Scale) end,
				Set = function(v)
					local pos = math.clamp((v - min) / (max - min), 0, 1)
					TweenService:Create(knob, TweenInfo.new(0.2), {Position = UDim2.new(pos, -9, 0.5, -9)}):Play()
					TweenService:Create(fill, TweenInfo.new(0.2), {Size = UDim2.new(pos, 0, 1, 0)}):Play()
					lbl.Text = text .. ": " .. v
					valLbl.Text = tostring(v)
				end
			}
		end,
		
