
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")

local AxovocUI = {}
local Themes = {
	Default = {Background = Color3.fromRGB(18, 18, 22), Sidebar = Color3.fromRGB(13, 13, 16), Accent = Color3.fromRGB(88, 101, 242), Secondary = Color3.fromRGB(30, 30, 36), Text = Color3.fromRGB(220, 220, 230), TextDark = Color3.fromRGB(140, 140, 150), Border = Color3.fromRGB(35, 35, 42), Hover = Color3.fromRGB(45, 45, 55), Element = Color3.fromRGB(28, 28, 34), Success = Color3.fromRGB(59, 165, 93), Danger = Color3.fromRGB(237, 66, 69)},
	Ocean = {Background = Color3.fromRGB(15, 23, 42), Sidebar = Color3.fromRGB(10, 15, 30), Accent = Color3.fromRGB(56, 189, 248), Secondary = Color3.fromRGB(30, 41, 59), Text = Color3.fromRGB(226, 232, 240), TextDark = Color3.fromRGB(148, 163, 184), Border = Color3.fromRGB(51, 65, 85), Hover = Color3.fromRGB(51, 65, 85), Element = Color3.fromRGB(30, 41, 59), Success = Color3.fromRGB(34, 197, 94), Danger = Color3.fromRGB(239, 68, 68)},
	Midnight = {Background = Color3.fromRGB(12, 10, 18), Sidebar = Color3.fromRGB(8, 6, 12), Accent = Color3.fromRGB(139, 92, 246), Secondary = Color3.fromRGB(30, 27, 40), Text = Color3.fromRGB(237, 233, 254), TextDark = Color3.fromRGB(167, 139, 250), Border = Color3.fromRGB(50, 45, 65), Hover = Color3.fromRGB(60, 55, 80), Element = Color3.fromRGB(35, 30, 50), Success = Color3.fromRGB(52, 211, 153), Danger = Color3.fromRGB(248, 113, 113)},
	Cyber = {Background = Color3.fromRGB(10, 10, 15), Sidebar = Color3.fromRGB(5, 5, 8), Accent = Color3.fromRGB(0, 255, 136), Secondary = Color3.fromRGB(20, 20, 30), Text = Color3.fromRGB(240, 240, 255), TextDark = Color3.fromRGB(150, 150, 170), Border = Color3.fromRGB(0, 255, 200), Hover = Color3.fromRGB(30, 30, 45), Element = Color3.fromRGB(25, 25, 35), Success = Color3.fromRGB(0, 255, 100), Danger = Color3.fromRGB(255, 0, 85)},
	Kawaii = {Background = Color3.fromRGB(30, 25, 35), Sidebar = Color3.fromRGB(25, 20, 30), Accent = Color3.fromRGB(255, 105, 180), Secondary = Color3.fromRGB(45, 35, 50), Text = Color3.fromRGB(255, 230, 240), TextDark = Color3.fromRGB(200, 160, 180), Border = Color3.fromRGB(255, 20, 147), Hover = Color3.fromRGB(60, 45, 65), Element = Color3.fromRGB(50, 40, 55), Success = Color3.fromRGB(255, 182, 193), Danger = Color3.fromRGB(255, 100, 130)}
}

function AxovocUI:CreateWindow(config)
	config = config or {}
	local themeName = config.Theme or "Default"
	local theme = Themes[themeName]
	local title = config.Title or "Axovoc UI"
	local key = config.Key
	local scriptName = config.ScriptName or "Axovoc UI"
	
	local gui = Instance.new("ScreenGui")
	gui.Name = "AxovocUI"
	gui.ResetOnSpawn = false
	gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	gui.Parent = LocalPlayer:WaitForChild("PlayerGui")
	
	local minimizedButton = Instance.new("TextButton")
	minimizedButton.Name = "MinBtn"
	minimizedButton.BackgroundColor3 = theme.Accent
	minimizedButton.BorderSizePixel = 0
	minimizedButton.Position = UDim2.new(0, 20, 0, 20)
	minimizedButton.Size = UDim2.new(0, 140, 0, 40)
	minimizedButton.Font = Enum.Font.GothamBold
	minimizedButton.Text = "Open " .. scriptName
	minimizedButton.TextColor3 = Color3.new(1, 1, 1)
	minimizedButton.TextSize = 14
	minimizedButton.Visible = false
	minimizedButton.AutoButtonColor = false
	minimizedButton.Parent = gui
	Instance.new("UICorner", minimizedButton).CornerRadius = UDim.new(0, 8)
	Instance.new("UIStroke", minimizedButton).Color = theme.Border
	Instance.new("UIStroke", minimizedButton).Thickness = 2
	
	local main = Instance.new("Frame")
	main.Name = "Main"
	main.BackgroundColor3 = theme.Background
	main.BorderSizePixel = 0
	main.Position = UDim2.new(0.5, -350, 0.5, -225)
	main.Size = UDim2.new(0, 700, 0, 450)
	main.Active = true
	main.ClipsDescendants = true
	main.Parent = gui
	Instance.new("UICorner", main).CornerRadius = UDim.new(0, 12)
	Instance.new("UIStroke", main).Color = theme.Border
	
	local resizeHandle = Instance.new("TextButton")
	resizeHandle.Name = "Resize"
	resizeHandle.BackgroundColor3 = theme.Accent
	resizeHandle.BackgroundTransparency = 0.5
	resizeHandle.BorderSizePixel = 0
	resizeHandle.Position = UDim2.new(1, -20, 1, -20)
	resizeHandle.Size = UDim2.new(0, 20, 0, 20)
	resizeHandle.Font = Enum.Font.Gotham
	resizeHandle.Text = "↘"
	resizeHandle.TextColor3 = theme.Text
	resizeHandle.TextSize = 14
	resizeHandle.AutoButtonColor = false
	resizeHandle.Parent = main
	Instance.new("UICorner", resizeHandle).CornerRadius = UDim.new(0, 6)
	
	local minWidth, minHeight = 500, 300
	local maxWidth, maxHeight = 1200, 800
	
	local resizing = false
	resizeHandle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			resizing = true
		end
	end)
	
	UserInputService.InputChanged:Connect(function(input)
		if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local newWidth = math.clamp(input.Position.X - main.AbsolutePosition.X, minWidth, maxWidth)
			local newHeight = math.clamp(input.Position.Y - main.AbsolutePosition.Y, minHeight, maxHeight)
			main.Size = UDim2.new(0, newWidth, 0, newHeight)
		end
	end)
	
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			resizing = false
		end
	end)
	
	if key then
		local keyFrame = Instance.new("Frame")
		keyFrame.BackgroundColor3 = theme.Background
		keyFrame.BorderSizePixel = 0
		keyFrame.Position = UDim2.new(0.5, -150, 0.5, -100)
		keyFrame.Size = UDim2.new(0, 300, 0, 200)
		keyFrame.Parent = gui
		Instance.new("UICorner", keyFrame).CornerRadius = UDim.new(0, 12)
		Instance.new("UIStroke", keyFrame).Color = theme.Border
		
		local keyTitle = Instance.new("TextLabel")
		keyTitle.BackgroundTransparency = 1
		keyTitle.Position = UDim2.new(0, 0, 0, 20)
		keyTitle.Size = UDim2.new(1, 0, 0, 30)
		keyTitle.Font = Enum.Font.GothamBold
		keyTitle.Text = "🔐 Key System"
		keyTitle.TextColor3 = theme.Text
		keyTitle.TextSize = 20
		keyTitle.Parent = keyFrame
		
		local keyBox = Instance.new("TextBox")
		keyBox.BackgroundColor3 = theme.Element
		keyBox.Position = UDim2.new(0.5, -120, 0, 70)
		keyBox.Size = UDim2.new(0, 240, 0, 40)
		keyBox.Font = Enum.Font.Gotham
		keyBox.PlaceholderText = "Enter Key..."
		keyBox.Text = ""
		keyBox.TextColor3 = theme.Text
		keyBox.TextSize = 14
		keyBox.Parent = keyFrame
		Instance.new("UICorner", keyBox).CornerRadius = UDim.new(0, 8)
		Instance.new("UIStroke", keyBox).Color = theme.Border
		
		local submitBtn = Instance.new("TextButton")
		submitBtn.BackgroundColor3 = theme.Accent
		submitBtn.Position = UDim2.new(0.5, -100, 0, 130)
		submitBtn.Size = UDim2.new(0, 200, 0, 40)
		submitBtn.Font = Enum.Font.GothamBold
		submitBtn.Text = "Submit"
		submitBtn.TextColor3 = Color3.new(1, 1, 1)
		submitBtn.TextSize = 14
		submitBtn.AutoButtonColor = false
		submitBtn.Parent = keyFrame
		Instance.new("UICorner", submitBtn).CornerRadius = UDim.new(0, 8)
		
		local errorLbl = Instance.new("TextLabel")
		errorLbl.BackgroundTransparency = 1
		errorLbl.Position = UDim2.new(0, 0, 0, 180)
		errorLbl.Size = UDim2.new(1, 0, 0, 20)
		errorLbl.Font = Enum.Font.Gotham
		errorLbl.Text = ""
		errorLbl.TextColor3 = theme.Danger
		errorLbl.TextSize = 12
		errorLbl.Parent = keyFrame
		
		submitBtn.MouseButton1Click:Connect(function()
			if keyBox.Text == key then
				TweenService:Create(keyFrame, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -150, -0.5, -100)}):Play()
				task.wait(0.3)
				keyFrame:Destroy()
			else
				errorLbl.Text = "Invalid Key!"
				task.delay(2, function() errorLbl.Text = "" end)
			end
		end)
	end
	
	return self:BuildMain(main, minimizedButton, theme, themeName, title, scriptName)
end

function AxovocUI:BuildMain(main, minimizedButton, theme, themeName, title, scriptName)
	local titleBar = Instance.new("Frame")
	titleBar.Name = "TitleBar"
	titleBar.BackgroundColor3 = theme.Sidebar
	titleBar.BorderSizePixel = 0
	titleBar.Size = UDim2.new(1, 0, 0, 45)
	titleBar.Parent = main
	Instance.new("UICorner", titleBar).CornerRadius = UDim.new(0, 12)
	
	local cornerFix = Instance.new("Frame")
	cornerFix.BackgroundColor3 = theme.Sidebar
	cornerFix.BorderSizePixel = 0
	cornerFix.Position = UDim2.new(0, 0, 1, -10)
	cornerFix.Size = UDim2.new(1, 0, 0, 10)
	cornerFix.Parent = titleBar
	
	local titleLbl = Instance.new("TextLabel")
	titleLbl.BackgroundTransparency = 1
	titleLbl.Position = UDim2.new(0, 20, 0, 0)
	titleLbl.Size = UDim2.new(0, 200, 1, 0)
	titleLbl.Font = Enum.Font.GothamBold
	titleLbl.Text = title
	titleLbl.TextColor3 = theme.Text
	titleLbl.TextSize = 18
	titleLbl.TextXAlignment = Enum.TextXAlignment.Left
	titleLbl.Parent = titleBar
	
	local btnHolder = Instance.new("Frame")
	btnHolder.BackgroundTransparency = 1
	btnHolder.Position = UDim2.new(1, -90, 0, 10)
	btnHolder.Size = UDim2.new(0, 80, 0, 25)
	btnHolder.Parent = titleBar
	
	local minBtn = Instance.new("TextButton")
	minBtn.BackgroundColor3 = theme.Secondary
	minBtn.Size = UDim2.new(0, 30, 0, 25)
	minBtn.Position = UDim2.new(0, 0, 0, 0)
	minBtn.Font = Enum.Font.GothamBold
	minBtn.Text = "−"
	minBtn.TextColor3 = theme.Text
	minBtn.TextSize = 16
	minBtn.AutoButtonColor = false
	minBtn.Parent = btnHolder
	Instance.new("UICorner", minBtn).CornerRadius = UDim.new(0, 6)
	
	local closeBtn = Instance.new("TextButton")
	closeBtn.BackgroundColor3 = theme.Danger
	closeBtn.Size = UDim2.new(0, 30, 0, 25)
	closeBtn.Position = UDim2.new(0, 40, 0, 0)
	closeBtn.Font = Enum.Font.GothamBold
	closeBtn.Text = "×"
	closeBtn.TextColor3 = Color3.new(1, 1, 1)
	closeBtn.TextSize = 16
	closeBtn.AutoButtonColor = false
	closeBtn.Parent = btnHolder
	Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0, 6)
	
	local sidebar = Instance.new("Frame")
	sidebar.Name = "Sidebar"
	sidebar.BackgroundColor3 = theme.Sidebar
	sidebar.BorderSizePixel = 0
	sidebar.Position = UDim2.new(0, 0, 0, 45)
	sidebar.Size = UDim2.new(0, 200, 1, -45)
	sidebar.Parent = main
	
	local tabList = Instance.new("ScrollingFrame")
	tabList.BackgroundTransparency = 1
	tabList.Position = UDim2.new(0, 10, 0, 10)
	tabList.Size = UDim2.new(1, -20, 1, -20)
	tabList.ScrollBarThickness = 0
	tabList.AutomaticCanvasSize = Enum.AutomaticSize.Y
	tabList.Parent = sidebar
	
	local listLayout = Instance.new("UIListLayout", tabList)
	listLayout.Padding = UDim.new(0, 4)
	
	local content = Instance.new("Frame")
	content.Name = "Content"
	content.BackgroundTransparency = 1
	content.Position = UDim2.new(0, 200, 0, 45)
	content.Size = UDim2.new(1, -200, 1, -45)
	content.Parent = main
	
	local pageHolder = Instance.new("Frame")
	pageHolder.BackgroundTransparency = 1
	pageHolder.Size = UDim2.new(1, 0, 1, 0)
	pageHolder.Parent = content
	
	local isMinimized = false
	
	minBtn.MouseButton1Click:Connect(function()
		isMinimized = true
		TweenService:Create(main, TweenInfo.new(0.3), {Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(main.Position.X.Scale, main.Position.X.Offset + main.AbsoluteSize.X / 2, main.Position.Y.Scale, main.Position.Y.Offset + main.AbsoluteSize.Y / 2)}):Play()
		task.delay(0.3, function()
			main.Visible = false
			minimizedButton.Visible = true
			minimizedButton.Position = UDim2.new(0, math.clamp(main.AbsolutePosition.X, 20, 1000), 0, math.clamp(main.AbsolutePosition.Y, 20, 500))
			TweenService:Create(minimizedButton, TweenInfo.new(0.3), {Size = UDim2.new(0, 140, 0, 40)}):Play()
		end)
	end)
	
	minimizedButton.MouseButton1Click:Connect(function()
		isMinimized = false
		minimizedButton.Visible = false
		main.Visible = true
		TweenService:Create(main, TweenInfo.new(0.3), {Size = UDim2.new(0, 700, 0, 450), Position = UDim2.new(0.5, -350, 0.5, -225)}):Play()
	end)
	
	closeBtn.MouseButton1Click:Connect(function()
		TweenService:Create(main, TweenInfo.new(0.3), {Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(main.Position.X.Scale, main.Position.X.Offset + main.AbsoluteSize.X / 2, main.Position.Y.Scale, main.Position.Y.Offset + main.AbsoluteSize.Y / 2)}):Play()
		task.delay(0.3, function()
			main:FindFirstAncestorOfClass("ScreenGui"):Destroy()
		end)
	end)
	
	local dragging, dragStart, startPos
	titleBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = main.Position
		end
	end)
	
	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end)
	
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	
	local minimizedDragging, minimizedDragStart, minimizedStartPos
	minimizedButton.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			minimizedDragging = true
			minimizedDragStart = input.Position
			minimizedStartPos = minimizedButton.Position
		end
	end)
	
	UserInputService.InputChanged:Connect(function(input)
		if minimizedDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - minimizedDragStart
			minimizedButton.Position = UDim2.new(minimizedStartPos.X.Scale, minimizedStartPos.X.Offset + delta.X, minimizedStartPos.Y.Scale, minimizedStartPos.Y.Offset + delta.Y)
		end
	end)
	
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			minimizedDragging = false
		end
	end)
	
	local window = {
		Theme = theme,
		ThemeName = themeName,
		Main = main,
		TabList = tabList,
		PageHolder = pageHolder,
		Tabs = {},
		CurrentTab = nil,
		Elements = {},
		
		ApplyTheme = function(self, newThemeName)
			local newTheme = Themes[newThemeName]
			if not newTheme then return end
			self.Theme = newTheme
			self.ThemeName = newThemeName
			
			main.BackgroundColor3 = newTheme.Background
			titleBar.BackgroundColor3 = newTheme.Sidebar
			cornerFix.BackgroundColor3 = newTheme.Sidebar
			sidebar.BackgroundColor3 = newTheme.Sidebar
			minimizedButton.BackgroundColor3 = newTheme.Accent
			
			for _, tab in ipairs(self.Tabs) do
				if tab.Page.Visible then
					tab.Button.BackgroundColor3 = newTheme.Accent
				else
					tab.Button.BackgroundColor3 = newTheme.Element
				end
				tab.Button.TextColor3 = newTheme.Text
			end
			
			for _, element in ipairs(self.Elements) do
				if element.UpdateTheme then
					element:UpdateTheme(newTheme)
				end
			end
		end,
		
		AddTab = function(self, name, icon)
			local tabBtn = Instance.new("TextButton")
			tabBtn.BackgroundColor3 = self.Theme.Element
			tabBtn.Size = UDim2.new(1, 0, 0, 38)
			tabBtn.Font = Enum.Font.Gotham
			tabBtn.Text = (icon or "📄") .. "  " .. name
			tabBtn.TextColor3 = self.Theme.Text
			tabBtn.TextSize = 14
			tabBtn.TextXAlignment = Enum.TextXAlignment.Left
			tabBtn.AutoButtonColor = false
			tabBtn.Parent = tabList
			Instance.new("UICorner", tabBtn).CornerRadius = UDim.new(0, 8)
			Instance.new("UIPadding", tabBtn).PaddingLeft = UDim.new(0, 12)
			
			local page = Instance.new("ScrollingFrame")
			page.BackgroundTransparency = 1
			page.Size = UDim2.new(1, 0, 1, 0)
			page.ScrollBarThickness = 4
			page.ScrollBarImageColor3 = self.Theme.Accent
			page.Visible = false
			page.AutomaticCanvasSize = Enum.AutomaticSize.Y
			page.Parent = pageHolder
			Instance.new("UIPadding", page).PaddingTop = UDim.new(0, 15)
			Instance.new("UIPadding", page).PaddingLeft = UDim.new(0, 15)
			Instance.new("UIPadding", page).PaddingRight = UDim.new(0, 15)
			Instance.new("UIPadding", page).PaddingBottom = UDim.new(0, 15)
			
			local pageLayout = Instance.new("UIListLayout", page)
			pageLayout.Padding = UDim.new(0, 10)
			pageLayout.SortOrder = Enum.SortOrder.LayoutOrder
			
			table.insert(self.Tabs, {Button = tabBtn, Page = page, Name = name})
			
			tabBtn.MouseButton1Click:Connect(function()
				for _, t in ipairs(self.Tabs) do
					t.Page.Visible = false
					TweenService:Create(t.Button, TweenInfo.new(0.2), {BackgroundColor3 = self.Theme.Element}):Play()
				end
				page.Visible = true
				TweenService:Create(tabBtn, TweenInfo.new(0.2), {BackgroundColor3 = self.Theme.Accent}):Play()
				self.CurrentTab = page
			end)
			
			if #self.Tabs == 1 then
				page.Visible = true
				tabBtn.BackgroundColor3 = self.Theme.Accent
				self.CurrentTab = page
			end
			
			return page
		end,
		
		AddSection = function(self, parent, text)
			local section = Instance.new("TextLabel")
			section.BackgroundTransparency = 1
			section.Size = UDim2.new(1, 0, 0, 25)
			section.Font = Enum.Font.GothamBold
			section.Text = text
			section.TextColor3 = self.Theme.Accent
			section.TextSize = 14
			section.TextXAlignment = Enum.TextXAlignment.Left
			section.Parent = parent
			section.LayoutOrder = #parent:GetChildren()
			return section
		end,
		
		AddButton = function(self, parent, text, callback)
			local btn = Instance.new("TextButton")
			btn.BackgroundColor3 = self.Theme.Element
			btn.Size = UDim2.new(1, 0, 0, 40)
			btn.Font = Enum.Font.Gotham
			btn.Text = text
			btn.TextColor3 = self.Theme.Text
			btn.TextSize = 14
			btn.AutoButtonColor = false
			btn.Parent = parent
			btn.LayoutOrder = #parent:GetChildren()
			Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
			
			table.insert(self.Elements, {
				UpdateTheme = function(_, newTheme)
					btn.BackgroundColor3 = newTheme.Element
					btn.TextColor3 = newTheme.Text
				end
			})
			
			btn.MouseEnter:Connect(function()
				TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = self.Theme.Hover}):Play()
			end)
			
			btn.MouseLeave:Connect(function()
				TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = self.Theme.Element}):Play()
			end)
			
			btn.MouseButton1Click:Connect(function()
				TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = self.Theme.Accent}):Play()
				task.delay(0.1, function()
					TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = self.Theme.Hover}):Play()
				end)
				if callback then callback() end
			end)
			
			return btn
		end,
		
		AddToggle = function(self, parent, text, default, callback)
			local holder = Instance.new("Frame")
			holder.BackgroundColor3 = self.Theme.Element
			holder.Size = UDim2.new(1, 0, 0, 45)
			holder.Parent = parent
			holder.LayoutOrder = #parent:GetChildren()
			Instance.new("UICorner", holder).CornerRadius = UDim.new(0, 8)
			
			local lbl = Instance.new("TextLabel")
			lbl.BackgroundTransparency = 1
			lbl.Position = UDim2.new(0, 15, 0, 0)
			lbl.Size = UDim2.new(0.7, 0, 1, 0)
			lbl.Font = Enum.Font.Gotham
			lbl.Text = text
			lbl.TextColor3 = self.Theme.Text
			lbl.TextSize = 14
			lbl.TextXAlignment = Enum.TextXAlignment.Left
			lbl.Parent = holder
			
			local toggle = Instance.new("Frame")
			toggle.BackgroundColor3 = default and self.Theme.Accent or self.Theme.Secondary
			toggle.Position = UDim2.new(1, -60, 0.5, -12)
			toggle.Size = UDim2.new(0, 50, 0, 24)
			toggle.ClipsDescendants = true
			toggle.Parent = holder
			Instance.new("UICorner", toggle).CornerRadius = UDim.new(1, 0)
			
			local knob = Instance.new("Frame")
			knob.BackgroundColor3 = Color3.new(1, 1, 1)
			knob.Position = default and UDim2.new(1, -22, 0, 2) or UDim2.new(0, 2, 0, 2)
			knob.Size = UDim2.new(0, 20, 0, 20)
			knob.Parent = toggle
			Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
			
			table.insert(self.Elements, {
				UpdateTheme = function(_, newTheme)
					holder.BackgroundColor3 = newTheme.Element
					lbl.TextColor3 = newTheme.Text
					if enabled then
						toggle.BackgroundColor3 = newTheme.Accent
					else
						toggle.BackgroundColor3 = newTheme.Secondary
					end
				end
			})
			
			local enabled = default
			local function update()
				enabled = not enabled
				TweenService:Create(toggle, TweenInfo.new(0.2), {BackgroundColor3 = enabled and self.Theme.Accent or self.Theme.Secondary}):Play()
				TweenService:Create(knob, TweenInfo.new(0.2), {Position = enabled and UDim2.new(1, -22, 0, 2) or UDim2.new(0, 2, 0, 2)}):Play()
				if callback then callback(enabled) end
			end
			
			local hit = Instance.new("TextButton")
			hit.BackgroundTransparency = 1
			hit.Size = UDim2.new(1, 0, 1, 0)
			hit.Text = ""
			hit.Parent = holder
			hit.MouseButton1Click:Connect(update)
			
			return {
				Value = function() return enabled end,
				Set = function(v) 
