local function createMainUI()
    languageFrame.Visible = false
    
    local Window = Apoto:CreateWindow({
        Name = "Open Arab City Script",
        Icon = "rbxassetid://18820555586",
        AccentColor3 = Color3.fromRGB(100, 100, 200)
    })
    
    local MainTab = Window:CreateTab({
        Name = "Main | القسم الاساسي",
        Icon = "rbxassetid://7733800044"
    })
    
    local CreditsTab = Window:CreateTab({
        Name = "Credits",
        Icon = "rbxassetid://7733800044"
    })
    
    MainTab:CreateLabel({
        Text = "Outfits | الملابس",
        TextSize = 18,
        TextColor = Color3.fromRGB(200, 200, 255)
    })
    
    MainTab:CreateButton({
        Text = "Become A Frog | أصبح ضفدع",
        Callback = function()
            ReplicatedStorage:WaitForChild("ApplyOutfitRequest"):FireServer("1774369027_4327")
        end
    })
    
    MainTab:CreateButton({
        Text = "Become a Car | اصبح سيارة",
        Callback = function()
            ReplicatedStorage:WaitForChild("ApplyOutfitRequest"):FireServer("1774355060_9283")
        end
    })
    
    MainTab:CreateButton({
        Text = "Become Axom | أصبح Axom",
        Callback = function()
            ReplicatedStorage:WaitForChild("ApplyOutfitRequest"):FireServer("1774369552_4728")
        end
    })
    
    MainTab:CreateLabel({
        Text = "Player Tools | أدوات اللاعب",
        TextSize = 18,
        TextColor = Color3.fromRGB(200, 200, 255)
    })
    
    local selectedPlayer = nil
    
    local playerSelector = MainTab:CreatePlayerSelector({
        Text = "Choose Player | اختار اللاعب",
        Callback = function(player)
            selectedPlayer = player
        end
    })
    
    MainTab:CreateButton({
        Text = "Display owned GamePasses",
        Callback = function()
            if not selectedPlayer then
                Window:CreateNotification({
                    Title = "Error",
                    Description = "Please select a player first",
                    Duration = 3
                })
                return
            end
            local owned = selectedPlayer:FindFirstChild("OwnedGamepasses")
            if owned then
                local passes = {}
                for _, child in ipairs(owned:GetChildren()) do
                    table.insert(passes, child.Name)
                end
                local text = #passes > 0 and table.concat(passes, "\n") or "No GamePasses found"
                Window:CreateNotification({
                    Title = "Owned GamePasses",
                    Description = text,
                    Duration = 5
                })
            else
                Window:CreateNotification({
                    Title = "Error",
                    Description = "No OwnedGamepasses found",
                    Duration = 3
                })
            end
        end
    })
    
    MainTab:CreateButton({
        Text = "Display Cash Amount",
        Callback = function()
            if not selectedPlayer then
                Window:CreateNotification({
                    Title = "Error",
                    Description = "Please select a player first",
                    Duration = 3
                })
                return
            end
            local cashDisplay = selectedPlayer:FindFirstChild("PlayerGui")
            if cashDisplay then
                local cashFrame = cashDisplay:FindFirstChild("CashDisplay")
                if cashFrame then
                    local frame = cashFrame:FindFirstChild("Frame")
                    if frame then
                        local textLabel = frame:FindFirstChild("TextLabel")
                        if textLabel then
                            Window:CreateNotification({
                                Title = "Cash Amount",
                                Description = textLabel.Text,
                                Duration = 5
                            })
                        else
                            Window:CreateNotification({
                                Title = "Error",
                                Description = "TextLabel not found",
                                Duration = 3
                            })
                        end
                    else
                        Window:CreateNotification({
                            Title = "Error",
                            Description = "Frame not found",
                            Duration = 3
                        })
                    end
                else
                    Window:CreateNotification({
                        Title = "Error",
                        Description = "CashDisplay not found",
                        Duration = 3
                    })
                end
            else
                Window:CreateNotification({
                    Title = "Error",
                    Description = "PlayerGui not found",
                    Duration = 3
                })
            end
        end
    })
    
    MainTab:CreateLabel({
        Text = "Spam Tool | أداة السبام",
        TextSize = 18,
        TextColor = Color3.fromRGB(200, 200, 255)
    })
    
    local spamTextBox = MainTab:CreateBox({
        Text = "Text To Spam | النص المراد سبامه",
        Placeholder = "Enter text here...",
        Default = ""
    })
    
    local spamDelayBox = MainTab:CreateBox({
        Text = "Spam Delay/Cooldown | مدة الانتظار",
        Placeholder = "1",
        Default = "1"
    })
    
    local function stopSpam()
        if spamCoroutine then
            coroutine.close(spamCoroutine)
            spamCoroutine = nil
        end
        spamRunning = false
    end
    
    local function startSpam()
        local message = spamTextBox:Get()
        local delay = tonumber(spamDelayBox:Get())
        if not message or message == "" then
            Window:CreateNotification({
                Title = "Error",
                Description = "Please enter text to spam",
                Duration = 3
            })
            return
        end
        if not delay or delay < 0.1 then
            delay = 1
        end
        spamRunning = true
        spamCoroutine = coroutine.create(function()
            while spamRunning do
                local args = {". "}
                ReplicatedStorage:WaitForChild("44_O_S"):FireServer(unpack(args))
                task.wait(delay)
            end
        end)
        coroutine.resume(spamCoroutine)
    end
    
    MainTab:CreateToggle({
        Text = "Spam | سبام",
        Default = false,
        Callback = function(value)
            if value then
                startSpam()
            else
                stopSpam()
            end
        end
    })
    
    MainTab:CreateLabel({
        Text = "Outfits Tools | أدوات الملابس",
        TextSize = 18,
        TextColor = Color3.fromRGB(200, 200, 255)
    })
    
    local selectedOutfitPlayer = nil
    
    local outfitPlayerSelector = MainTab:CreatePlayerSelector({
        Text = "Choose Player | اختار اللاعب",
        Callback = function(player)
            selectedOutfitPlayer = player
        end
    })
    
    MainTab:CreateButton({
        Text = "Display Outfits | استخرج الملابس",
        Callback = function()
            if not selectedOutfitPlayer then
                Window:CreateNotification({
                    Title = "Error",
                    Description = "Please select a player first",
                    Duration = 3
                })
                return
            end
            local playerGui = selectedOutfitPlayer:FindFirstChild("PlayerGui")
            if playerGui then
                local outfitGui = playerGui:FindFirstChild("OutfitGuiModernFix")
                if outfitGui then
                    local frame = outfitGui:FindFirstChild("Frame")
                    if frame then
                        frame.Visible = true
                        ReplicatedStorage:WaitForChild("RequestOutfitsList"):FireServer()
                        Window:CreateNotification({
                            Title = "Success",
                            Description = "Outfit GUI opened for " .. selectedOutfitPlayer.Name,
                            Duration = 3
                        })
                    else
                        Window:CreateNotification({
                            Title = "Error",
                            Description = "Frame not found in OutfitGuiModernFix",
                            Duration = 3
                        })
                    end
                else
                    local newOutfitGui = Instance.new("ScreenGui")
                    newOutfitGui.Name = "OutfitGuiModernFix"
                    newOutfitGui.ResetOnSpawn = false
                    newOutfitGui.Parent = playerGui
                    local newFrame = Instance.new("Frame")
                    newFrame.Size = UDim2.new(0, 400, 0, 520)
                    newFrame.Position = UDim2.new(0.5, -200, 0.5, -260)
                    newFrame.AnchorPoint = Vector2.new(0.5, 0.5)
                    newFrame.BackgroundColor3 = Color3.fromRGB(28, 28, 28)
                    newFrame.BorderSizePixel = 0
                    newFrame.Visible = true
                    newFrame.Parent = newOutfitGui
                    ReplicatedStorage:WaitForChild("RequestOutfitsList"):FireServer()
                    Window:CreateNotification({
                        Title = "Success",
                        Description = "Created Outfit GUI for " .. selectedOutfitPlayer.Name,
                        Duration = 3
                    })
                end
            else
                Window:CreateNotification({
                    Title = "Error",
                    Description = "PlayerGui not found",
                    Duration = 3
                })
            end
        end
    })
    
    CreditsTab:CreateLabel({
        Text = "This Script Was Made by Axom.\nتم صنع هذا السكربت من قِبَل Axom",
        TextSize = 16,
        TextColor = Color3.fromRGB(255, 255, 255)
    })
    
    CreditsTab:CreateButton({
        Text = "Discord - ديسكورد",
        Callback = function()
            setclipboard("https://discord.gg/FgR3MXqZy9")
            Window:CreateNotification({
                Title = "Copied!",
                Description = "Discord link copied to clipboard",
                Duration = 2
            })
        end
    })
    
    CreditsTab:CreateButton({
        Text = "Youtube - يوتيوب",
        Callback = function()
            setclipboard("https://youtube.com/@axos0022")
            Window:CreateNotification({
                Title = "Copied!",
                Description = "Youtube link copied to clipboard",
                Duration = 2
            })
        end
    })
    
    CreditsTab:CreateButton({
        Text = "Tiktok - تيكتوك",
        Callback = function()
            setclipboard("https://tiktok.com/@axos002")
            Window:CreateNotification({
                Title = "Copied!",
                Description = "Tiktok link copied to clipboard",
                Duration = 2
            })
        end
    })
    
    Window:CreateNotification({
        Title = "Loaded",
        Description = "Script loaded successfully!",
        Duration = 3
    })
end

englishButton.MouseButton1Click:Connect(function()
    createMainUI()
end)

arabicButton.MouseButton1Click:Connect(function()
    createMainUI()
end)
