		TweenService:Create(bg, TweenInfo.new(0.2), {BackgroundColor3 = enabled and Theme.Ac or Theme.El}):Play()
		TweenService:Create(knob, TweenInfo.new(0.2), {Position = enabled and UDim2.new(1,-26,0,2) or UDim2.new(0,2,0,2)}):Play()
		if callback then callback(enabled) end
	end
	
	local hit = Instance.new("TextButton", holder)
	hit.BackgroundTransparency = 1
	hit.Size = UDim2.new(1,0,1,0)
	hit.Text = ""
	hit.MouseButton1Click:Connect(update)
	
	return {Get = function() return enabled end, Set = function(v) if v ~= enabled then update() end end}
end

local function Slider(parent, text, min, max, default, callback)
	local holder = Instance.new("Frame")
	holder.BackgroundTransparency = 1
	holder.Size = UDim2.new(1,0,0,55)
	holder.Parent = parent
	
	local lbl = Instance.new("TextLabel")
	lbl.BackgroundTransparency = 1
	lbl.Size = UDim2.new(1,0,0,20)
	lbl.Font = Enum.Font.Gotham
	lbl.Text = text .. ": " .. default
	lbl.TextColor3 = Theme.Tx
	lbl.TextSize = 13
	lbl.TextXAlignment = Enum.TextXAlignment.Left
	lbl.Parent = holder
	
	local track = Instance.new("Frame")
	track.BackgroundColor3 = Theme.El
	track.Position = UDim2.new(0,0,0,32)
	track.Size = UDim2.new(1,0,0,8)
	track.Parent = holder
	Instance.new("UICorner", track).CornerRadius = UDim.new(0,4)
	
	local fill = Instance.new("Frame")
	fill.BackgroundColor3 = Theme.Ac
	fill.Size = UDim2.new((default-min)/(max-min),0,1,0)
	fill.BorderSizePixel = 0
	fill.Parent = track
	Instance.new("UICorner", fill).CornerRadius = UDim.new(0,4)
	
	local knob = Instance.new("Frame")
	knob.BackgroundColor3 = Color3.new(1,1,1)
	knob.Position = UDim2.new((default-min)/(max-min),-8,0.5,-8)
	knob.Size = UDim2.new(0,16,0,16)
	knob.ZIndex = 2
	knob.Parent = track
	Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)
	
	local dragging = false
	local function update(input)
		local pos = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
		local val = math.floor(min + (max - min) * pos)
		knob.Position = UDim2.new(pos,-8,0.5,-8)
		fill.Size = UDim2.new(pos,0,1,0)
		lbl.Text = text .. ": " .. val
		if callback then callback(val) end
	end
	
	track.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			update(input)
		end
	end)
	
	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			update(input)
		end
	end)
	
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	
	return {Get = function() return math.floor(min + (max - min) * fill.Size.X.Scale) end}
end

