    TabFrame.Size = UDim2.new(0.95, 0, 0, 0)
    TabFrame.BackgroundColor3 = Themes[CurrentTheme].Bg
    TabFrame.BorderSizePixel = 0
    TabFrame.Visible = false
    TabFrame.Parent = ContentFrame

    local TabLayoutInner = Instance.new("UIListLayout")
    TabLayoutInner.Padding = UDim.new(0, 10)
    TabLayoutInner.HorizontalAlignment = Enum.HorizontalAlignment.Center
    TabLayoutInner.Parent = TabFrame

    local UIPadding = Instance.new("UIPadding")
    UIPadding.PaddingBottom = UDim.new(0, 10)
    UIPadding.PaddingTop = UDim.new(0, 10)
    UIPadding.Parent = TabFrame

    TabBtn.MouseButton1Click:Connect(function()
        for _, child in pairs(ContentFrame:GetChildren()) do
            if child:IsA("Frame") then child.Visible = false end
        end
