local function ApplyTheme()
    local T = Themes[CurrentTheme]
    Main.BackgroundColor3 = T.Bg
    Top.BackgroundColor3 = T.Top
    Title.TextColor3 = T.Text
    MainStroke.Color = T.Stroke
    Content.BackgroundColor3 = T.Bg
    Content.ScrollBarImageColor3 = T.Accent
    for _, obj in ipairs(Main:GetDescendants()) do
        if obj:IsA("TextLabel") or obj:IsA("TextBox") then obj.TextColor3 = T.Text end
        if obj:IsA("Frame") and obj ~= Main and obj ~= Top and obj ~= TabBar then
            if obj.BackgroundTransparency == 0 then obj.BackgroundColor3 = T.Bg end
        end
        if obj:IsA("UIStroke") then obj.Color = T.Stroke end
    endend
