local function PlayerSelector(parent, callback)
	local holder = Instance.new("Frame")
	holder.BackgroundTransparency = 1
	holder.Size = UDim2.new(1,0,0,180)
	holder.Parent = parent
	
	local searchBox = Search(holder, "Search players...", function() end)
	searchBox.Size = UDim2.new(1,0,0,35)
	searchBox.Position = UDim2.new(0,0,0,0)
	
	local scroll = Instance.new("ScrollingFrame")
	scroll.BackgroundColor3 = Theme.El
	scroll.Position = UDim2.new(0,0,0,40)
	scroll.Size = UDim2.new(1,0,1,-40)
	scroll.ScrollBarThickness = 4
	scroll.ScrollBarImageColor3 = Theme.Ac
	scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
	scroll.Parent = holder
	Instance.new("UICorner", scroll).CornerRadius = UDim.new(0,6)
	Instance.new("UIListLayout", scroll).Padding = UDim.new(0,4)
	Instance.new("UIPadding", scroll).PaddingTop = UDim.new(0,5)
	Instance.new("UIPadding", scroll).PaddingLeft = UDim.new(0,5)
	Instance.new("UIPadding", scroll).PaddingRight = UDim.new(0,5)
	Instance.new("UIPadding", scroll).PaddingBottom = UDim.new(0,5)
	
	local function refresh(query)
		for _,c in ipairs(scroll:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
		for _,plr in ipairs(Players:GetPlayers()) do
			if not query or plr.Name:lower():find(query:lower()) then
				local btn = Instance.new("TextButton")
				btn.BackgroundColor3 = Theme.Sc
				btn.Size = UDim2.new(1,0,0,32)
				btn.Font = Enum.Font.Gotham
				btn.Text = plr.Name
				btn.TextColor3 = Theme.Tx
				btn.TextSize = 12
				btn.AutoButtonColor = false
				btn.Parent = scroll
				Instance.new("UICorner", btn).CornerRadius = UDim.new(0,4)
				btn.MouseButton1Click:Connect(function() if callback then callback(plr) end end)
			end
		end
	end
	
	searchBox:GetPropertyChangedSignal("Text"):Connect(function() refresh(searchBox.Text) end)
	refresh()
	
	Players.PlayerAdded:Connect(refresh)
	Players.PlayerRemoving:Connect(refresh)
end

