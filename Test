local function ApplyTheme()
    local T = Themes[CurrentTheme]
    MainFrame.BackgroundColor3 = T.Bg
    TopBar.BackgroundColor3 = T.Top
    Title.TextColor3 = T.Text
    MainStroke.Color = T.Stroke
    ContentFrame.BackgroundColor3 = T.Bg
    ContentFrame.ScrollBarImageColor3 = T.Accent
    for _, obj in ipairs(MainFrame:GetDescendants()) do
        if obj:IsA("TextLabel") or obj:IsA("TextBox") then
            obj.TextColor3 = T.Text
        end
        if obj:IsA("Frame") and obj ~= MainFrame and obj ~= TopBar and obj ~= TabContainer then
            if obj.BackgroundTransparency == 0 then
                obj.BackgroundColor3 = T.Bg
            end
        end
        if obj:IsA("UIStroke") then
            obj.Color = T.Stroke
        end
    end
end

local function CreateTab(name)
